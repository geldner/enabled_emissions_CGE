    192       ----------
    193       A-0. FILES
    194       ----------
    195   >!
    196    
    197   File
    198       GTAPSETS # file with set specification #;
    199   File
    200       GTAPDATA # file containing all Base Data #;
    201   File
    202       GTAPPARM # file containing behavioral parameters #;
    203   File (new)
    204       GTAPSUM # file containing data summary and accounting checks #;
    205    
    206   !<
    207       --------------------
    208       A-1. SET definitions
    209       --------------------
    210    
    211       Sets define relevant groupings of entities over which we will be performing
    212       operations in the model. SUBSETS are defined in order to facilitate
    213       summation over only a portion of a given group, e.g., margin commodities.
    214    
    215       The GTAP Model requires separate SET specification for activities and
    216       commodities because of multi-production possibilities--i.e., a single
    217       activity could produce multiple commodities (e.g., an agriculture activity
    218       producing multiple agricultural commodities), or for a commodity to be
    219       produced by multiple activities (e.g., electricity being produced by
    220       different generation activities).
    221    
    222       Although the standard GTAP Data Base has a diagonal 'make' matrix, it is
    223       possible to aggregate it such that the resulting aggregated
    224       database would have a non-diagonal 'make' matrix structure.
    225    
    226       Aide-Memoire for Sets and indices
    227       ---------------------------------
    228    
    229       Activities
    230       |-----------|
    231       |  ACTS(a)  |
    232       |-----------|
    233    
    234       Commodities
    235       |-----------------------|
    236       |        COMM(c)        |
    237       |-----------------------|
    238       |  MARG(m)  |  NMRG(n)  |
    239       |-----------------------|
    240    
    241       Endowments
    242       |---------------------------------------------------|
    243       |                      ENDW(e)                      |
    244       |---------------------------------------------------|
    245       |  ENDWF(e)  |  ENDWC(e)  |  ENDWM(e)  |  ENDWS(e)  |
    246       |---------------------------------------------------|
    247                    |              ENDWMS(e)               |
    248                    |--------------------------------------|
    249    
    250    
    251       Commodities and endowments
    252       |-----------------------|
    253       |        DEMD(d)        |
    254       |-----------------------|
    255       |  COMM(c)  |  ENDW(e)  |
    256       |-----------------------|
    257    
    258   >!
    259    
    260   Coefficient
    261       VERNUM # version of GTAP Data Base #;
    262   Read
    263       VERNUM from file GTAPDATA header "DVER";
    264   Update (change)
    265       VERNUM = 0.0; ! force it to be copied to update file !
    266    
    267   Set
    268       REG # regions #
    269       read elements from file GTAPSETS header "REG";
    270   Set
    271       COMM # commodities #
    272       read elements from file GTAPSETS header "COMM";
    273   Set
    274       MARG # margin commodities #
    275       read elements from file GTAPSETS header "MARG";
    276   Subset
    277       MARG is subset of COMM;
    278   Set
    279       NMRG # non-margin commodities # = COMM - MARG;
    280   Set
    281       ACTS # activities #
    282       read elements from file GTAPSETS header "ACTS";
    283   Set
    284       ENDW # endowments #
    285       read elements from file GTAPSETS header "ENDW";
    286   Set !< The single element ENDWC set is defined for the sake of convenience >!
    287       ENDWC # capital endowment # (capital);
    288       ! read elements from file GTAPSETS header "ENDC"; !
    289   Subset
    290       ENDWC is subset of ENDW;
    291   Set
    292       ENDWT # endowment types # (mobile, sluggish, fixed);
    293   Coefficient (parameter)(all,e,ENDW)(all,t,ENDWT)
    294       ENDOWFLAG(e,t) # binary (1,0) flag for endowment mobility #;
    295   Read
    296       ENDOWFLAG from file GTAPPARM header "EFLG";
    297   Assertion # checking just 1 non-zero in each factor row #
    298       (all,e,ENDW) sum{t,ENDWT: ENDOWFLAG(e,t) ne 0, 1} = 1;
    299   Set
    300       ENDWM # mobile endowments # = (all,e,ENDW:ENDOWFLAG(e,"mobile") ne 0);
    301   Subset
    302       ENDWM is subset of ENDW;
Declaration of 'ENDWM' as a SUBSET of 'ENDW'.
%% Information only. 
    This subset relation is a consequence of earlier subset declarations.
    303   Set
    304       ENDWS # sluggish endowment # = (all,e,ENDW:ENDOWFLAG(e,"sluggish") ne 0);
    305   Subset
    306       ENDWS is subset of ENDW;
Declaration of 'ENDWS' as a SUBSET of 'ENDW'.
%% Information only. 
    This subset relation is a consequence of earlier subset declarations.
    307   Set
    308       ENDWMS # mobile and sluggish endowments # = ENDWM + ENDWS;
    309   Subset
    310       ENDWMS is subset of ENDW;
    311   Subset
    312       ENDWC is subset of ENDWMS;
    313   Set
    314       ENDWF # Sector-specific endowment # = ENDW - ENDWMS;
    315   Set
    316       DEMD # demanded commodities and endowments # = ENDW + COMM;
    317   Set
    318       ENDWXC # all endowments except capital # = ENDW - ENDWC;
    319   Set
    320       ENDWMSXC # mobile and sluggish endowments except capital # = ENDWMS - ENDWC;
    321   Subset
    322       ENDWS is subset of ENDWMSXC;
    323    
    324   !<
    325       Sets for GTAP-E
    326       ---------------
    327   >!
    328   Set
    329       CTAX # commodities subject to carbon tax #
    330       read elements from file GTAPSETS header "CTAX";
    331   Subset
    332       CTAX is subset of COMM;
    333   Set
    334       EGY # energy commodities #
    335       read elements from file GTAPSETS header "COME";
    336   Subset
    337       EGY is subset of COMM;
    338    
    339   !<
    340       Sets for GTAP-EP
    341       ----------------
    342   >!
    343    
    344   Set
    345       ELEC # Electricity commodity (commodities) #
    346       read elements from file GTAPSETS header "ELEC";
    347   Subset
    348       ELEC is subset of COMM;
    349   !Set
    350       ELTD # Electricity transmission and distribution commodity #
    351       read elements from file GTAPSETS header "ELTD";
    352   Subset
    353       ELTD is subset of EGY;!
    354   Set
    355       ELEA # Electricity activity (activities) #
    356       read elements from file GTAPSETS header "ELEA";
    357   Subset
    358       ELEA is subset of ACTS;
    359   Subset
    360       ELEA is subset of EGY;
    361   Set
    362       EGYVOL # Energy volumes: all energy except electicity T&D # = EGY - "TnD";
    363   Subset
    364       ELEA is subset of EGYVOL;
    365   ! End Temporary !
    366    
    367   !< Activity-specific sets >!
    368   Set
    369       SUBF # subproducts in demand by firms # (vaen, ken, eny, nely, ncoal);
    370   Set !< GTAP-Power >!
    371       ELEF # subutilities in firms' electricity consumption #
    372       read elements from file GTAPSETS header "ELEF";
    373   Set !< GTAP-Power >!
    374       EBLF # inputs into firms' base load power subutility #
    375       read elements from file GTAPSETS header "EBLF";
    376   Set !< GTAP-Power >!
    377       EPLF # inputs into firms' peak load power subutility #
    378       read elements from file GTAPSETS header "EPLF";
    379   Set !< GTAP-Power: add power subutilities, ELEF, in ALLF >!
    380       ALLF # commodities demanded by firms # = DEMD + SUBF + ELEF;
    381   Set
    382       NCOALF # inputs into non-coal energy subproduction # (oil, gas, oil_pcts);
    383   Set
    384       NELYF # inputs into non-electricity energy subproduction # (coal, ncoal);
    385   Set
    386       ENYF # inputs into energy subproduction # (ely, nely);
    387   Set
    388       KENF # inputs into capital-energy subproduction # (capital, eny);
    389   Set
    390       KEN # capital-energy subproduction # (ken);
    391   Set
    392       VAENF # inputs into value-added-energy subproduction # = ENDWXC + KEN;
    393   Subset
    394       NCOALF is subset of ALLF;
    395   Subset
    396       NELYF  is subset of ALLF;
    397   Subset
    398       ENYF   is subset of ALLF;
    399   Subset
    400       KENF   is subset of ALLF;
    401   Subset
    402       VAENF  is subset of ALLF;
    403   Set
    404       NENYF # inputs into non-energy subproduction # = COMM - EGY;
    405   Set
    406       VAEN # value-added-energy subproduction # (vaen);
    407   Set
    408       TOPF # inputs into top of production structure # = NENYF + VAEN;
    409   Subset
    410       TOPF is subset of ALLF;
    411   !< GTAP-Power: add sets and subset >!
    412   Set
    413       EGENF # inputs into firms' electricity generation nest: egen #
    414       read elements from file GTAPSETS header "EGNF";
    415   Set
    416       ELYF # inputs into firms' electricity top-nest #
    417       read elements from file GTAPSETS header "ELYF";
    418   Subset
    419       EBLF is subset of ALLF;
    420   Subset
    421       EPLF is subset of ALLF;
    422   SubSet
    423       EGENF is subset of ALLF;
    424   SubSet
    425       ELYF is subset of ALLF;
    426   !< GTAP-Power: end (add sets and subsets) >!
    427    
    428   !< Private household-specific sets >!
    429   Set
    430       SUBP # subutilities in private consumption # (eny);
    431   Set !< GTAP-Power >!
    432       ELEP # subutilities in private electricity consumption #
    433       read elements from file GTAPSETS header "ELEP";
    434   Set !< GTAP-Power >!
    435       EBLP # inputs into private base load power subutility #
    436       read elements from file GTAPSETS header "EBLP";
    437   Set !< GTAP-Power >!
    438       EPLP # inputs into private peak load power subutility #
    439       read elements from file GTAPSETS header "EPLP";
    440   Set !< GTAP-Power: add power subutilities, ELEP, in ALLP >!
    441       ALLP # commodities demanded by private # = COMM + SUBP + ELEP;
    442   Set
    443       ENYP # inputs into private energy subutility #
    444       (coal, oil, gas, oil_pcts, ely);
    445   Subset
    446       ENYP is subset of ALLP;
    447   Set
    448       NENYP # non-energy subutility commodities # = COMM - EGY;
    449   Set
    450       ENY # private energy composite # (eny);
    451   Set
    452       TOPP # inputs into top of private consumption structure # = ENY + NENYP;
    453   Subset
    454       TOPP is subset of ALLP ;
    455    
    456   !< GTAP-Power: add sets and subset >!
    457   Set
    458       EGENP # inputs into private electricity generation nest: egen #
    459       read elements from file GTAPSETS header "EGNP";
    460   Set
    461       ELYP # inputs into private electricity top-nest #
    462       read elements from file GTAPSETS header "ELYP";
    463   Subset
    464       EBLP is subset of ALLP;
    465   Subset
    466       EPLP is subset of ALLP;
    467   SubSet
    468       EGENP is subset of ALLP;
    469   SubSet
    470       ELYP is subset of ALLP;
    471   !< GTAP-Power: end (add sets and subsets) >!
    472    
    473   !< Government-specific sets >!
    474   Set
    475       SUBG # subutilities in government consumption # (eny, neny);
    476    
    477   Set !< GTAP-Power >!
    478       ELEG # subutilities in government electricity consumption #
    479       read elements from file GTAPSETS header "ELEG";
    480   Set !< GTAP-Power >!
    481       EBLG # inputs into governemnt base load power subutility #
    482       read elements from file GTAPSETS header "EBLG";
    483   Set !< GTAP-Power >!
    484       EPLG # inputs into governemnt peak load power subutility #
    485       read elements from file GTAPSETS header "EPLG";
    486   Set !< GTAP-Power: add power subutilities, ELEG, in ALLG >!
    487       ALLG # commodities demanded by government # = COMM + SUBG + ELEG;
    488   Set
    489       ENYG # energy inputs into government energy subutility #
    490       (coal, oil, gas, oil_pcts, ely);
    491   Subset
