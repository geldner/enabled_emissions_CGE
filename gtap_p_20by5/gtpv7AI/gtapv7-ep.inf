    514       ELYG is subset of ALLG;
    515   !< GTAP-Power: end (add sets and subsets) >!
    516    
    517   !< Investment-specific sets >!
    518   Set
    519       SUBI # subutilities in investment consumption # (eny, neny);
    520   Set !< GTAP-Power >!
    521       ELEI # subutilities in investment electricity consumption #
    522       read elements from file GTAPSETS header "ELEI";
    523   Set !< GTAP-Power >!
    524       EBLI # inputs into governemnt base load power subutility #
    525       read elements from file GTAPSETS header "EBLI";
    526   Set !< GTAP-Power >!
    527       EPLI # inputs into governemnt peak load power subutility #
    528       read elements from file GTAPSETS header "EPLI";
    529   Set !< GTAP-Power: add power subutilities, ELEG, in ALLI >!
    530       ALLI # commodities demanded by investment # = COMM + SUBI + ELEI;
    531   Set !< GTAP-Power: change element electricity to ely>!
    532       ENYI # energy inputs into investment energy subutility #
    533       (coal, oil, gas, oil_pcts, ely);
    534   Subset
    535       ENYI is subset of ALLI;
    536   Set
    537       NENYI # non-energy subutility commodities # = COMM - EGY;
    538   Set
    539       TOPI # inputs into top of investment demand structure # (eny, neny);
    540   Subset
    541       TOPI is subset of ALLI ;
    542   Set
    543       FUEL # fossil fuel commodities # read elements from file GTAPSETS header "FUEL";
    544   Subset
    545       FUEL is subset of COMM;
    546    
    547   !< GTAP-Power: add sets and subset >!
    548   Set
    549       EGENI # inputs into investment electricity generation nest: egen #
    550       read elements from file GTAPSETS header "EGNI";
    551   Set
    552       ELYI # inputs into investment electricity top-nest #
    553       read elements from file GTAPSETS header "ELYI";
    554   Subset
    555       EBLI is subset of ALLI;
    556   Subset
    557       EPLI is subset of ALLI;
    558   SubSet
    559       EGENI is subset of ALLI;
    560   SubSet
    561       ELYI is subset of ALLI;
    562    
    563   !< GTAP-Power: end (add sets and subsets) >!
    564    
    565   !< Define set for emissions trading >!
    566   Set BLOC # carbon trading blocs #
    567       read elements from file GTAPPARM header "TRBL";
    568   Mapping
    569       REGTOBLOC from REG to BLOC;
    570   Read (by_elements)
    571       REGTOBLOC from file GTAPPARM header "MAPB";
    572    
    573   !<
    574       -------------------
    575       A-2. READ Base Data
    576       -------------------
    577       We read in here almost all the base data, and define variables and
    578       coefficients associated with them. A few data arrays, namely: VKB,
    579       VTMFSD and DPARSUM are read in their respective modules.
    580    
    581       Data flows and prices are valued at: supplier(S)
    582                                            basic(B)
    583                                            producer(P)
    584                                            FOB exports
    585                                            CIF imports
    586    
    587       The READ statements are divided into six sections:
    588       Firms
    589       Commodity Supply
    590       Government Consumption
    591       Private Consumption
    592       Investment Consumption
    593       Saving
    594       Global Bank
    595       International Trade and Transport
    596    
    597       GTAP-E: Carbon Dioxide Emissions
    598               Carbon Taxation
    599    
    600       Since these are invariant for each solution of the model, they are termed
    601       coefficients. Coefficients are assigned upper case to distinguish them
    602       from variables (this is purely cosmetic, as GEMPACK is not case-sensitive).
    603       Variables in GEMPACK are assigned lower case labels to denote the fact that
    604       they are percentage changes. In some cases, original levels values for
    605       selected variables are defined to permit the user to compare post-simulation
    606       levels values across several simulations.
    607    
    608       The updating command indicates how the new level of the coefficient will
    609       be computed based on the previous solution of the linearized equations.
    610       Note that the notation used in the update commands is a shorthand for
    611       total differentials of these coefficient values.  Thus, w * v indicates
    612       that we want to take the total differential of W * V, plug in the
    613       calculated values of w and v, and add this to the base level in order to
    614       obtain a revised value for this product.
    615   >!
    616    
    617   Coefficient
    618       RNREG # Reciprocal of number of regions (for zerodivide default) #;
    619   Formula
    620       RNREG = 1 / sum{r,REG, 1};
    621    
    622   !<
    623       Firms
    624       -----
    625   >!
    626    
    627   !<  Domestic intermediate purchases by firms at basic prices >!
    628   Variable (orig_level=1.0)(all,c,COMM)(all,r,REG)
    629       pds(c,r) # price of domestically supplied commodity c in region r #;
    630   Variable (orig_level=VDFB)(all,c,COMM)(all,a,ACTS)(all,r,REG)
    631       qfd(c,a,r) # demand for domestic commodity c by activity a in region r #;
    632   Coefficient (ge 0)(all,c,COMM)(all,a,ACTS)(all,r,REG)
    633       VDFB(c,a,r) # expenditure on domestic c by act. a in r at basic prices #;
    634   Read
    635       VDFB from file GTAPDATA header "VDFB";
    636   Update (all,c,COMM)(all,a,ACTS)(all,r,REG)
    637       VDFB(c,a,r) = pds(c,r) * qfd(c,a,r);
    638    
    639   !<  Imported intermediate purchases by firms at basic prices >!
    640   Variable (orig_level=1.0)(all,c,COMM)(all,r,REG)
    641       pms(c,r) # price of aggregate commodity import bundle c in region r #;
    642   Variable (orig_level=VMFB)(all,c,COMM)(all,a,ACTS)(all,r,REG)
    643       qfm(c,a,r) # imported commodity c for use by activity a in region r #;
    644   Coefficient (ge 0)(all,c,COMM)(all,a,ACTS)(all,r,REG)
    645       VMFB(c,a,r) # expenditure on imported c by act. a in r at basic prices #;
    646   Read
    647       VMFB from file GTAPDATA header "VMFB";
    648   Update (all,c,COMM)(all,a,ACTS)(all,r,REG)
    649       VMFB(c,a,r) = pms(c,r) * qfm(c,a,r);
    650    
    651   !<  Domestic intermediate purchases by firms at purchaser's prices >!
    652   Variable (all,c,COMM)(all,a,ACTS)(all,r,REG)
    653       pfd(c,a,r) # price of domestic com. c purchased by act. a in region r #;
    654   Coefficient (ge 0)(all,c,COMM)(all,a,ACTS)(all,r,REG)
    655       VDFP(c,a,r) # expenditure on dom. c by act. a in r at purchaser's prices #;
    656   Read
    657       VDFP from file GTAPDATA header "VDFP";
    658   Update (all,c,COMM)(all,a,ACTS)(all,r,REG)
    659       VDFP(c,a,r) = pfd(c,a,r) * qfd(c,a,r);
    660    
    661   !<  Imported intermediate purchases by firms at purchaser's prices >!
    662   Variable (all,c,COMM)(all,a,ACTS)(all,r,REG)
    663       pfm(c,a,r) # price of imported com. c purchased by act. a in region r #;
    664   Coefficient (ge 0)(all,c,COMM)(all,a,ACTS)(all,r,REG)
    665       VMFP(c,a,r) # expenditure on imp. c by act. a in r at purchaser's prices #;
    666   Read
    667       VMFP from file GTAPDATA header "VMFP";
    668   Update (all,c,COMM)(all,a,ACTS)(all,r,REG)
    669       VMFP(c,a,r) = pfm(c,a,r) * qfm(c,a,r);
    670    
    671   Variable (all,c,COMM)(all,a,ACTS)(all,r,REG)
    672       tfd(c,a,r) # tax on domestic c purchased by act. a in r #;
    673   Coefficient (ge 0)(all,c,COMM)(all,a,ACTS)(all,r,REG)
    674       VDFPNC(c,a,r)
    675       # carbon tax-excl expenditure on dom. c by act. a in r at purchaser's prices #;
    676   Read
    677       VDFPNC from file GTAPDATA header "DFNC";
    678   Update (all,c,COMM)(all,a,ACTS)(all,r,REG)
    679       VDFPNC(c,a,r) = tfd(c,a,r) * pds(c,r) * qfd(c,a,r);
    680    
    681   Variable (all,c,COMM)(all,a,ACTS)(all,r,REG)
    682       tfm(c,a,r) # tax on imported c purchased by act. a in r #;
    683   Coefficient (ge 0)(all,c,COMM)(all,a,ACTS)(all,r,REG)
    684       VMFPNC(c,a,r)
    685       # carbon tax-excl expenditure on imp. c by act. a in r at purchaser's prices #;
    686   Read
    687       VMFPNC from file GTAPDATA header "MFNC";
    688   Update  (all,c,COMM)(all,a,ACTS)(all,r,REG)
    689       VMFPNC(c,a,r) = tfm(c,a,r) * pms(c,r) * qfm(c,a,r);
    690    
    691   !<  Endowment at supplier's (after income tax) prices >!
    692   Variable (Orig_level=1.0)(all,e,ENDW)(all,a,ACTS)(all,r,REG)
    693       pes(e,a,r) # supply (after income tax) price of e for use by a in r #;
    694   Variable (orig_level=EVOS)(all,e,ENDW)(all,a,ACTS)(all,r,REG)
    695       qes(e,a,r) # supply of endowment e for use by activity a in region r #;
    696   Coefficient (ge 0) (all,e,ENDW)(all,a,ACTS)(all,r,REG)
    697       EVOS(e,a,r) # value of e for use by a in r at supplier (after tax) prices #;
    698   Read
    699       EVOS from file GTAPDATA header "EVOS";
    700   Update (all,e,ENDW)(all,a,ACTS)(all,r,REG)
    701       EVOS(e,a,r) = pes(e,a,r) * qes(e,a,r);
    702    
    703   !<  Endowments at basic (income tax inclusive) prices >!
    704   Variable (all,e,ENDW)(all,a,ACTS)(all,r,REG)
    705       peb(e,a,r) # basic price of endowment e in act. a in region r #;
    706   Variable (orig_level=EVFB)(all,e,ENDW)(all,a,ACTS)(all,r,REG)
    707       qfe(e,a,r) # demand for endowment e by act. a in region r #;
    708   Coefficient (ge 0)(all,e,ENDW)(all,a,ACTS)(all,r,REG)
    709       EVFB(e,a,r) # expenditure on endowment e by act. a in r at basic prices #;
    710   Read
    711       EVFB from file GTAPDATA header "EVFB";
    712   Update (all,e,ENDW)(all,a,ACTS)(all,r,REG)
    713       EVFB(e,a,r) = peb(e,a,r) * qfe(e,a,r);
    714    
    715   !<  Endowments at purchaser's prices >!
    716   Variable (all,e,ENDW)(all,a,ACTS)(all,r,REG)
    717       pfe(e,a,r) # price of endowment e purchased by activity a region r #;
    718   Coefficient (ge 0)(all,e,ENDW)(all,a,ACTS)(all,r,REG)
    719       EVFP(e,a,r) # expenditure on endowment e by a in r at purchaser's prices #;
    720   Read
    721       EVFP from file GTAPDATA header "EVFP";
    722   Update (all,e,ENDW)(all,a,ACTS)(all,r,REG)
    723       EVFP(e,a,r) = pfe(e,a,r) * qfe(e,a,r);
    724    
    725   !<
    726       Commodity supply
    727       ----------------
    728   >!
    729    
    730   !<  'make' matrix at supplier's (i.e., output tax exclusive) prices >!
    731   Variable (all,c,COMM)(all,a,ACTS)(all,r,REG)
    732       ps(c,a,r) # supply price of commodity c produced by activity a in r #;
    733   Variable (all,c,COMM)(all,a,ACTS)(all,r,REG)
    734       qca(c,a,r) # supply of commodity c by activity a in r #;
    735   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
    736       MAKES(c,a,r) # 'make' matrix valued at supplier's prices #;
    737   Read
    738       MAKES from file GTAPDATA header "MAKS";
    739   Update (all,c,COMM)(all,a,ACTS)(all,r,REG)
    740       MAKES(c,a,r) = ps(c,a,r) * qca(c,a,r);
    741    
    742   !<  'make' matrix at basic (i.e., output tax inclusive) prices >!
    743   Variable (all,c,COMM)(all,a,ACTS)(all,r,REG)
    744       pca(c,a,r) # basic price of commodity c produced by activity a in r #;
    745   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
    746       MAKEB(c,a,r) # 'make' matrix valued at basic prices #;
    747   Read
    748       MAKEB from file GTAPDATA header "MAKB";
    749   Update (all,c,COMM)(all,a,ACTS)(all,r,REG)
    750       MAKEB(c,a,r) = pca(c,a,r) * qca(c,a,r);
    751    
    752   !<
    753       Government consumption
    754       ----------------------
    755   >!
    756    
    757   !<  Domestic commodity purchases by government at basic prices >!
    758   Variable (orig_level=VDGB)(all,c,COMM)(all,r,REG)
    759       qgd(c,r) # government demand for domestic commodity c in region r #;
    760   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    761       VDGB(c,r) # government expenditure on domestic c in r at basic prices #;
    762   Read
    763       VDGB from file GTAPDATA header "VDGB";
    764   Update (all,c,COMM)(all,r,REG)
    765       VDGB(c,r) = pds(c,r) * qgd(c,r);
    766    
    767   !<  Imported commodity purchases by government at basic prices >!
    768   Variable (orig_level=VMGB)(all,c,COMM)(all,r,REG)
    769       qgm(c,r) # government demand for imported commodity c in region r #;
    770   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    771       VMGB(c,r) # government expenditure on imported c in r at basic prices #;
    772   Read
    773       VMGB from file GTAPDATA header "VMGB";
    774   Update (all,c,COMM)(all,r,REG)
    775       VMGB(c,r) = pms(c,r) * qgm(c,r);
    776    
    777   !<  Domestic commodity purchases by government at purchaser's prices >!
    778   Variable (all,c,COMM)(all,r,REG)
    779       pgd(c,r) # price of domestic com. c purchased by government in region r #;
    780   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    781       VDGP(c,r) # government expenditure on dom. c in r at purchaser's prices #;
    782   Read
    783       VDGP from file GTAPDATA header "VDGP";
    784   Update (all,c,COMM)(all,r,REG)
    785       VDGP(c,r) = pgd(c,r) * qgd(c,r);
    786    
    787   !<  Imported commodity purchases by government at purchaser's prices >!
    788   Variable (all,c,COMM)(all,r,REG)
    789       pgm(c,r) # price of imported com. c purchased by government in region r #;
    790   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    791       VMGP(c,r) # government expenditure on imp. c in r at purchaser's prices #;
    792   Read
    793       VMGP from file GTAPDATA header "VMGP";
    794   Update (all,c,COMM)(all,r,REG)
    795       VMGP(c,r) = pgm(c,r) * qgm(c,r);
    796    
    797   Variable (all,c,COMM)(all,r,REG)
    798       tgd(c,r) # power of tax on domestic c purchased by government in r #;
    799   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    800       VDGPNC(c,r)
    801       # carbon tax-exclusive gov't expend. on dom. c in r at purchaser's prices #;
    802   Read
    803       VDGPNC from file GTAPDATA header "DGNC";
    804   Update (all,c,COMM)(all,r,REG)
    805       VDGPNC(c,r) = tgd(c,r) * pds(c,r) * qgd(c,r);
    806    
    807   Variable (all,c,COMM)(all,r,REG)
    808       tgm(c,r) # power of tax on domestic c purchased by government in r #;
    809   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    810       VMGPNC(c,r)
    811       # carbon tax-exclusive gov't expend. on imp. c in r at purchaser's prices #;
    812   Read
    813       VMGPNC from file GTAPDATA header "MGNC";
    814   Update (all,c,COMM)(all,r,REG)
    815       VMGPNC(c,r) = tgm(c,r) * pms(c,r) * qgm(c,r);
    816    
    817   !<
    818       Private consumption
    819       -------------------
    820   >!
    821    
    822   !<  Domestic commodity purchases by priv. household at basic prices >!
    823   Variable (orig_level=VDPB)(all,c,COMM)(all,r,REG)
    824       qpd(c,r) # private household demand for domestic commodity c in region r #;
    825   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    826       VDPB(c,r) # private household expenditure on dom. c in r at basic prices #;
    827   Read
    828       VDPB from file GTAPDATA header "VDPB";
    829   Update (all,c,COMM)(all,r,REG)
    830       VDPB(c,r) = pds(c,r) * qpd(c,r);
    831    
    832   !<  Imported commodity purchases by priv. household at basic prices >!
    833   Variable (orig_level=VMPB)(all,c,COMM)(all,r,REG)
    834       qpm(c,r) # private household demand for imported commodity c in region r #;
    835   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    836       VMPB(c,r) # private household expenditure on imp. c in r at basic prices #;
    837   Read
    838       VMPB from file GTAPDATA header "VMPB";
    839   Update (all,c,COMM)(all,r,REG)
    840       VMPB(c,r)= pms(c,r) * qpm(c,r);
    841    
    842   !<  Domesticcommodity purchases by priv. household at purchaser's prices >!
    843   Variable (all,c,COMM)(all,r,REG)
    844       ppd(c,r) # price of domestic com. c purchased by private household in r #;
    845   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    846       VDPP(c,r) # private hhld expenditure on dom. c in r at purchaser's prices #;
    847   Read
    848       VDPP from file GTAPDATA header "VDPP";
    849   Update (all,c,COMM)(all,r,REG)
    850       VDPP(c,r) = ppd(c,r) * qpd(c,r);
    851    
    852   !<  Imported commodity purchases by priv. household at purchaser's prices >!
    853   Variable (all,c,COMM)(all,r,REG)
    854       ppm(c,r) # price of imported com. c purchased by private household in r #;
    855   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    856       VMPP(c,r) # private hhld expenditure on imp. c in r at purchaser's prices #;
    857   Read
    858       VMPP from file GTAPDATA header "VMPP";
    859   Update (all,c,COMM)(all,r,REG)
    860       VMPP(c,r) = ppm(c,r) * qpm(c,r);
    861    
    862   Variable (all,c,COMM)(all,r,REG)
    863       tpd(c,r) # power of tax on domestic c purchased by private hhld in r #;
    864   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    865       VDPPNC(c,r)
    866       # carbon tax-excl private hhld expend. on dom. c in r at purchaser's prices #;
    867   Read
    868       VDPPNC from file GTAPDATA header "DPNC";
    869   Update (all,c,COMM)(all,r,REG)
    870       VDPPNC(c,r) = tpd(c,r) * pds(c,r) * qpd(c,r);
    871    
    872   Variable (all,c,COMM)(all,r,REG)
    873       tpm(c,r) # power of tax on imported c purchased by private hhld in r #;
    874   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    875       VMPPNC(c,r)
    876       # carbon tax-excl private hhld expend. on imp. c in r at purchaser's prices #;
    877   Read
    878       VMPPNC from file GTAPDATA header "MPNC";
    879   Update (all,c,COMM)(all,r,REG)
    880       VMPPNC(c,r) = tpm(c,r) * pms(c,r) * qpm(c,r);
    881    
    882    
    883   !<
    884       Investment consumption
    885       ----------------------
    886   >!
    887    
    888   !<  Domestic commodity purchases by investment agent at basic prices >!
    889   Variable (orig_level=VDIB)(all,c,COMM)(all,r,REG)
    890       qid(c,r) # investment demand for domestic commodity c in region r #;
    891   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    892       VDIB(c,r) # investment expenditure on domestic c in r at basic prices #;
    893   Read
    894       VDIB from file GTAPDATA header "VDIB";
    895   Update (all,c,COMM)(all,r,REG)
    896       VDIB(c,r) = pds(c,r) * qid(c,r);
    897    
    898   !<  Imported commodity purchases by investment agent at basic prices >!
    899   Variable (orig_level=VMIB)(all,c,COMM)(all,r,REG)
    900       qim(c,r) # investment demand for imported commodity c in region r #;
    901   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    902       VMIB(c,r) # investment expenditure on imported c in r at basic prices #;
    903   Read
    904       VMIB from file GTAPDATA header "VMIB";
    905   Update (all,c,COMM)(all,r,REG)
    906       VMIB(c,r) = pms(c,r) * qim(c,r);
    907    
    908   !<  Domestic commodity purchases by investment agent at purchaser's prices >!
    909   Variable (all,c,COMM)(all,r,REG)
    910       pid(c,r) # price of domestic com. c purchased by investment agent in r #;
    911   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    912       VDIP(c,r) # investment expenditure on dom. c in r at purchaser's prices #;
    913   Read
    914       VDIP from file GTAPDATA header "VDIP";
    915   Update (all,c,COMM)(all,r,REG)
    916       VDIP(c,r) = pid(c,r) * qid(c,r);
    917    
    918   !<  Imported commodity purchases by investment agent at purchaser's prices >!
    919   Variable (all,c,COMM)(all,r,REG)
    920       pim(c,r) # price of imported com. c purchased by investment agent in r #;
    921   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    922       VMIP(c,r) # investment expenditure on imp. c in r at purchaser's prices #;
    923   Read
    924       VMIP from file GTAPDATA header "VMIP";
    925   Update (all,c,COMM)(all,r,REG)
    926       VMIP(c,r) = pim(c,r) * qim(c,r);
    927    
    928   Variable (all,c,COMM)(all,r,REG)
    929       tid(c,r) # power of tax on domestic invesment commodity c in region r #;
    930   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    931       VDIPNC(c,r)
    932       # carbon tax-excl investment expend. on dom. c in r at purchaser's prices #;
    933   Read
    934       VDIPNC from file GTAPDATA header "DINC";
    935   Update (all,c,COMM)(all,r,REG)
    936       VDIPNC(c,r) = tid(c,r) * pds(c,r) * qid(c,r);
    937    
    938   Variable (all,c,COMM)(all,r,REG)
    939       tim(c,r) # power of tax on imported invesment commodity c in region r #;
    940   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
    941       VMIPNC(c,r)
    942       # carbon tax-excl investment expend. on imp. c in r at purchaser's prices #;
    943   Read
    944       VMIPNC from file GTAPDATA header "MINC";
    945   Formula (initial)(all,c,COMM)(all,r,REG)
    946       VMIPNC(c,r) = VMIP(c,r);
    947   Update (all,c,COMM)(all,r,REG)
    948       VMIPNC(c,r) = tim(c,r) * pms(c,r) * qim(c,r);
    949    
    950   !<
    951       Saving
    952       ------
    953   >!
    954    
    955   Variable (all,r,REG)
    956       psave(r) # price of saving in region r #;
    957   Variable (all,r,REG)
    958       qsave(r) # regional demand for NET saving #;
    959   Coefficient (all,r,REG)
    960       SAVE(r) # NET saving in region r valued at purchaser's prices #;
    961   Read
    962       SAVE from file GTAPDATA header "SAVE";
    963   Update (all,r,REG)
    964       SAVE(r) = psave(r) * qsave(r);
    965    
    966   !<
    967       Global bank
    968       -----------
    969   >!
    970    
    971   Variable (all,r,REG)
    972       pinv(r) # price index of investment goods #;
    973   Variable (all,r,REG)
    974       kb(r) # beginning-of-period capital stock in r #;
    975   Coefficient (ge 0)(all,r,REG)
    976       VDEP(r) # value of capital depeciation in r (exogenous) #;
    977   Read
    978       VDEP from file GTAPDATA header "VDEP";
    979   Update (all,r,REG)
    980       VDEP(r) = pinv(r) * kb(r);
    981   !<
    982       Value of capital depreciation is used to compute the (exogenous)
    983       depreciation rate and therefore does not appear in update.
    984   >!
    985    
    986   !<
    987       International trade
    988       -------------------
    989   >!
    990    
    991   !<  Exports at basic prices >!
    992   Variable (orig_level=VXSB)(all,c,COMM)(all,s,REG)(all,d,REG)
    993       qxs(c,s,d) # export sales of commodity c from source s to destination d #;
    994   Coefficient (ge 0)(all,c,COMM)(all,s,REG)(all,d,REG)
    995       VXSB(c,s,d)
    996       # value of exports of  c from s to d at basic prices (tradeables only) #;
    997   Read
    998       VXSB from file GTAPDATA header "VXSB";
    999   Update (all,c,COMM)(all,s,REG)(all,d,REG)
   1000       VXSB(c,s,d) = pds(c,s) * qxs(c,s,d);
   1001    
   1002   !<  Exports at FOB (i.e., exports tax inclusive) prices >!
   1003   Variable (all,c,COMM)(all,s,REG)(all,d,REG)
   1004       pfob(c,s,d) # FOB world price of com. c from source s to destination d #;
   1005   Coefficient (ge 0)(all,c,COMM)(all,s,REG)(all,d,REG)
   1006       VFOB(c,s,d)
   1007       # value of exports of c from s to d at FOB prices (tradeables only) #;
   1008   Read
   1009       VFOB from file GTAPDATA header "VFOB";
   1010   Update (all,c,COMM)(all,s,REG)(all,d,REG)
   1011       VFOB(c,s,d) = pfob(c,s,d) * qxs(c,s,d);
   1012    
   1013   !<  Imports at CIF prices >!
   1014   Variable (all,c,COMM)(all,s,REG)(all,d,REG)
   1015       pcif(c,s,d) # CIF world price of imported com. c from source s to dest. d #;
   1016   Coefficient (ge 0)(all,c,COMM)(all,s,REG)(all,d,REG)
   1017       VCIF(c,s,d)
   1018       # value of imports of c from s to d at CIF prices (tradeables only) #;
   1019   Read
   1020       VCIF from file GTAPDATA header "VCIF";
   1021   Update (all,c,COMM)(all,s,REG)(all,d,REG)
   1022       VCIF(c,s,d) = pcif(c,s,d) * qxs(c,s,d);
   1023    
   1024   !<  Imports at basic (import tariff inclusive) prices >!
   1025   Variable (all,c,COMM)(all,s,REG)(all,d,REG)
   1026       pmds(c,s,d) # price of imported c supplied by source region s to dest. d #;
   1027   Coefficient (ge 0)(all,c,COMM)(all,s,REG)(all,d,REG)
   1028       VMSB(c,s,d)
   1029       # value of imports of c from s to d at domestic (basic) prices #;
   1030   Read
   1031       VMSB from file GTAPDATA header "VMSB";
   1032   Update (all,c,COMM)(all,s,REG)(all,d,REG)
   1033       VMSB(c,s,d) = pmds(c,s,d) * qxs(c,s,d);
   1034    
   1035   !<
   1036       International transport margins
   1037       -------------------------------
   1038   >!
   1039    
   1040   Variable (orig_level=VST)(all,m,MARG)(all,r,REG)
   1041       qst(m,r) # supply of margin m from region r for international transport #;
   1042   Coefficient (ge 0)(all,m,MARG)(all,r,REG)
   1043       VST(m,r)
   1044       # value of exports of margin m from r for int'l transport at basic prices #;
   1045   Read
   1046       VST from file GTAPDATA header "VST";
   1047   Update (all,m,MARG)(all,r,REG)
   1048       VST(m,r) = pds(m,r) * qst(m,r);
   1049    
   1050   !<
   1051       Carbon Dioxide Emissions
   1052       ------------------------
   1053   >!
   1054   Variable (all,r,REG)
   1055       gco2t(r) # aggregate carbon dioxide emissions in region r#;
   1056    
   1057   Variable (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1058       gco2fd(c,a,r) # CO2 emissions from firms' use of domestic c in region r #;
   1059   Coefficient (ge 0)(all,f,FUEL)(all,a,ACTS)(all,r,REG)
   1060       MDF(f,a,r)  # CO2 emissions from firms' use of domestic c in region r #;
   1061   Read
   1062       MDF from file GTAPDATA header "MDF";
   1063   Update (all,f,FUEL)(all,a,ACTS)(all,r,REG)
   1064       MDF(f,a,r) = gco2fd(f,a,r);
   1065   Coefficient (ge 0)(all,c,COMM)(all,a,ACTS)(all,r,REG)
   1066       CO2DF(c,a,r)  # CO2 emissions from firms' use of domestic c in region r #;
   1067   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1068       CO2DF(c,a,r) = 0;
   1069   Formula (all,f,FUEL)(all,a,ACTS)(all,r,REG)
   1070       CO2DF(f,a,r) = MDF(f,a,r);
   1071    
   1072   Variable (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1073       gco2fm(c,a,r) # CO2 emissions from firms' use of imported c in region r #;
   1074   Coefficient (ge 0)(all,f,FUEL)(all,a,ACTS)(all,r,REG)
   1075       MMF(f,a,r)  # CO2 emissions from firms' use of imported c in region r #;
   1076   Read
   1077       MMF from file GTAPDATA header "MMF";
   1078   Update (all,f,FUEL)(all,a,ACTS)(all,r,REG)
   1079       MMF(f,a,r) = gco2fm(f,a,r);
   1080   Coefficient (ge 0)(all,c,COMM)(all,a,ACTS)(all,r,REG)
   1081       CO2MF(c,a,r)  # CO2 emissions from firms' use of imported c in region r #;
   1082   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1083       CO2MF(c,a,r) = 0;
   1084   Formula (all,f,FUEL)(all,a,ACTS)(all,r,REG)
   1085       CO2MF(f,a,r) = MMF(f,a,r);
   1086    
   1087   !<  Carbon emissions associated with government's use of commodities >!
   1088   Variable (all,c,COMM)(all,r,REG)
   1089       gco2gd(c,r) # CO2 emissions from govt's use of domestic c in region r #;
   1090   Coefficient (ge 0)(all,f,FUEL)(all,r,REG)
   1091       MDG(f,r)  # CO2 emissions from govt's use of domestic c in region r #;
   1092   Read
   1093       MDG from file GTAPDATA header "MDG";
   1094   Update (all,f,FUEL)(all,r,REG)
   1095       MDG(f,r) = gco2gd(f,r);
   1096   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
   1097       CO2DG(c,r)  # CO2 emissions from govt's use of domestic c in region r #;
   1098   Formula (all,c,COMM)(all,r,REG)
   1099       CO2DG(c,r) = 0;
   1100   Formula (all,f,FUEL)(all,r,REG)
   1101       CO2DG(f,r) = MDG(f,r);
   1102    
   1103   Variable (all,c,COMM)(all,r,REG)
   1104       gco2gm(c,r) # CO2 emissions from govt's use of imported c in region r #;
   1105   Coefficient (ge 0)(all,f,FUEL)(all,r,REG)
   1106       MMG(f,r)  # CO2 emissions from govt's use of imported c in region r #;
   1107   Read
   1108       MMG from file GTAPDATA header "MMG";
   1109   Update (all,f,FUEL)(all,r,REG)
   1110       MMG(f,r) = gco2gm(f,r);
   1111   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
   1112       CO2MG(c,r)  # CO2 emissions from govt's use of imported c in region r #;
   1113   Formula (all,c,COMM)(all,r,REG)
   1114       CO2MG(c,r) = 0;
   1115   Formula (all,f,FUEL)(all,r,REG)
   1116       CO2MG(f,r) = MMG(f,r);
   1117    
   1118   !<  Carbon emissions associated with private household's use of commodities >!
   1119   Variable (all,c,COMM)(all,r,REG)
   1120       gco2pd(c,r) # CO2 emissions from private hhld's use of domestic c in region r #;
   1121   Coefficient (ge 0)(all,f,FUEL)(all,r,REG)
   1122       MDP(f,r)  # CO2 emissions from private hhld's use of domestic c in region r #;
   1123   Read
   1124       MDP from file GTAPDATA header "MDP";
   1125   Update (all,f,FUEL)(all,r,REG)
   1126       MDP(f,r) = gco2pd(f,r);
   1127   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
   1128       CO2DP(c,r)  # CO2 emissions from private hhld's use of domestic c in region r #;
   1129   Formula (all,c,COMM)(all,r,REG)
   1130       CO2DP(c,r) = 0;
   1131   Formula (all,f,FUEL)(all,r,REG)
   1132       CO2DP(f,r) = MDP(f,r);
   1133    
   1134   Variable (all,c,COMM)(all,r,REG)
   1135       gco2pm(c,r) # CO2 emissions from private hhld's use of imported c in region r #;
   1136   Coefficient (ge 0)(all,f,FUEL)(all,r,REG)
   1137       MMP(f,r)  # CO2 emissions from private hhld's use of imported c in region r #;
   1138   Read
   1139       MMP from file GTAPDATA header "MMP";
   1140   Update (all,f,FUEL)(all,r,REG)
   1141       MMP(f,r) = gco2pm(f,r);
   1142   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
   1143       CO2MP(c,r)  # CO2 emissions from private hhld's use of imported c in region r #;
   1144   Formula (all,c,COMM)(all,r,REG)
   1145       CO2MP(c,r) = 0;
   1146   Formula (all,f,FUEL)(all,r,REG)
   1147       CO2MP(f,r) = MMP(f,r);
   1148    
   1149   !<  Carbon emissions associated with investment demand >!
   1150   Variable (all,c,COMM)(all,r,REG)
   1151       gco2id(c,r) # CO2 emissions from investment demand for domestic c in region r #;
   1152   Coefficient (ge 0)(all,f,FUEL)(all,r,REG)
   1153       MDI(f,r)  # CO2 emissions from investment demand for domestic c in region r #;
   1154   Read
   1155       MDI from file GTAPDATA header "MDI";
   1156   Update (all,f,FUEL)(all,r,REG)
   1157       MDI(f,r) = gco2id(f,r);
   1158   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
   1159       CO2DI(c,r)  # CO2 emissions from investment demand for domestic c in region r #;
   1160   Formula (all,c,COMM)(all,r,REG)
   1161       CO2DI(c,r) = 0;
   1162   Formula (all,f,FUEL)(all,r,REG)
   1163       CO2DI(f,r) = MDI(f,r);
   1164    
   1165   Variable (all,c,COMM)(all,r,REG)
   1166       gco2im(c,r) # CO2 emissions from investment demand for imported c in region r #;
   1167   Coefficient (ge 0)(all,f,FUEL)(all,r,REG)
   1168       MMI(f,r)  # CO2 emissions from investment demand for imported c in region r #;
   1169   Read
   1170       MMI from file GTAPDATA header "MMI";
   1171   Update (all,f,FUEL)(all,r,REG)
   1172       MMI(f,r) = gco2im(f,r);
   1173   Coefficient (ge 0)(all,c,COMM)(all,r,REG)
   1174       CO2MI(c,r)  # CO2 emissions from investment demand for imported c in region r #;
   1175   Formula (all,c,COMM)(all,r,REG)
   1176       CO2MI(c,r) = 0;
   1177   Formula (all,f,FUEL)(all,r,REG)
   1178       CO2MI(f,r) = MMI(f,r);
   1179    
   1180   ! carbon dioxide emissions !
   1181   Coefficient(all,r,REG)(all,c,COMM)
   1182       CO2(r,c) # carbon dioxide emissions (millions of tonnes of CO2) #;
   1183   Formula (all,r,REG)(all,c,COMM)
   1184       CO2(r,c) = sum{a,ACTS, CO2DF(c,a,r) + CO2MF(c,a,r)}
   1185                + CO2DG(c,r) + CO2MG(c,r)  + CO2DP(c,r) + CO2MP(c,r)
   1186                + CO2DI(c,r) + CO2MI(c,r);
   1187    
   1188   Coefficient (all,r,REG)
   1189       CO2T(r) # carbon dioxide emissions (millions of tonnes of CO2) #;
   1190   Formula (all,r,REG)
   1191       CO2T(r) = sum{c,CTAX, CO2(r,c)};
   1192    
   1193   Coefficient (all,b,BLOC)
   1194       CO2TB(b)# carbon dioxide emissions (millions of tonnes of CO2) #;
   1195   Formula (all,b,BLOC)
   1196       CO2TB(b) = sum{r,REG: REGTOBLOC(r) = b, CO2T(r)};
   1197    
   1198   !<
   1199       Carbon Taxation
   1200       ---------------
   1201   >!
   1202   Variable (change) (all,r,REG)
   1203       del_dvco2tra(r) # net emissions trading revenue #;
   1204   Variable (change) (all,b,BLOC)
   1205       del_nctaxb(b) # nominal carbon tax (current USD per tonne of CO2) #;
   1206   Coefficient (all,r,REG)
   1207       NCTAXLEV(r) # nominal carbon tax Level (current USD per tonne of CO2) #;
   1208   Read
   1209       NCTAXLEV from file GTAPDATA header "NTAX";
   1210   Update (change) (all,r,REG)
   1211       NCTAXLEV(r) = del_nctaxb(REGTOBLOC(r));
   1212    
   1213   !<
   1214       -------------------------------------
   1215       A-3. Key derivatives of the Base Data
   1216       -------------------------------------
   1217    
   1218       Key derivatives of the Base Data
   1219       Regional expenditure and income
   1220       Indirect tax receipts
   1221       Miscellaneous coefficients and parameters
   1222    
   1223   >!
   1224    
   1225   !<  Intermediate and endowment expenditure by firms at purchaser's prices >!
   1226   Coefficient (all,d,ALLF)(all,a,ACTS)(all,r,REG)
   1227       VFP(d,a,r) # expenditure on d by act. a in r valued at purchaser's prices #;
   1228   Formula (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   1229       VFP(e,a,r) = EVFP(e,a,r);
   1230   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1231       VFP(c,a,r) = VDFP(c,a,r) + VMFP(c,a,r);
   1232    
   1233   !<  Value of output at supplier's prices >!
   1234   Coefficient (all,a,ACTS)(all,r,REG)
   1235       VOS(a,r) # output of act. a in r valued at supplier's prices #;
   1236   Formula (all,a,ACTS)(all,r,REG)
   1237       VOS(a,r) = sum{d,DEMD, VFP(d,a,r)};
   1238    
   1239   !<  Endowments >!
   1240   Coefficient (all,e,ENDW)(all,r,REG)
   1241       VES(e,r) # endowment supply in region r, at supplier's (after tax) prices #;
   1242   Formula (all,e,ENDW)(all,r,REG)
   1243       VES(e,r) = sum{a,ACTS, EVOS(e,a,r)};
   1244    
   1245   !< Commodity supply >!
   1246   Coefficient (all,a,ACTS)(all,r,REG)
   1247       MAKEBACT(a,r) # total output of activity a valued at basic prices #;
   1248   Formula (all,a,ACTS)(all,r,REG)
   1249       MAKEBACT(a,r) = sum{c,COMM, MAKEB(c,a,r)};
   1250    
   1251   Coefficient (all,c,COMM)(all,r,REG)
   1252       MAKEBCOM(c,r) # supply of commodity c valued at basic prices #;
   1253   Formula (all,c,COMM)(all,r,REG)
   1254       MAKEBCOM(c,r) = sum{a,ACTS, MAKEB(c,a,r)};
   1255    
   1256   Coefficient (all,c,COMM)(all,r,REG)
   1257       VDB(c,r) # domestic sales of c in r at basic prices (tradeables only) #;
   1258   Formula (all,c,COMM)(all,r,REG)
   1259       VDB(c,r) = VDPB(c,r) + VDGB(c,r) + VDIB(c,r) + sum{a,ACTS, VDFB(c,a,r)};
   1260    
   1261   !<  Commodity supply = Commodity demand >!
   1262   Coefficient (all,c,COMM)(all,r,REG)
   1263       VCB(c,r) # supply of commodity c in region r valued at basic prices #;
   1264   Formula (all,c,COMM)(all,r,REG)
   1265       VCB(c,r) = VDB(c,r) + sum{d,REG, VXSB(c,r,d)} + IF[c in MARG, VST(c,r)];
   1266    
   1267   !<
   1268       Regional expenditure and income
   1269       -------------------------------
   1270    
   1271       Regional income is allocated between private consumption expenditure,
   1272       government consumption expenditure, and saving.
   1273    
   1274       Expenditure of Regional household
   1275       .................................
   1276    
   1277                      Regional household(h.h.)
   1278                       Expenditure = Income
   1279                                _/|\_
   1280                              _/  |  \_
   1281                            _/    |    \_
   1282                          _/      |      \_
   1283                        _/        |        \_
   1284              Private h.h.        |        Government h.h.
   1285              ( PRIVEXP )         |          ( GOVEXP )
   1286                 _/\_             |              _/\_  <---(CES: ESUBG)
   1287               _/    \_           |            _/    \_
   1288              /        \          |           /        \
   1289           Domestic  Imported   Saving    Domestic    Imported
   1290            Goods     Goods     ( SAVE )    Goods       Goods
   1291           ( VDPP )  ( VMPP )              ( VDGP )    ( VMGP )
   1292    
   1293       Note: The coefficients at the ends of branches are
   1294             Base Data, e.g., VDPP, SAVE.
   1295   >!
   1296    
   1297   !< Government consumption expenditure, GOVEXP >!
   1298   Coefficient (all,c,COMM)(all,r,REG)
   1299       VGPT(c,r) # government cons. expenditure on c in r at purchaser's prices #;
   1300   Formula (all,c,COMM)(all,r,REG)
   1301       VGPT(c,r) = VDGP(c,r) + VMGP(c,r);
   1302   Coefficient (all,r,REG)
   1303       GOVEXP(r) # aggregate government expenditure in region r #;
   1304   Formula (all,r,REG)
   1305       GOVEXP(r) = sum{c,COMM, VGPT(c,r)};
   1306    
   1307   !< Private household consumption expenditure, PRIVEXP >!
   1308   Coefficient (all,c,COMM)(all,r,REG)
   1309       VPPT(c,r) # private household expenditure on c in r at purchaser's prices #;
   1310   Formula (all,c,COMM)(all,r,REG)
   1311       VPPT(c,r) = VDPP(c,r) + VMPP(c,r);
   1312   Coefficient (all,r,REG)
   1313       PRIVEXP(r) # aggregate private consumption expenditure in region r #;
   1314   Formula (all,r,REG)
   1315       PRIVEXP(r) = sum{c,COMM, VPPT(c,r)};
   1316    
   1317   Coefficient (all,c,ALLP)(all,r,REG)
   1318       VPP(c,r) # private household expenditure on c in r at purchaser's prices #;
   1319   Formula (all,c,ALLP)(all,r,REG)
   1320       VPP(c,r) = 0.0;
   1321   Formula (all,c,COMM)(all,r,REG)
   1322       VPP(c,r) = VPPT(c,r);
   1323    
   1324   !< Investment consumption expenditure >!
   1325   Coefficient (all,c,COMM)(all,r,REG)
   1326       VIPT(c,r) # expenditure on investment c valued at purchaser's prices #;
   1327   Formula (all,c,COMM)(all,r,REG)
   1328       VIPT(c,r) = VDIP(c,r) + VMIP(c,r);
   1329    
   1330   !< Aggregate income = aggregate expenditure + saving >!
   1331   Coefficient (all,r,REG)
   1332       INCOME(r) # level of expenditure, which equals NET income in region r #;
   1333   Formula (all,r,REG)
   1334       INCOME(r) = PRIVEXP(r) + GOVEXP(r) + SAVE(r);
   1335    
   1336   !<
   1337       Indirect tax receipts
   1338       ---------------------
   1339   >!
   1340    
   1341   !< Production tax revenue >!
   1342   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1343       PTAX(c,a,r) # revenue from tax on commodity c produced by activity a in r #;
   1344   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1345       PTAX(c,a,r) = MAKEB(c,a,r) - MAKES(c,a,r);
   1346   Coefficient (all,r,REG)
   1347       TAXROUT(r) # total revenue from production tax payments in region r #;
   1348   Formula (all,r,REG)
   1349       TAXROUT(r) = sum{c,COMM, sum{a,ACTS, PTAX(c,a,r)}};
   1350    
   1351   !< Government consumption tax revenue >!
   1352   Coefficient (all,c,COMM)(all,r,REG)
   1353       DGTAX(c,r) # tax revenue from gov't cons. of domestic c in region r #;
   1354   Formula (all,c,COMM)(all,r,REG)
   1355       DGTAX(c,r) = VDGPNC(c,r) - VDGB(c,r);
   1356   Coefficient (all,c,COMM)(all,r,REG)
   1357       MGTAX(c,r) # tax revenue from gov't consumption of imported c in region r #;
   1358   Formula (all,c,COMM)(all,r,REG)
   1359       MGTAX(c,r) = VMGPNC(c,r) - VMGB(c,r);
   1360   !< Carbon tax revenue from government consumption >!
   1361   Coefficient (all,c,COMM)(all,r,REG)
   1362       DGCTAX(c,r) # carbon tax revenue from gov't consumption of dom. c in r #;
   1363   Formula (all,c,COMM)(all,r,REG)
   1364       DGCTAX(c,r) = VDGP(c,r) - VDGPNC(c,r);
   1365   Coefficient (all,c,COMM)(all,r,REG)
   1366       MGCTAX(c,r) # carbon tax revenue from gov't consumption of dom. c in r #;
   1367   Formula (all,c,COMM)(all,r,REG)
   1368       MGCTAX(c,r) = VMGP(c,r) - VMGPNC(c,r);
   1369   Coefficient (all,r,REG)
   1370       TAXRGC(r) # total revenue from government consumption tax payments in r #;
   1371   Formula (all,r,REG)
   1372       TAXRGC(r) = sum{c,COMM, DGTAX(c,r) + MGTAX(c,r)};
   1373    
   1374   !< Private household consumption tax revenue >!
   1375   Coefficient (all,c,COMM)(all,r,REG)
   1376       DPTAX(c,r) # tax revenue from priv. hhld cons. of domestic c in region r #;
   1377   Formula (all,c,COMM)(all,r,REG)
   1378       DPTAX(c,r) = VDPPNC(c,r) - VDPB(c,r);
   1379   Coefficient (all,c,COMM)(all,r,REG)
   1380       MPTAX(c,r) # tax revenue from priv. hhld cons. of imported c in region r #;
   1381   Formula (all,c,COMM)(all,r,REG)
   1382       MPTAX(c,r) = VMPPNC(c,r) - VMPB(c,r);
   1383   !< Carbon tax revenue from private household consumption >!
   1384   Coefficient (all,c,COMM)(all,r,REG)
   1385       DPCTAX(c,r) # carbon tax revenue priv. hhld cons. of domestic c in r #;
   1386   Formula (all,c,COMM)(all,r,REG)
   1387       DPCTAX(c,r) = VDPP(c,r) - VDPPNC(c,r);
   1388   Coefficient (all,c,COMM)(all,r,REG)
   1389       MPCTAX(c,r) # carbon tax revenue priv. hhld cons. of importer c in r #;
   1390   Formula (all,c,COMM)(all,r,REG)
   1391       MPCTAX(c,r) = VMPP(c,r) - VMPPNC(c,r);
   1392   Coefficient (all,r,REG)
   1393       TAXRPC(r) # total revenue from priv. hhld consumption tax payments in r #;
   1394   Formula (all,r,REG)
   1395       TAXRPC(r) = sum{c,COMM, DPTAX(c,r) + MPTAX(c,r)};
   1396    
   1397   !< Investment consumption tax revenue >!
   1398   Coefficient (all,c,COMM)(all,r,REG)
   1399       DITAX(c,r) # tax revenue from investment cons. of domestic c in region r #;
   1400   Formula (all,c,COMM)(all,r,REG)
   1401       DITAX(c,r) = VDIPNC(c,r) - VDIB(c,r);
   1402   Coefficient (all,c,COMM)(all,r,REG)
   1403       MITAX(c,r) # tax revenue from investment cons. of imported c in region r #;
   1404   Formula (all,c,COMM)(all,r,REG)
   1405       MITAX(c,r) = VMIPNC(c,r) - VMIB(c,r);
   1406   !< Carbon tax revenue from investment consumption >!
   1407   Coefficient (all,c,COMM)(all,r,REG)
   1408       DICTAX(c,r) # carbon tax revenue investment cons. of domestic c in r #;
   1409   Formula (all,c,COMM)(all,r,REG)
   1410       DICTAX(c,r) = VDIP(c,r) - VDIPNC(c,r);
   1411   Coefficient (all,c,COMM)(all,r,REG)
   1412       MICTAX(c,r) # carbon tax revenue investment cons. of imported c in r #;
   1413   Formula (all,c,COMM)(all,r,REG)
   1414       MICTAX(c,r) = VMIP(c,r) - VMIPNC(c,r);
   1415   Coefficient (all,r,REG)
   1416       TAXRIC(r) # total revenue from investment consumption tax payments in r #;
   1417   Formula (all,r,REG)
   1418       TAXRIC(r) = sum{c,COMM, DITAX(c,r) + MITAX(c,r)};
   1419    
   1420   !< Intermediate consumption tax revenue >!
   1421   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1422       DFTAX(c,a,r) # tax revenue from use of dom. intermediate c by act. a in r #;
   1423   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1424       DFTAX(c,a,r) = VDFPNC(c,a,r) - VDFB(c,a,r);
   1425   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1426       MFTAX(c,a,r) # tax revenue from use of imp. intermediate c by act. a in r #;
   1427   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1428       MFTAX(c,a,r) = VMFPNC(c,a,r) - VMFB(c,a,r);
   1429   !< Carbon tax revenue from intermediate consumption >!
   1430   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1431       DFCTAX(c,a,r) # carbon tax revenue from use of domestic c by a in r #;
   1432   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1433       DFCTAX(c,a,r) = VDFP(c,a,r) - VDFPNC(c,a,r);
   1434   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1435       MFCTAX(c,a,r) # carbon tax revenue from use of domestic c by a in r #;
   1436   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1437       MFCTAX(c,a,r) = VMFP(c,a,r) - VMFPNC(c,a,r);
   1438   Coefficient (all,r,REG)
   1439       TAXRIU(r) # total revenue from tax on intermediate goods usage in r #;
   1440   Formula (all,r,REG)
   1441       TAXRIU(r) = sum{c,COMM, sum{a,ACTS, DFTAX(c,a,r) + MFTAX(c,a,r)}};
   1442    
   1443   !< Endowment tax revenue >!
   1444   Coefficient (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   1445       ETAX(e,a,r) # tax revenue from use of endowment e by act. a in region r #;
   1446   Formula (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   1447       ETAX(e,a,r) = EVFP(e,a,r) - EVFB(e,a,r);
   1448   Coefficient (all,r,REG)
   1449       TAXRFU(r) # total revenue from use of factor/endowment e by act. a in r #;
   1450   Formula (all,r,REG)
   1451       TAXRFU(r) = sum{e,ENDW, sum{a,ACTS, ETAX(e,a,r)}};
   1452    
   1453   !< Endowment income tax revenue >!
   1454   Coefficient (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   1455       INCTAX(e,a,r) # tax revenue from endowment income tax in region r #;
   1456   Formula (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   1457       INCTAX(e,a,r) = EVFB(e,a,r) - EVOS(e,a,r);
   1458    
   1459   !< Exports tax revenue >!
   1460   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)
   1461       XTAXD(c,s,d) # tax rev. from exports of c from source s to destination d #;
   1462   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   1463       XTAXD(c,s,d) = VFOB(c,s,d) - VXSB(c,s,d);
   1464   Coefficient (all,r,REG)
   1465       TAXREXP(r) # total revenue from export tax payments in r #;
   1466   Formula (all,s,REG)
   1467       TAXREXP(s) = sum{c,COMM, sum{d,REG, XTAXD(c,s,d)}};
   1468    
   1469   !< Import tariff revenue >!
   1470   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)
   1471       MTAX(c,s,d) # tax rev from imports of c from source s to destination d #;
   1472   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   1473       MTAX(c,s,d) = VMSB(c,s,d) - VCIF(c,s,d);
   1474   Coefficient (all,r,REG)
   1475       TAXRIMP(r) # total revenue from import tax payments in r #;
   1476   Formula (all,d,REG)
   1477       TAXRIMP(d) = sum{c,COMM, sum{s,REG, MTAX(c,s,d)}};
   1478    
   1479   !<
   1480       -----------------------------------
   1481       A-4. Commom COEFFICIENTS/PARAMETERS
   1482       -----------------------------------
   1483       Common coefficients are defined as coefficients which are used in more
   1484       than one module. For example, ESUBD(c,r) is used in the goverment household,
   1485       private household, and firms modules.
   1486   >!
   1487    
   1488   !< Regional investment expenditure >!
   1489   Coefficient (all,r,REG)
   1490       REGINV(r) # regional GROSS investment in r #;
   1491   Formula (all,r,REG)
   1492       REGINV(r) = sum{c,COMM, VIPT(c,r)};
   1493   Coefficient (all,r,REG)
   1494       NETINV(r) # regional NET investment in region r #;
   1495   Formula (all,r,REG)
   1496       NETINV(r) = REGINV(r) - VDEP(r);
   1497    
   1498   !< Net global investment expenditure >!
   1499   Coefficient
   1500       GLOBINV # global expenditures on net investment #;
   1501   Formula
   1502       GLOBINV = sum{r,REG, NETINV(r)};
   1503    
   1504   !< GTAP-Power: Electricity data assignment >!
   1505   Coefficient (all,c,ELEP)(all,r,REG)
   1506       VPPE(c,r) # value of private electricity use in r, at producer's prices #;
   1507   Formula (all,r,REG)
   1508       VPPE("epl",r) = sum{c,EPLP, VPP(c,r)};
   1509   Formula (all,r,REG)
   1510       VPPE("ebl",r) = sum{c,EBLP, VPP(c,r)};
   1511   Formula (all,r,REG)
   1512       VPP("ebl",r) = VPPE("ebl",r);
   1513   Formula (all,r,REG)
   1514       VPP("epl",r) = VPPE("epl",r);
   1515   Formula (all,r,REG)
   1516       VPPE("egen",r) = sum{c,EGENP, VPP(c,r)};
   1517   Formula (all,r,REG)
   1518       VPP("egen",r) = VPPE("egen",r);
   1519   Formula (all,r,REG)
   1520       VPPE("ely",r) = sum{c,ELYP, VPP(c,r)};
   1521   Formula (all,r,REG)
   1522       VPP("ely",r) = VPPE("ely",r);
   1523    
   1524   !< GTAP-Power: Energy volume data assignment for ACES >!
   1525   Coefficient (all,c,EGYVOL)(all,r,REG)
   1526       EDP(c,r) # energy volume assoc w/ private demand for dom. c in r, MToE #;
   1527   Formula (initial)(all,c,EGYVOL)(all,r,REG)
   1528       EDP(c,r) = 0.0;
   1529   Read (ifheaderexists)
   1530       EDP from file GTAPDATA header "EDP";
   1531   Update (all,c,EGYVOL)(all,r,REG)
   1532       EDP(c,r) = qpd(c,r);
   1533   Coefficient (all,c,EGYVOL)(all,r,REG)
   1534       EMP(c,r) # energy volume assoc w/ private demand for imp. c in r, MToE #;
   1535   Formula (initial)(all,c,EGYVOL)(all,r,REG)
   1536       EMP(c,r) = 0.0;
   1537   Update (all,c,EGYVOL)(all,r,REG)
   1538       EMP(c,r) = qpm(c,r);
   1539   Read  (ifheaderexists)
   1540       EMP from file GTAPDATA header "EMP";
   1541   Coefficient (all,c,ALLP)(all,r,REG)
   1542       EPA(c,r) # energy volume assoc w/ aggregate private demand for c in r, MToE #;
   1543   Formula (all,c,ALLP)(all,r,REG)
   1544       EPA(c,r) = 0.0;
   1545   Formula (all,c,EGYVOL)(all,r,REG)
   1546       EPA(c,r) = EDP(c,r) + EMP(c,r);
   1547    
   1548   !< GTAP-Power: energy volume assoc w/ electricity sub-products for ACES >!
   1549   Coefficient (all,c,ALLP)(all,r,REG)
   1550       EPAS(c,r) # energy volume assoc w/ private sub-products in r  #;
   1551   Formula (all,c,ALLP)(all,r,REG)
   1552       EPAS(c,r) = 0.0;
   1553   Formula (all,r,REG)
   1554       EPAS("ebl",r) = sum{c,EBLP, EPA(c,r)};
   1555   Formula (all,r,REG)
   1556       EPA("ebl",r) = EPAS("ebl",r);
   1557   Formula (all,r,REG)
   1558       EPAS("epl",r) = sum{c,EPLP, EPA(c,r)};
   1559   Formula (all,r,REG)
   1560       EPA("epl",r) = EPAS("epl",r);
   1561   Formula (all,r,REG)
   1562       EPAS("egen",r) = sum{c,EGENP, EPA(c,r)};
   1563   Formula (all,r,REG)
   1564       EPA("egen",r)= EPAS("egen",r);
   1565   Formula (all,r,REG)
   1566       EPAS("ely",r) = sum{c,ELYP, EPA(c,r)};
   1567   Formula (all,r,REG)
   1568       EPA("ely",r) = EPAS("ely",r);
   1569   Formula (all,r,REG)
   1570       EPAS("eny",r) = sum{c,ENYP, EPA(c,r)};
   1571   Formula (all,r,REG)
   1572       EPA("eny",r) = EPAS("eny",r);
   1573   !< GTAP-Power: End of electricity data assignment >!
   1574    
   1575   !< Private household consumption subutility >!
   1576   Coefficient (all,c,SUBP)(all,r,REG)
   1577       VPPS(c,r) # private hhld expend. on c in r valued at producer's prices #;
   1578   Formula (all,c,SUBP)(all,r,REG)
   1579       VPPS(c,r) = 0.0;
   1580   Formula (all,r,REG)
   1581       VPPS("eny",r) = sum{c,ENYP, VPP(c,r)};
   1582   Formula (all,r,REG)
   1583       VPP("eny",r) = VPPS("eny",r);
   1584    
   1585   Zerodivide default RNREG;
   1586   !< Elasticity of cost with respect to utility from private consumption >!
   1587   Coefficient (all,c,TOPP)(all,r,REG)
   1588       CONSHR(c,r) # share of private hhld consumption devoted to good c in r #;
   1589   Formula (all,c,TOPP)(all,r,REG)
   1590       CONSHR(c,r) = VPP(c,r) / sum{cc,TOPP, VPP(cc,r)};
   1591   Zerodivide off;
   1592   !< GTAP-E changed: Redefine from COMM to TOPP >!
   1593   Coefficient (parameter)(all,c,TOPP)(all,r,REG)
   1594       INCPAR(c,r) # expansion parameter in the CDE minimum expenditure function #;
   1595   Read
   1596       INCPAR from file GTAPPARM header "INCP";
   1597   Coefficient (all,r,REG)
   1598       UELASPRIV(r)
   1599       # elasticity of cost wrt utility from private consumption #;
   1600   Formula (all,r,REG)
   1601       UELASPRIV(r) = sum{c,TOPP, CONSHR(c,r) * INCPAR(c,r)};
   1602    
   1603   !<  Domestic/imported Armington elasticity >!
   1604   Coefficient (parameter)(all,c,COMM)(all,r,REG)
   1605       ESUBD(c,r)
   1606       # region-specific elast. of subst. for dom. and imp. goods for all agents #;
   1607   Read
   1608       ESUBD from file GTAPPARM header "ESBD";
   1609   Assertion (all,c,COMM)(all,r,REG) ESUBD(c,r) ge 0;
   1610    
   1611   !<
   1612       ---------------------
   1613       A-5. Common VARIABLES
   1614       ---------------------
   1615    
   1616       Common variables are defined as variables which are used in more than one
   1617       module. For example, the variable y(r) is used in the Goverment
   1618       Consumption, Private Consumption, Firms, Regional Household and
   1619       Investment, Global Bank and Saving modules.
   1620       Appendices, e.g., Summary Indices, are not included in this definition.
   1621   >!
   1622    
   1623   Variable (all,r,REG)
   1624       y(r) # regional household income in region r #;
   1625   Variable (all,r,REG)
   1626       pop(r) # regional population #;
   1627    
   1628   Variable (all,r,REG)
   1629       pgov(r) # price index for gov't expenditure in region r #;
   1630   Variable (all,r,REG)
   1631       yg(r) # regional government consumption expenditure in region r #;
   1632   Variable (all,r,REG)
   1633       ug(r) # per capita utility from gov't expend. in region r #;
   1634    
   1635   Variable (all,r,REG)
   1636       ppriv(r) # price index for priv. household cons. expenditure in region r #;
   1637   Variable (all,r,REG)
   1638       yp(r) # regional private consumption expenditure in region r #;
   1639   Variable (all,r,REG)
   1640       uepriv(r) # elasticity of cost wrt utility from private consumption #;
   1641   Variable (all,r,REG)
   1642       up(r) # per capita utility from private expend. in region r #;
   1643    
   1644   Variable (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1645       to(c,a,r) # power of tax on com. c supplied by act. a in region r #;
   1646   Variable (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   1647       tinc(e,a,r) # power of income tax on endowment e supplied to act. a in r #;
   1648   Variable (all,e,ENDW)(all,r,REG)
   1649       endwslack(e,r) # slack variable in endowment market clearing condition #;
   1650   !<
   1651       endwslack is exogenous, unless the user wishes to employ a partial
   1652       equilibrium closure in which the price of one or more of the primary factors
   1653       is fixed.
   1654   >!
   1655    
   1656   Variable (orig_level=VMB)(all,c,COMM)(all,r,REG)
   1657       qms(c,r) # aggregate imports of c in region r, basic price weights #;
   1658   Variable
   1659       globalcgds # global supply of capital goods for NET investment #;
   1660   Variable
   1661       pcgdswld # world average price of capital goods (net investment weights) #;
   1662    
   1663   !<
   1664       ================
   1665       Equation modules
   1666       ================
   1667       1.  Firms
   1668       2.  Commodity supply
   1669       3.  Income distribution
   1670       4.  Allocation of income across expenditure categories
   1671       5.  Domestic final demand
   1672       6.  Trade, goods market equilibrium and prices
   1673       7.  Factor market equilibrium
   1674       8.  Allocation of global saving
   1675       9.  Tax revenue streams
   1676       10. Numeraire and Walras law
   1677       11. Welfare measurement and decomposition
   1678   >!
   1679    
   1680   !<
   1681       --------
   1682       1. Firms
   1683       --------
   1684    
   1685       To implement the production system, we define a set "SUBF" of
   1686       subproducts, corresponding to the various composites of TP-16, the
   1687       value-added-energy composite, the capital-energy composite, and so on
   1688       (we call them "subproducts" not "composites" to avoid confusion with the
   1689       domestic-import and import-import composites).  We include subproducts
   1690       with endowments and tradables in a set "ALLF" of commodities
   1691       demanded by firms.
   1692    
   1693       The following picture describes the firms production structure.
   1694    
   1695       Set structure
   1696       -------------
   1697    
   1698       |--------------------------------------------------|
   1699       |                    ALLF                     |
   1700       |--------------------------------------------------|
   1701       |                   DEMD               | SUBF |
   1702       |--------------------------------------|-----------|
   1703       |   ENDW       |         COMM          |
   1704       |---------------------------------------
   1705    
   1706       Production structure
   1707       --------------------
   1708    
   1709                                        qo(c,a,r) [ao(c,a,r)]    TOTAL OUTPUT NEST
   1710                                        /\
   1711                                       /  \  <----- CES
   1712                                      /    \
   1713                                     /      \
   1714                                    /        \
   1715                       endowment-energy       non-energy inputs
   1716   Val.-add.-en. nest    /| \                                 /\
   1717       CES ----->       / |  \                               /  \  <------ CES
   1718                       /  |   \                             /    \
   1719                      /   |    \                           /      \
   1720                     /    |     \                         /        \
   1721                  Land  Labor  K-E subproduct         Domestic     Foreign
   1722                                 /\
   1723                                /  \
   1724                               /    \                  Capital-energy nest
   1725                              /      \     <--------- CES (subst. el. ELFKEN)
   1726                             /        \
   1727                            /          \
   1728                           /            \
   1729                          /              \
   1730                         K             energy subproduct
   1731                                                   /\         Energy nest
   1732                                                  /  \ <--- CES (subst. el. ELFENY)
   1733                                                 /    \
   1734                                                /      \
   1735                                               /        \
   1736                                              /          \
   1737                                         electricity  non-electr. energy
   1738                                                           /\
   1739       Non-electricity energy nest                        /  \
   1740       CES (subst. el. ELFNELY)  ---------------->       /    \
   1741                                                        /      \
   1742                                                       /        \
   1743                                              non-coal energy   coal
   1744                                                   /\
   1745       Non-coal energy nest     ------------>     /  \
   1746       CES (subst. el. ELFNCOAL)                 /    \
   1747                                                /      \
   1748                                               /        \
   1749                                              /          \
   1750                                    crude oil, gas, petr. products
   1751    
   1752    
   1753    
   1754       1-1. Sourcing of commodities by firms
   1755            1-1.1 Notational Links
   1756            1-1.2 Non-Coal Energy Nest
   1757            1-1.3 Non-Electricity Energy Nest
   1758            1-1.4 Energy Nest
   1759            1-1.5 Capital-Energy Nest
   1760            1-1.6 Value-Added-Energy Nest
   1761       1-2. Top of the production structure
   1762       1-3. Technical change equations
   1763   >!
   1764    
   1765   !<
   1766       1-1. Sourcing of commodities by firms
   1767       -------------------------------------
   1768   >!
   1769   Variable (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1770       pfat(c,a,r) # firms' price for commodity c for use by act. a in r #;
   1771   Variable (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1772       qfat(c,a,r) # demand for commodity c for use by act. a in region r #;
   1773   Variable (all,c,ALLF)(all,a,ACTS)(all,r,REG)
   1774       pfa(c,a,r) # firms' price for commodity c for use by act. a in r #;
   1775   Variable (all,c,ALLF)(all,a,ACTS)(all,r,REG)
   1776       qfa(c,a,r) # demand for commodity c for use by act. a in region r #;
   1777   Variable (all,c,ALLF)(all,a,ACTS)(all,r,REG)
   1778       afa(c,a,r) # composite interm. input c augmenting tech ch. by act. a in r #;
   1779   Variable (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   1780       afe(e,a,r) # primary factor e augmenting tech change by act. a in r #;
   1781    
   1782   Equation E_qfd
   1783   # act. a demands for domestic good c #
   1784   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1785       qfd(c,a,r) = qfat(c,a,r) - ESUBD(c,r) * [pfd(c,a,r) - pfat(c,a,r)];
   1786    
   1787   Equation E_qfm
   1788   # act. a demands for composite import c #
   1789   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1790       qfm(c,a,r) = qfat(c,a,r) - ESUBD(c,r) * [pfm(c,a,r) - pfat(c,a,r)];
   1791    
   1792   Coefficient (all,c,COMM)(all,a,ACTS)(all,s,REG)
   1793       FMSHR(c,a,s) # share of firms' imports in dom. composite, purch. prices #;
   1794   Zerodivide default RNREG;
   1795   Zerodivide (nonzero_by_zero) default RNREG;
   1796   Formula (all,c,COMM)(all,a,ACTS)(all,s,REG)
   1797       FMSHR(c,a,s) = VMFP(c,a,s) / VFP(c,a,s);
   1798   Zerodivide off;
   1799    
   1800   Equation E_pfat
   1801   # industry price for composite commodities #
   1802   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1803       pfat(c,a,r) = [1 - FMSHR(c,a,r)] * pfd(c,a,r) + FMSHR(c,a,r) * pfm(c,a,r);
   1804    
   1805   !<
   1806       1-1.1 Notational Links
   1807       ----------------------
   1808   >!
   1809   Equation E_pfa1
   1810   # endowment input prices into the production system #
   1811   (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   1812       pfa(e,a,r) = pfe(e,a,r);
   1813    
   1814   Equation E_pfa2
   1815   # commodity input prices into the production system #
   1816   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1817       pfa(c,a,r) = pfat(c,a,r);
   1818    
   1819   Equation E_qfe
   1820   # Output endowment quantities from the production system #
   1821   (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   1822       qfe(e,a,r) = qfa(e,a,r);
   1823    
   1824   Equation E_qfat
   1825   # Output tradables quantities from the production system #
   1826   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   1827       qfat(c,a,r) = qfa(c,a,r);
   1828    
   1829   !<
   1830       1-1.2 Non-Coal Energy nest
   1831       --------------------------
   1832   >!
   1833   Coefficient (all,c,SUBF)(all,a,ACTS)(all,r,REG)
   1834       VFPS(c,a,r) # producer expend. on c by a in r valued at purchaser's prices #;
   1835   Formula (all,c,SUBF)(all,a,ACTS)(all,r,REG)
   1836       VFPS(c,a,r) = 0.0;
   1837   Formula (all,a,ACTS)(all,r,REG)
   1838       VFPS("ncoal",a,r) = sum{c,NCOALF, VFP(c,a,r)};
   1839   Formula (all,a,ACTS)(all,r,REG)
   1840       VFP("ncoal",a,r) = VFPS("ncoal",a,r);
   1841    
   1842   Zerodivide default RNREG;
   1843   Coefficient (all,c,NCOALF)(all,a,ACTS)(all,r,REG)
   1844       FNCOALSHR(c,a,r)
   1845       # share of c in cost to act. a of non-coal energy subproduct #;
   1846   Formula (all,c,NCOALF)(all,a,ACTS)(all,r,REG)
   1847       FNCOALSHR(c,a,r) = VFP(c,a,r) / VFPS("ncoal",a,r);
   1848   Zerodivide off;
   1849    
   1850   Equation E_pfa3
   1851   # price of non-coal energy #
   1852   (all,a,ACTS)(all,r,REG)
   1853       pfa("ncoal",a,r)
   1854           = sum{k,NCOALF, FNCOALSHR(k,a,r) * [pfa(k,a,r) - afa(k,a,r)]};
   1855    
   1856   Coefficient (parameter) (all,a,ACTS)(all,r,REG)
   1857       ELFNCOAL(a,r)
   1858       # elasticity of substitution in non-coal energy subproduction #;
   1859   Read
   1860       ELFNCOAL from file GTAPPARM header "EFNC";
   1861    
   1862   Equation E_qfa1
   1863   # demand for inputs into non-coal energy subproduction #
   1864   (all,c,NCOALF)(all,a,ACTS)(all,r,REG)
   1865       qfa(c,a,r) = -afa(c,a,r) + qfa("ncoal",a,r)
   1866                  - ELFNCOAL(a,r) * [pfa(c,a,r) - afa(c,a,r) - pfa("ncoal",a,r)];
   1867    
   1868   !<
   1869       1-1.3 Non-Electricity Energy nest
   1870       ---------------------------------
   1871   >!
   1872    
   1873   Formula (all,a,ACTS)(all,r,REG)
   1874       VFPS("nely",a,r) = sum{c,NELYF, VFP(c,a,r)};
   1875   Formula (all,a,ACTS)(all,r,REG)
   1876       VFP("nely",a,r) = VFPS("nely",a,r);
   1877   Coefficient (all,c,NELYF)(all,a,ACTS)(all,r,REG)
   1878       FNELYSHR(c,a,r)
   1879       # share of c in cost to a of non-electricity energy subproduct #;
   1880   Zerodivide default RNREG;
   1881   Formula (all,c,NELYF)(all,a,ACTS)(all,r,REG)
   1882       FNELYSHR(c,a,r) = VFP(c,a,r) / VFPS("nely",a,r);
   1883   Zerodivide off;
   1884    
   1885   Equation E_pfa4
   1886   # price of non-electricity energy subproduct #
   1887   (all,a,ACTS)(all,r,REG)
   1888       pfa("nely",a,r) =
   1889           sum{k,NELYF, FNELYSHR(k,a,r) * [pfa(k,a,r) - afa(k,a,r)]};
   1890    
   1891   Coefficient (parameter) (all,a,ACTS)(all,r,REG)
   1892       ELFNELY(a,r)
   1893       # elasticity of substitution in non-electricity energy subproduction #;
   1894   Read
   1895       ELFNELY from file GTAPPARM header "EFNL";
   1896    
   1897   Equation E_qfa2
   1898   # demand for inputs into non-electricity energy subproduction #
   1899   (all,c,NELYF)(all,a,ACTS)(all,r,REG)
   1900       qfa(c,a,r) = -afa(c,a,r) + qfa("nely",a,r)
   1901                  - ELFNELY(a,r) * [pfa(c,a,r) - afa(c,a,r) - pfa("nely",a,r)];
   1902    
   1903   !<
   1904       1-1.4 Energy nest
   1905       -----------------
   1906   >!
   1907   !< GTAP-Power: electricity data assignment >!
   1908   Coefficient (all,c,ELEF)(all,a,ACTS)(all,r,REG)
   1909       VFPE(c,a,r) # value of firms' electricity use in r, at producer's prices #;
   1910   Formula (all,a,ACTS)(all,r,REG)
   1911       VFPE("ebl",a,r) = sum{c,EBLF, VFP(c,a,r)};
   1912   Formula (all,a,ACTS)(all,r,REG)
   1913       VFPE("epl",a,r) = sum{c,EPLF, VFP(c,a,r)};
   1914   Formula (all,a,ACTS)(all,r,REG)
   1915       VFP("ebl",a,r) = VFPE("ebl",a,r);
   1916   Formula (all,a,ACTS)(all,r,REG)
   1917       VFP("epl",a,r) = VFPE("epl",a,r);
   1918    
   1919   Formula (all,a,ACTS)(all,r,REG)
   1920       VFPE("egen",a,r) = sum{c,EGENF, VFP(c,a,r)};
   1921   Formula (all,a,ACTS)(all,r,REG)
   1922       VFP("egen",a,r) = VFPE("egen",a,r);
   1923   Formula (all,a,ACTS)(all,r,REG)
   1924       VFPE("ely",a,r) = sum{c,ELYF, VFP(c,a,r)};
   1925   Formula (all,a,ACTS)(all,r,REG)
   1926       VFP("ely",a,r) = VFPE("ely",a,r);
   1927    
   1928   !< GTAP-Power: Energy volume data assignment for ACES >!
   1929   Coefficient (all,c,EGYVOL)(all,a,ACTS)(all,r,REG)
   1930       EDF(c,a,r) # energy volume assoc w/demand for dom. c by activity a in r, MToE #;
   1931   Formula (initial)(all,c,EGYVOL)(all,a,ACTS)(all,r,REG)
   1932       EDF(c,a,r) = 0.0;
   1933   Read (ifheaderexists)
   1934       EDF from file GTAPDATA header "EFD";
   1935   Update (all,c,EGYVOL)(all,a,ACTS)(all,r,REG)
   1936       EDF(c,a,r) = qfd(c,a,r);
   1937   Coefficient (all,c,EGYVOL)(all,a,ACTS)(all,r,REG)
   1938       EMF(c,a,r) # energy volume assoc w/demand for imp. c by activity a in r, MToE #;
   1939   Formula (initial)(all,c,EGYVOL)(all,a,ACTS)(all,r,REG)
   1940       EMF(c,a,r) = 0.0;
   1941   Read (ifheaderexists)
   1942       EMF from file GTAPDATA header "EFM";
   1943   Update (all,c,EGYVOL)(all,a,ACTS)(all,r,REG)
   1944       EMF(c,a,r) = qfm(c,a,r);
   1945   Coefficient (all,c,ALLF)(all,a,ACTS)(all,r,REG)
   1946       EFA(c,a,r) # energy volume assoc aggregate demand for c by a in r, MToE #;
   1947   Formula (all,c,ALLF)(all,a,ACTS)(all,r,REG)
   1948       EFA(c,a,r) = 0.0;
   1949   Formula (all,c,EGYVOL)(all,a,ACTS)(all,r,REG)
   1950       EFA(c,a,r) = EDF(c,a,r) + EMF(c,a,r);
   1951    
   1952   Coefficient (all,c,ALLF)(all,a,ACTS)(all,r,REG)
   1953       EFAS(c,a,r) # energy volume assoc w/ sub-products of activity a in r  #;
   1954   Formula (all,c,ALLF)(all,a,ACTS)(all,r,REG)
   1955       EFAS(c,a,r) = 0.0;
   1956   Formula (all,a,ACTS)(all,r,REG)
   1957       EFAS("ebl",a,r) = sum{c,EBLF, EFA(c,a,r)};
   1958   Formula (all,a,ACTS)(all,r,REG)
   1959       EFA("ebl",a,r) = EFAS("ebl",a,r);
   1960   Formula (all,a,ACTS)(all,r,REG)
   1961       EFAS("epl",a,r) = sum{c,EPLF, EFA(c,a,r)};
   1962   Formula (all,a,ACTS)(all,r,REG)
   1963       EFA("epl",a,r) = EFAS("epl",a,r);
   1964   Formula (all,a,ACTS)(all,r,REG)
   1965       EFAS("egen",a,r) = sum{c,EGENF, EFA(c,a,r)};
   1966   Formula (all,a,ACTS)(all,r,REG)
   1967       EFA("egen",a,r) = EFAS("egen",a,r);
   1968   Formula (all,a,ACTS)(all,r,REG)
   1969       EFAS("ely",a,r) = sum{c,ELYF, EFA(c,a,r)};
   1970   Formula (all,a,ACTS)(all,r,REG)
   1971       EFA("ely",a,r) = EFAS("ely",a,r);
   1972   Formula (all,a,ACTS)(all,r,REG)
   1973       EFAS("eny",a,r) = sum{c,ENYF, EFA(c,a,r)};
   1974   Formula (all,a,ACTS)(all,r,REG)
   1975       EFA("eny",a,r) = EFAS("eny",a,r);
   1976   !< GTAP-Power: End of electricity data assignment >!
   1977    
   1978   Formula (all,a,ACTS)(all,r,REG)
   1979       VFPS("eny",a,r) = sum{c,ENYF, VFP(c,a,r)};
   1980   Formula (all,a,ACTS)(all,r,REG)
   1981       VFP("eny",a,r) = VFPS("eny",a,r);
   1982   Zerodivide default RNREG;
   1983   Coefficient (all,c,ENYF)(all,a,ACTS)(all,r,REG)
   1984       FENYSHR(c,a,r) # share of c in cost to a of energy subproduct #;
   1985   Formula (all,c,ENYF)(all,a,ACTS)(all,r,REG)
   1986       FENYSHR(c,a,r) = VFP(c,a,r) / VFPS("eny",a,r);
   1987   Zerodivide off;
   1988    
   1989   Equation E_pfa5
   1990   # price of energy subproduct #
   1991   (all,a,ACTS)(all,r,REG)
   1992       pfa("eny",a,r) = sum{k,ENYF,
   1993                              FENYSHR(k,a,r) * [pfa(k,a,r) - afa(k,a,r)]};
   1994    
   1995   Coefficient (parameter) (all,a,ACTS)(all,r,REG)
   1996       ELFENY(a,r) # elasticity of substitution in energy subproduction #;
   1997   Read
   1998       ELFENY from file GTAPPARM header "EFEN";
   1999    
   2000   Equation E_qfa3 # demand for inputs into energy subproduction #
   2001   (all,c,ENYF)(all,a,ACTS)(all,r,REG)
   2002       qfa(c,a,r) = -afa(c,a,r) + qfa("eny",a,r)
   2003                  - ELFENY(a,r) * [pfa(c,a,r) - afa(c,a,r) - pfa("eny",a,r)];
   2004    
   2005   !<
   2006       1-1.5 Capital-Energy nest
   2007       -------------------------
   2008   >!
   2009   Formula (all,a,ACTS)(all,r,REG)
   2010       VFPS("ken",a,r) = sum{c,KENF, VFP(c,a,r)};
   2011   Formula (all,a,ACTS)(all,r,REG)
   2012       VFP("ken",a,r) = VFPS("ken",a,r);
   2013   Coefficient (all,c,KENF)(all,a,ACTS)(all,r,REG)
   2014       FKENSHR(c,a,r) # share of c in cost to a of capital-energy subproduct #;
   2015   Zerodivide default RNREG;
   2016   Formula (all,c,KENF)(all,a,ACTS)(all,r,REG)
   2017       FKENSHR(c,a,r) = VFP(c,a,r) / VFPS("ken",a,r);
   2018   Zerodivide off;
   2019    
   2020   Equation E_pfa6
   2021   # price of capital-energy subproduct #
   2022   (all,a,ACTS)(all,r,REG)
   2023       pfa("ken",a,r)
   2024           = sum{k,KENF, FKENSHR(k,a,r) * [pfa(k,a,r) - afa(k,a,r)]};
   2025    
   2026   Coefficient (parameter) (all,a,ACTS)(all,r,REG)
   2027       ELFKEN(a,r)
   2028       # elasticity of substitution in capital-energy subproduction #;
   2029   Read
   2030       ELFKEN from file GTAPPARM header "EFKE";
   2031    
   2032   Equation E_qfa4
   2033   # demand for inputs into capital-energy subproduction #
   2034   (all,c,KENF)(all,a,ACTS)(all,r,REG)
   2035       qfa(c,a,r) = -afa(c,a,r) + qfa("ken",a,r)
   2036                  - ELFKEN(a,r) * [pfa(c,a,r) - afa(c,a,r) - pfa("ken",a,r)];
   2037    
   2038   !<
   2039       1-1.6 Value-Added-Energy nest
   2040       -----------------------------
   2041   >!
   2042   Formula (all,a,ACTS)(all,r,REG)
   2043       VFPS("vaen",a,r) = sum{c,VAENF, VFP(c,a,r)};
   2044   Formula (all,a,ACTS)(all,r,REG)
   2045       VFP("vaen",a,r) = VFPS("vaen",a,r);
   2046   Coefficient (all,c,VAENF)(all,a,ACTS)(all,r,REG)
   2047       FVAENSHR(c,a,r)
   2048       # share of c in cost to a of value-added-energy subproduct #;
   2049   Zerodivide default RNREG;
   2050   Formula (all,c,VAENF)(all,a,ACTS)(all,r,REG)
   2051       FVAENSHR(c,a,r) = VFP(c,a,r) / VFPS("vaen",a,r);
   2052   Zerodivide off;
   2053    
   2054   Equation E_pfa7 # price of value-added-energy subproduct #
   2055   (all,a,ACTS)(all,r,REG)
   2056       pfa("vaen",a,r)
   2057           = sum{k,VAENF, FVAENSHR(k,a,r) * [pfa(k,a,r) - afa(k,a,r)]};
   2058   Coefficient (parameter) (all,a,ACTS)(all,r,REG)
   2059       ELFVAEN(a,r)
   2060       # elasticity of substitution in value-added-energy subproduction #;
   2061   Read
   2062       ELFVAEN from file GTAPPARM header "EFVE";
   2063    
   2064   Equation E_qfa5
   2065   # demand for inputs into value-added-energy subproduction #
   2066   (all,c,VAENF)(all,a,ACTS)(all,r,REG)
   2067       qfa(c,a,r) = -afa(c,a,r) + qfa("vaen",a,r)
   2068                  - ELFVAEN(a,r) * [pfa(c,a,r) - afa(c,a,r) - pfa("vaen",a,r)];
   2069    
   2070   !<
   2071       1-1.7 Electricity nest
   2072       ----------------------
   2073   >!
   2074    
   2075   !<
   2076       1-1.7.1 Electricity (top-level) composite
   2077       -----------------------------------------
   2078   >!
   2079   Variable (all,c,ELEF)(all,a,ACTS)(all,r,REG)
   2080       pfac(c,a,r) # ACES-related price for commodity c used by a in region r #;
   2081   Coefficient (parameter)(all,a,ACTS)(all,r,REG)
   2082       ELFELY(a,r) # top level elasticity of substitution: electricity and TnD #;
   2083   Formula (initial)(all,a,ACTS)(all,r,REG)
   2084       ELFELY(a,r) = 0.0;
   2085   Read (ifheaderexists)
   2086       ELFELY from file GTAPPARM header "EFEL";
   2087   Zerodivide default RNREG;
   2088   Coefficient (all,c,ELYF)(all,a,ACTS)(all,r,REG)
   2089       FSHELY(c,a,r) # share of electricity and TnD in composite electricity of act. a #;
   2090   Formula (all,c,ELYF)(all,a,ACTS)(all,r,REG)
   2091       FSHELY(c,a,r) = VFP(c,a,r) / VFPE("ely",a,r);
   2092   !Coefficient (all,c,ELYF)(all,a,ACTS)(all,r,REG)
   2093       FSHELYVOL(c,a,r) # vol. share of electricity and TnD in composite electricity of act. a #;
   2094   Formula (all,c,ELYF)(all,a,ACTS)(all,r,REG)
   2095       FSHELYVOL(c,a,r) = EFA(c,a,r) / EFAS("ely",a,r);!
   2096   Zerodivide off;
   2097    
   2098   Equation E_pfac1
   2099   # ACES-related private composite price for commodity c used by a in region r #
   2100   (all,a,ACTS)(all,r,REG)
   2101   !    pfac("ely",a,r) = sum{c,ELYF, FSHELYVOL(c,a,r) * [pfa(c,a,r) - afa(c,a,r)]};!
   2102       pfac("ely",a,r) = pfa("ely",a,r);
   2103    
   2104   Equation E_pfa8
   2105   # price of  top level electricity composite of activity a #
   2106   (all,a,ACTS)(all,r,REG)
   2107       pfa("ely",a,r) = sum{c,ELYF, FSHELY(c,a,r) * [pfa(c,a,r)  - afa(c,a,r)]};
   2108    
   2109   Equation E_qfa7
   2110   # input demand for top level electricity composite of activity a #
   2111   (all,c,ELYF)(all,a,ACTS)(all,r,REG)
   2112   !    qfa(c,a,r) = - afa(c,a,r) + qfa("ely",a,r)
   2113                  - ELFELY(r) * [pfa(c,a,r) - afa(c,a,r) - pfac("ely",a,r)];!
   2114       qfa(c,a,r) = - afa(c,a,r) + qfa("ely",a,r)
   2115                  - ELFELY(a,r) * [pfa(c,a,r) - afa(c,a,r) - pfa("ely",a,r)];
   2116    
   2117   !<
   2118       1-1.7.2 Base and Peak load composite
   2119       ------------------------------------
   2120   >!
   2121   Coefficient (parameter)(all,a,ACTS)(all,r,REG)
   2122       ELFEGEN(a,r) # elasticity of substitution in base load power of activity a #;
   2123   Formula (initial)(all,a,ACTS)(all,r,REG)
   2124       ELFEGEN(a,r) = 1.0;
   2125   Read (ifheaderexists)
   2126       ELFEGEN from file GTAPPARM header "EFEG";
   2127    
   2128   Coefficient (all,c,EGENF)(all,a,ACTS)(all,r,REG)
   2129       FSHEGEN(c,a,r) # share of c in (base and peak load) electricity composite of act. a #;
   2130   Coefficient (all,c,EGENF)(all,a,ACTS)(all,r,REG)
   2131       FSHEGENVOL(c,a,r) # vol. share of c in (base and peak load) electricity composite of act. a #;
   2132   Zerodivide default RNREG;
   2133   Zerodivide (nonzero_by_zero) default 0.0;
   2134   Formula (all,c,EGENF)(all,a,ACTS)(all,r,REG)
   2135       FSHEGEN(c,a,r) = VFP(c,a,r) / VFPE("egen",a,r);
   2136   Formula (all,c,EGENF)(all,a,ACTS)(all,r,REG)
   2137       FSHEGENVOL(c,a,r) = EFA(c,a,r) / EFAS("egen",a,r);
   2138   Zerodivide off;
   2139    
   2140   Equation E_pfac2
   2141   # ACES-related private composite price for commodity c used by a in region r #
   2142   (all,a,ACTS)(all,r,REG)
   2143       pfac("egen",a,r) = sum{c,EGENF, FSHEGENVOL(c,a,r) * [pfa(c,a,r) - afa(c,a,r)]};
   2144    
   2145   Equation E_pfa9
   2146   # price of (base and peak load) electricity composite by activity a #
   2147   (all,a,ACTS)(all,r,REG)
   2148       pfa("egen",a,r) = sum{c,EGENF, FSHEGEN(c,a,r) * [pfa(c,a,r) - afa(c,a,r)]};
   2149    
   2150   Equation E_qfa8
   2151   # input demand for (base and peak load) electricity composite of activity a #
   2152   (all,c,EGENF)(all,a,ACTS)(all,r,REG)
   2153   !    qfa(c,a,r) = - afa(c,a,r) + qfa("egen",a,r)
   2154                  - ELFEGEN(r) * [pfa(c,a,r) - afa(c,a,r) - pfac("egen",a,r)];!
   2155       qfa(c,a,r) = - afa(c,a,r) + qfa("egen",a,r)
   2156                  - ELFEGEN(a,r) * [pfa(c,a,r) - afa(c,a,r) - pfa("egen",a,r)];
   2157    
   2158   !<
   2159       1-1.7.3 Base load nest
   2160       ----------------------
   2161   >!
   2162   Coefficient (parameter)(all,a,ACTS)(all,r,REG)
   2163       ELFEBL(a,r) # elasticity of substitution in base load power of activity a #;
   2164   Formula (initial)(all,a,ACTS)(all,r,REG)
   2165       ELFEBL(a,r) = 1.0;
   2166   Read (ifheaderexists)
   2167       ELFEBL from file GTAPPARM header "EFEB";
   2168    
   2169   Coefficient (all,c,EBLF)(all,a,ACTS)(all,r,REG)
   2170       FSHEBL(c,a,r) # share of c in cost of electricity (base load) subutility of activity a #;
   2171   Coefficient (all,c,EBLF)(all,a,ACTS)(all,r,REG)
   2172       FSHEBLVOL(c,a,r) # vol. share of c in cost of electricity (base load) subutility of activity a #;
   2173   Zerodivide default RNREG;
   2174   Formula (all,c,EBLF)(all,a,ACTS)(all,r,REG)
   2175       FSHEBL(c,a,r) = VFP(c,a,r) / VFPE("ebl",a,r);
   2176   Formula (all,c,EBLF)(all,a,ACTS)(all,r,REG)
   2177       FSHEBLVOL(c,a,r) = EFA(c,a,r) / EFAS("ebl",a,r);
   2178   Zerodivide off;
   2179    
   2180   Equation E_pfac3
   2181   # ACES-related private composite price for commodity c used by a in region r #
   2182   (all,a,ACTS)(all,r,REG)
   2183       pfac("ebl",a,r) = sum{c,EBLF, FSHEBLVOL(c,a,r) * [pfa(c,a,r) - afa(c,a,r)]};
   2184    
   2185   Equation E_pfa10
   2186   # price of energy subutility (baseload power) of activity a #
   2187   (all,a,ACTS)(all,r,REG)
   2188       pfa("ebl",a,r) = sum{c,EBLF, FSHEBL(c,a,r) * [pfa(c,a,r) - afa(c,a,r)]};
   2189    
   2190   Equation E_qfa9
   2191   # input demand for baseload power of activity a #
   2192   (all,c,EBLF)(all,a,ACTS)(all,r,REG)
   2193   !    qfa(c,a,r) = - afa(c,a,r) + qfa("ebl",a,r)
   2194                  - ELFEBL(r) * [pfa(c,a,r) - afa(c,a,r) - pfac("ebl",a,r)];!
   2195       qfa(c,a,r) = - afa(c,a,r) + qfa("ebl",a,r)
   2196                  - ELFEBL(a,r) * [pfa(c,a,r) - afa(c,a,r) - pfa("ebl",a,r)];
   2197    
   2198   !<
   2199       1-1.7.4 Peak load nest
   2200       ----------------------
   2201   >!
   2202   Coefficient (parameter)(all,a,ACTS)(all,r,REG)
   2203       ELFEPL(a,r) # elasticity of substitution in peak load power of activity a #;
   2204   Formula (initial)(all,a,ACTS)(all,r,REG)
   2205       ELFEPL(a,r) = 1.0;
   2206   Read (ifheaderexists)
   2207       ELFEPL from file GTAPPARM header "EFEP";
   2208    
   2209   Coefficient (all,c,EPLF)(all,a,ACTS)(all,r,REG)
   2210       FSHEPL(c,a,r) # share of c in cost of electricity (Peak load) subutility of activity a #;
   2211   Coefficient (all,c,EPLF)(all,a,ACTS)(all,r,REG)
   2212       FSHEPLVOL(c,a,r) # share of c in cost of electricity (Peak load) subutility of activity a #;
   2213   Zerodivide default RNREG;
   2214   Formula (all,c,EPLF)(all,a,ACTS)(all,r,REG)
   2215       FSHEPL(c,a,r) = VFP(c,a,r) / VFPE("epl",a,r);
   2216   Formula (all,c,EPLF)(all,a,ACTS)(all,r,REG)
   2217       FSHEPLVOL(c,a,r) = EFA(c,a,r) / EFAS("epl",a,r);
   2218   Zerodivide off;
   2219    
   2220   Equation E_pfac4
   2221   # ACES-related private composite price for commodity c used by a in region r #
   2222   (all,a,ACTS)(all,r,REG)
   2223       pfac("epl",a,r) = sum{c,EPLF, FSHEPLVOL(c,a,r) * [pfa(c,a,r) - afa(c,a,r)]};
   2224    
   2225   Equation E_pfa11
   2226   # price of energy subutility (peak load power) of activity a #
   2227   (all,a,ACTS)(all,r,REG)
   2228       pfa("epl",a,r) = sum{c,EPLF, FSHEPL(c,a,r) * [pfa(c,a,r) - afa(c,a,r)]};
   2229    
   2230   Equation E_qfa10
   2231   # input demand for peak load power of activity a #
   2232   (all,c,EPLF)(all,a,ACTS)(all,r,REG)
   2233   !    qfa(c,a,r) = - afa(c,a,r) + qfa("epl",a,r)
   2234                  - ELFEPL(r) * [pfa(c,a,r) - afa(c,a,r) - pfac("epl",a,r)];!
   2235       qfa(c,a,r) = - afa(c,a,r) + qfa("epl",a,r)
   2236                  - ELFEPL(a,r) * [pfa(c,a,r) - afa(c,a,r) - pfa("epl",a,r)];
   2237    
   2238   !<
   2239       1.2 Top of the Production Structure
   2240       -----------------------------------
   2241   >!
   2242    
   2243   Variable (all,a,ACTS)(all,r,REG)
   2244       po(a,r) # unit cost/revenue of activity a in region r #;
   2245   Variable (orig_level=VOS)(all,a,ACTS)(all,r,REG)
   2246       qo(a,r) # output of activity a in region r #;
   2247   Variable (all,a,ACTS)(all,r,REG)
   2248       ao(a,r) # output augmenting technical change by activity a in region r #;
   2249   Coefficient (parameter)(all,a,ACTS)(all,r,REG)
   2250       ESUBT(a,r)
   2251       # elast. of sub. bet. composite intermediate and factor inputs in prod'n #;
   2252   Read
   2253       ESUBT from file GTAPPARM header "ESBT";
   2254   Assertion (all,a,ACTS)(all,r,REG) ESUBT(a,r) ge 0;
   2255    
   2256   Variable (all,a,ACTS)(all,r,REG)
   2257       profitslack(a,r) # slack variable in the zero profit equation #;
   2258    
   2259   Coefficient (all,a,ACTS)(all,r,REG)
   2260       VFPTOT(a,r) # total cost of inputs into a in r #;
   2261   Formula (all,a,ACTS)(all,r,REG)
   2262       VFPTOT(a,r) = sum{c,TOPF, VFP(c,a,r)};
   2263   Coefficient (all,c,TOPF)(all,a,ACTS)(all,r,REG)
   2264       FSHOUT(c,a,r) # share of c in total costs of j in r #;
   2265    
   2266   Zerodivide default RNREG;
   2267   Formula (all,c,TOPF)(all,a,ACTS)(all,r,REG)
   2268       FSHOUT(c,a,r) = VFP(c,a,r) / VFPTOT(a,r);
   2269   Zerodivide off;
   2270    
   2271   Equation E_qo
   2272   # industry zero pure profits condition #
   2273   (all,a,ACTS)(all,r,REG)
   2274       po(a,r) + ao(a,r)
   2275           = sum{c,TOPF, FSHOUT(c,a,r) * [pfa(c,a,r) - afa(c,a,r)]}
   2276           + profitslack(a,r);
   2277   !<
   2278       profitslack is exogenous, unless the user wishes to specify output in a
   2279       given region exogenously.
   2280    
   2281       E_qo defines industry zero pure profits condition. This condition
   2282       permits us to determine the endogenous output level for each sector,
   2283       except when profitslack is itself endogenous.
   2284   >!
   2285    
   2286   Equation E_qfa6
   2287   # sector demands for factor-energy subproduct and intermediate inputs #
   2288   (all,c,TOPF)(all,a,ACTS)(all,r,REG)
   2289       qfa(c,a,r) = -afa(c,a,r) + qo(a,r) - ao(a,r)
   2290                  - ESUBT(a,r) * [pfa(c,a,r) - afa(c,a,r) - po(a,r) - ao(a,r)];
   2291    
   2292   !<
   2293       1-3. Technical change equations
   2294       -------------------------------
   2295   >!
   2296    
   2297   !< Hicks-neutral technical change shifters >!
   2298   Variable (all,a,ACTS)
   2299       aosec(a) # output tech change for act. a, worldwide #;
   2300   Variable (all,r,REG)
   2301       aoreg(r) # specific output tech change in region r #;
   2302   Variable (all,a,ACTS)(all,r,REG)
   2303       aoall(a,r) # output augmenting technical change in act. a of r #;
   2304   Equation E_ao
   2305   # sector/region specific average rate of output augmenting tech change #
   2306   (all,a,ACTS)(all,r,REG)
   2307       ao(a,r) = aosec(a) + aoreg(r) + aoall(a,r);
   2308    
   2309   !< Intermediate input technical change and shifters >!
   2310   Variable (all,c,ALLF)
   2311       afcom(c) # intermediate tech change of input c, worldwide #;
   2312   Variable (all,a,ACTS)
   2313       afsec(a) # intermediate tech change of act. a, worldwide #;
   2314   Variable (all,r,REG)
   2315       afreg(r) # intermediate tech change in region r #;
   2316   Variable (all,c,ALLF)(all,a,ACTS)(all,r,REG)
   2317       afall(c,a,r) # intermediate input c augmenting tech change by act. a in r #;
   2318   Variable (all,r,REG)
   2319       afereg(r) # factor input tech change in region r #;
   2320   Variable (all,e,ENDW)
   2321       afecom(e) # factor input tech change of endowwment e, worldwide #;
   2322   Variable (all,a,ACTS)
   2323       afesec(a) # factor input tech change of act. a, worldwide #;
   2324   Variable (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   2325       afeall(e,a,r) # primary factor e augmenting tech change for act. a in r #;
   2326    
   2327   Equation E_afa
   2328   # sector/region specific average rate of intermediates augmenting tech change #
   2329   (all,c,ALLF)(all,a,ACTS)(all,r,REG)
   2330       afa(c,a,r) = afcom(c) + afsec(a) + afreg(r) + afall(c,a,r)
   2331                  + IF[c in ENDW, afereg(r) + afecom(c) + afesec(a) + afeall(c,a,r)];
   2332    
   2333   Equation E_afe
   2334   # sector/region specific average rate of intermediates augmenting tech change #
   2335   (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   2336       afe(e,a,r) = afa(e,a,r);
   2337    
   2338   !<
   2339       ---------------------
   2340       2-0. Commodity supply
   2341       ---------------------
   2342    
   2343       The following picture describes commodity supply and sourcing. On the supply
   2344       side, activities with multiple outputs are given a CET specification wherein
   2345       they maximize their total revenue stream subject to being on the constant
   2346       elasticity of transformation frontier. On the demand side, buyers of a
   2347       commodity produced by multiple activities wish to minimize the total cost
   2348       of supply subject to a CES preference function.
   2349    
   2350                                    qo(a,r)  [ao(a,r)]
   2351                                     |
   2352                  CET[ETRAQ] ----->  | 'make'
   2353                                     |
   2354                                  qca(c,a,r)
   2355                                     |
   2356                  CES[ESUBQ] ----->  |  'sourcing'
   2357                                     |
   2358                                   qc(c,r)
   2359   >!
   2360    
   2361   Coefficient (parameter)(all,a,ACTS)(all,r,REG)
   2362       ETRAQ(a,r)
   2363       # elasticity of transformation among commodities produced by act. a #;
   2364   Read
   2365       ETRAQ from file GTAPPARM header "ETRQ";
   2366   Assertion (all,a,ACTS)(all,r,REG) ETRAQ(a,r) lt 0;
   2367    
   2368   Coefficient (all,a,ACTS)(all,r,REG)
   2369       MAKESCOM(a,r) # pre-tax output of activity a in r #;
   2370   Formula (all,a,ACTS)(all,r,REG)
   2371       MAKESCOM(a,r) = sum{c,COMM, MAKES(c,a,r)};
   2372   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   2373       MAKESACTSHR(c,a,r) # share of c and a in output of a at supplier prices #;
   2374   Zerodivide default RNREG;
   2375   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   2376       MAKESACTSHR(c,a,r) = MAKES(c,a,r) / MAKESCOM(a,r);
   2377   Zerodivide off;
   2378    
   2379   Equation E_qca
   2380   # supply of commodities by act. a #
   2381   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   2382       qca(c,a,r) = IF[MAKES(c,a,r) gt 0,
   2383                       qo(a,r) - ETRAQ(a,r) * [ps(c,a,r) - po(a,r)]];
   2384    
   2385   Equation E_po
   2386   # average unit (tax-exclusive) cost of output of act. a #
   2387   (all,a,ACTS)(all,r,REG)
   2388        po(a,r) = sum{c,COMM, MAKESACTSHR(c,a,r) * ps(c,a,r)};
   2389    
   2390   Equation E_ps
   2391   # links basic and supply price of commodity c produced by activity a in r #
   2392   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   2393       pca(c,a,r) = ps(c,a,r) + to(c,a,r);
   2394   !<
   2395       E_ps links supplier/producer (pre-) and basic (post-tax) prices for firms.
   2396       This captures the effect of output taxes or subsidies.
   2397       Note: The power of activity tax, to, is commodity- and activity-specific.
   2398             to(c,a,r) > 1 in the case of a tax
   2399             to(c,a,r) < 1 in the case of a subsidy.
   2400   >!
   2401    
   2402   Variable (all,a,ACTS)(all,r,REG)
   2403       pb(a,r) # price index: basic (tax-inclusive) price of output of act. a #;
   2404   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   2405       MAKEBACTSHR(c,a,r) # share of c and a in output of act. a at basic prices #;
   2406   Zerodivide default RNREG;
   2407   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   2408       MAKEBACTSHR(c,a,r) = MAKEB(c,a,r) / MAKEBACT(a,r);
   2409   Zerodivide off;
   2410    
   2411   Equation E_pb
   2412   # price index: basic (tax-inclusive) price of output of act. a #
   2413   (all,a,ACTS)(all,r,REG)
   2414        pb(a,r) = sum{c,COMM, MAKEBACTSHR(c,a,r) * pca(c,a,r)};
   2415    
   2416   Coefficient (parameter)(all,c,COMM)(all,r,REG)
   2417       ESUBQ(c,r)
   2418       # 1/CES elast. for sourcing of commodity c produced by various activities #;
   2419   Formula (initial) (all,c,COMM)(all,r,REG)
   2420       ESUBQ(c,r) = 0.0; ! ie, Default 0.0 means perfect substitutes !
   2421   Read (ifheaderexists)
   2422       ESUBQ from file GTAPPARM header "ESBQ";
   2423   Assertion (all,c,COMM)(all,r,REG) ESUBQ(c,r) ge 0;
   2424   !<
   2425       ESUBQ is 1/CES elasticity. ESUBQ=0.0 means that commodity c produced by 2
   2426       or more activities are perfect substitutes--i.e., each activity receives the
   2427       same price (i.e., the law of one price holds) for a given commodity.
   2428       In the equation E_pca below,  pca(c,a,r) = pds(c,r) if ESUBQ = 0.0
   2429       But this will not work well if two or more activities each only produce the
   2430       same good (e.g., CoalElec and NuclearElec each only produce electricity),
   2431       resulting in structurally singular matrix problems, especially under the
   2432       standard GTAP closure, where most factors used by these activitiesare
   2433       perfectly mobile. In such cases, capital could be set as a sluggish
   2434       factor (note: if ETRAE=-0.000001, capital becomes a sector-specific factor);
   2435       or alternatively, capital could be perfectfly mobile across sectors but with
   2436       ESUBQ set to allow for a degree of commodity sourcing differentiation
   2437       (i.e., commodity c produced by diff activities are imperfect substitutes).
   2438       For example, ESUBQ could be set to 0.5 giving an elasticity of substitution
   2439       of 2.0 = 1/ESUBQ = 1/0.5. Alternative values for ESUBQ could be defined by
   2440       the user in the parameter input file.
   2441   >!
   2442    
   2443   Variable (orig_level=VCB)(all,c,COMM)(all,r,REG)
   2444       qc(c,r) # total commodity supply in region r #;
   2445   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   2446       MAKEBCOMSHR(c,a,r) # share of c by a in commodity supply at basic prices #;
   2447   Zerodivide default RNREG;
   2448   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   2449       MAKEBCOMSHR(c,a,r) = MAKEB(c,a,r) / MAKEBCOM(c,r);
   2450   Zerodivide off;
   2451    
   2452   Equation E_pca
   2453   # CES allocation of commodity output by activity (ESUBQ(c,r) is 1/CES elast.) #
   2454   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   2455       pca(c,a,r) = IF[MAKEB(c,a,r) gt 0,
   2456                       pds(c,r) - ESUBQ(c,r) * [qca(c,a,r) - qc(c,r)]];
   2457    
   2458   Equation E_qc
   2459   # market clearing condition for total commodity supply #
   2460   (all,c,COMM)(all,r,REG)
   2461        qc(c,r) = sum{a,ACTS, MAKEBCOMSHR(c,a,r) * qca(c,a,r)};
   2462    
   2463   !<
   2464       ------------------------
   2465       3-0. Income distribution
   2466       ------------------------
   2467   >!
   2468    
   2469   Variable (all,r,REG)
   2470       fincome(r) # factor income at basic prices net of depreciation #;
   2471   Coefficient (all,r,REG)
   2472       FY(r) # primary factor income in r net of depreciation #;
   2473   Formula (all,r,REG)
   2474       FY(r) = sum{e,ENDW, sum{a,ACTS, EVFB(e,a,r)}} - VDEP(r);
   2475    
   2476   Equation E_fincome
   2477   # factor income at basic prices net of depreciation #
   2478   (all,r,REG)
   2479       FY(r) * fincome(r)
   2480           = sum{e,ENDW, sum{a,ACTS, EVFB(e,a,r)*[peb(e,a,r) + qes(e,a,r)]}}
   2481           - VDEP(r)  * [pinv(r) + kb(r)];
   2482    
   2483   !< Computation of Regional Income >!
   2484   Variable (all,r,REG)
   2485       incomeslack(r) # slack variable in the expression for regional income #;
   2486       !< This is exogenous, unless the user wishes to fix regional income. >!
   2487   Variable (change)(all,r,REG)
   2488       del_indtaxr(r) # change in ratio of indirect taxes to INCOME in r #;
   2489   Coefficient (all,r,REG)
   2490       INDTAX(r) # indirect tax receipts in r #;
   2491   Formula (all,r,REG)
   2492       INDTAX(r) = TAXRPC(r) + TAXRGC(r) + TAXRIC(r) + TAXRIU(r) + TAXRFU(r)
   2493                 + TAXROUT(r) + TAXREXP(r) + TAXRIMP(r);
   2494    
   2495   !< Emissions quota >!
   2496   Variable (all,r,REG)
   2497       gco2q(r) # emissions quota #;
   2498   Coefficient (ge 0) (all,r,REG)
   2499       CO2Q(r) # emissions quota (millions of tonnes of CO2) #;
   2500   Update (all,r,REG)
   2501       CO2Q(r) = gco2q(r);
   2502   Read
   2503       CO2Q from file GTAPDATA header "CO2Q";
   2504    
   2505   Equation E_y
   2506   # regional income = sum of primary factor income and indirect tax receipts #
   2507   (all,r,REG)
   2508       INCOME(r) * y(r)
   2509           = FY(r) * fincome(r)
   2510           + 100.0 * INCOME(r) * del_indtaxr(r)
   2511           + INDTAX(r) * y(r)
   2512           + CO2Q(r) * NCTAXLEV(r) * gco2q(r)
   2513           + 100.0 * CO2Q(r) * del_nctaxb(REGTOBLOC(r))
   2514           + INCOME(r) * incomeslack(r);
   2515   !<
   2516       This equation computes regional income as the sum of primary factor
   2517       payment and indirect tax receipts.  The first term computes the change in
   2518       endowment income, net of depreciation.  The second and third terms compute
   2519       the change in ordinary indirect tax revenue.  The fourth term computes the
   2520       revenues/expenditures from carbon emissions trading.  The fifth term
   2521       computes revenue from carbon taxes.
   2522   >!
   2523    
   2524   !<
   2525       -------------------------------------------------------
   2526       4-0. Allocation of income across expenditure categories
   2527       -------------------------------------------------------
   2528   >!
   2529    
   2530   Variable (all,r,REG)
   2531       uelas(r) # elasticity of cost of utility wrt utility #;
   2532   Variable (all,r,REG)
   2533       dpsave(r) # saving distribution parameter #;
   2534   Variable (all,r,REG)
   2535       dpgov(r) # government consumption distribution parameter #;
   2536   Variable (all,r,REG)
   2537       dppriv(r) # private consumption distribution parameter #;
   2538    
   2539   Equation E_qsave
   2540   # saving #
   2541   (all,r,REG)
   2542       psave(r) + qsave(r) - y(r) = uelas(r) + dpsave(r);
   2543    
   2544   Equation E_yg
   2545   # government consumption expenditure #
   2546   (all,r,REG)
   2547       yg(r) - y(r) = uelas(r) + dpgov(r);
   2548    
   2549   Equation E_yp
   2550   # private consumption expenditure #
   2551   (all,r,REG)
   2552       yp(r) - y(r) = -[uepriv(r) - uelas(r)] + dppriv(r);
   2553    
   2554   Variable (all,r,REG)
   2555       dpav(r) # average distribution parameter shift, for EV calc. #;
   2556   Coefficient (all,r,REG)
   2557       XSHRPRIV(r) # private expenditure share in regional income #;
   2558   Formula (all,r,REG)
   2559       XSHRPRIV(r) = PRIVEXP(r) / INCOME(r);
   2560   Coefficient (all,r,REG)
   2561       XSHRGOV(r) # government expenditure share in regional income #;
   2562   Formula (all,r,REG)
   2563       XSHRGOV(r) = GOVEXP(r) / INCOME(r);
   2564   Coefficient (all,r,REG)
   2565       XSHRSAVE(r) # saving share in regional income #;
   2566   Formula (all,r,REG)
   2567       XSHRSAVE(r) = SAVE(r) / INCOME(r);
   2568    
   2569   Equation E_uelas
   2570   # elasticity of cost of utility wrt utility #
   2571   (all,r,REG)
   2572       uelas(r) = XSHRPRIV(r) * uepriv(r) - dpav(r);
   2573    
   2574   Equation E_dpav
   2575   # average distribution parameter shift #
   2576   (all,r,REG)
   2577       dpav(r)
   2578           = XSHRPRIV(r) * dppriv(r)
   2579           + XSHRGOV(r)  * dpgov(r)
   2580           + XSHRSAVE(r) * dpsave(r);
   2581    
   2582   Variable (all,r,REG)
   2583       p(r) # price index for disposition of income by regional household #;
   2584    
   2585   Equation E_p
   2586   # price index for disposition of income by regional household #
   2587   (all,r,REG)
   2588       p(r) = XSHRPRIV(r) * ppriv(r) + XSHRGOV(r) * pgov(r)
   2589            + XSHRSAVE(r) * psave(r);
   2590    
   2591   Variable (all,r,REG)
   2592       au(r) # input-neutral shift in utility function #;
   2593   Variable (all,r,REG)
   2594       dpsum(r) # sum of the distribution parameters #;
   2595   Variable (all,r,REG)
   2596       u(r) # per capita utility from aggregate hhld expend. in region r #;
   2597   Coefficient (all,r,REG)
   2598       DPARSUM(r) # sum of distribution parameters #;
   2599   Read
   2600       DPARSUM from file GTAPDATA header "DPSM";
   2601   Update (all,r,REG)
   2602       DPARSUM(r) = dpsum(r);
   2603    
   2604   Coefficient (all,r,REG)
   2605       UTILELAS(r) # elasticity of cost of utility wrt utility #;
   2606   Formula (all,r,REG)
   2607       UTILELAS(r)
   2608           = [UELASPRIV(r) * XSHRPRIV(r) + XSHRGOV(r) + XSHRSAVE(r)] / DPARSUM(r);
   2609   Coefficient (all,r,REG)
   2610       DPARPRIV(r) # private consumption distribution parameter #;
   2611   Formula (all,r,REG)
   2612       DPARPRIV(r) = UELASPRIV(r) * XSHRPRIV(r) / UTILELAS(r);
   2613   Coefficient (all,r,REG)
   2614       DPARGOV(r) # government consumption distribution parameter #;
   2615   Formula (all,r,REG)
   2616       DPARGOV(r) = XSHRGOV(r) / UTILELAS(r);
   2617    
   2618   Coefficient (all,r,REG)
   2619       DPARSAVE(r) # saving distribution parameter #;
   2620   Formula (all,r,REG)
   2621       DPARSAVE(r) = XSHRSAVE(r) / UTILELAS(r);
   2622    
   2623   Coefficient (all,r,REG)
   2624       UTILPRIV(r) # utility from private consumption #;
   2625   Formula (initial)(all,r,REG)
   2626       UTILPRIV(r) = 1.0;
   2627   Update (all,r,REG)
   2628       UTILPRIV(r) = up(r);
   2629    
   2630   Coefficient (all,r,REG)
   2631       UTILGOV(r) # utility from government consumption #;
   2632   Formula (initial)(all,r,REG)
   2633       UTILGOV(r) = 1.0;
   2634   Update (all,r,REG)
   2635       UTILGOV(r) = ug(r);
   2636    
   2637   Coefficient (all,r,REG)
   2638       UTILSAVE(r) # utility from saving #;
   2639   Formula (initial)(all,r,REG)
   2640       UTILSAVE(r) = 1.0;
   2641   Update (change) (all,r,REG)
   2642       UTILSAVE(r) = [[qsave(r) - pop(r)] / 100] * UTILSAVE(r);
   2643    
   2644   Equation E_u
   2645   # regional household utility #
   2646   (all,r,REG)
   2647       u(r) = au(r) + DPARPRIV(r) * loge(UTILPRIV(r)) * dppriv(r)
   2648            + DPARGOV(r) * loge(UTILGOV(r)) * dpgov(r)
   2649            + DPARSAVE(r) * loge(UTILSAVE(r)) * dpsave(r)
   2650            + [1.0 / UTILELAS(r)] * [y(r) - pop(r) - p(r)];
   2651    
   2652   Equation E_dpsum
   2653   # sum of the distribution parameters #
   2654   (all,r,REG)
   2655       DPARSUM(r) * dpsum(r)
   2656           = DPARPRIV(r) * dppriv(r)
   2657           + DPARGOV(r) * dpgov(r)
   2658           + DPARSAVE(r) * dpsave(r);
   2659    
   2660   !<
   2661       --------------------------
   2662       5-0. Domestic final demand
   2663       --------------------------
   2664   >!
   2665    
   2666   !<
   2667       5-1. Private expenditures
   2668       -------------------------
   2669   >!
   2670    
   2671   !<  We first compute for the Allen Partials, Price and Income Elasticities
   2672       then derive Private household's Composite Demand >!
   2673    
   2674   Coefficient (parameter)(all,c,TOPP)(all,r,REG)
   2675       SUBPAR(c,r)
   2676       # substitution parameter in CDE minimum expenditure function #;
   2677   Read
   2678       SUBPAR from file GTAPPARM header "SUBP";
   2679   Coefficient (all,c,TOPP)(all,r,REG)
   2680       ALPHA(c,r) # 1 - sub. parameter in the CDE minimum expenditure function #;
   2681   Formula (all,c,TOPP)(all,r,REG)
   2682       ALPHA(c,r) = 1 - SUBPAR(c,r);
   2683   Coefficient (all,c,TOPP)(all,k,TOPP)(all,r,REG)
   2684       APE(c,k,r) # Allen partial elast. of sub. between composite c and k in r #;
   2685   Formula (all,c,TOPP)(all,k,TOPP)(all,r,REG)
   2686       APE(c,k,r)
   2687           = ALPHA(c,r) + ALPHA(k,r) - sum{n,TOPP, CONSHR(n,r) * ALPHA(n,r)};
   2688   Formula (all,c,TOPP)(all,r,REG)
   2689       APE(c,c,r)
   2690           = 2.0 * ALPHA(c,r)
   2691           - sum{n,TOPP, CONSHR(n,r) * ALPHA(n,r)}
   2692           - ALPHA(c,r) / CONSHR(c,r);
   2693    
   2694   Coefficient (all,c,TOPP)(all,r,REG)
   2695       EY(c,r) # income elast. of private hhld demand for c in r #;
   2696   Formula (all,c,TOPP)(all,r,REG)
   2697       EY(c,r)
   2698           =   [1.0 / sum{n,TOPP, CONSHR(n,r) * INCPAR(n,r)}]
   2699               * [INCPAR(c,r) * [1.0 - ALPHA(c,r)]
   2700                   + sum{n,TOPP, CONSHR(n,r) * INCPAR(n,r) * ALPHA(n,r)}]
   2701           + [ALPHA(c,r) - sum{n,TOPP, CONSHR(n,r) * ALPHA(n,r)}];
   2702    
   2703   Coefficient (all,c,TOPP)(all,k,TOPP)(all,r,REG)
   2704       EP(c,k,r)
   2705       # uncomp. elast. of private hhld demand for c wrt price of k in r #;
   2706   Formula (all,c,TOPP)(all,k,TOPP)(all,r,REG)
   2707       EP(c,k,r) = 0;
   2708   Formula (all,c,TOPP)(all,k,TOPP)(all,r,REG)
   2709       EP(c,k,r) = [APE(c,k,r) - EY(c,r)] * CONSHR(k,r);
   2710    
   2711   Variable (all,c,ALLP)(all,r,REG)
   2712       ppa(c,r) # private consumption price for commodity c in region r #;
   2713   Variable (all,c,ALLP)(all,r,REG)
   2714       qpa(c,r) # private hhld demand for commodity c in region r #;
   2715    
   2716   Equation E_qpa1
   2717   # private consumption demands for composite commodities #
   2718   (all,c,TOPP)(all,r,REG)
   2719       qpa(c,r) - pop(r)
   2720           = sum{k,TOPP, EP(c,k,r) * ppa(k,r)} + EY(c,r) * [yp(r) - pop(r)];
   2721   !<
   2722       E_qpa defines private consumption demands for composite commodities.
   2723       Demand system is on a per capita basis. Here, yp(r) - pop(r) is % change in
   2724       per capita income.
   2725   >!
   2726    
   2727   !< Utility from Private Consumption >!
   2728   Coefficient (all,c,TOPP)(all,r,REG)
   2729       XWCONSHR(c,r) # expansion-parameter-weighted consumption share #;
   2730   Formula (all,c,TOPP)(all,r,REG)
   2731       XWCONSHR(c,r) = CONSHR(c,r) * INCPAR(c,r) / UELASPRIV(r);
   2732    
   2733   Equation E_uepriv
   2734   # elasticity of expenditure wrt utility from private consumption #
   2735   (all,r,REG)
   2736       uepriv(r) = sum{c,TOPP, XWCONSHR(c,r) * [ppa(c,r) + qpa(c,r) - yp(r)]};
   2737    
   2738   Equation E_ppriv
   2739   # price index for private consumption expenditure #
   2740   (all,r,REG)
   2741       ppriv(r) = sum{c,TOPP, CONSHR(c,r) * ppa(c,r)};
   2742    
   2743   Equation E_up
   2744   # computation of utility from private consumption in r #
   2745   (all,r,REG)
   2746       UELASPRIV(r) * up(r) = yp(r) - ppriv(r) - pop(r) ;
   2747   !<
   2748       E_up determines private consumption utility for a representative
   2749       household in region r, based on the per capita private expenditure
   2750       function.
   2751   >!
   2752    
   2753   Variable (all,c,COMM)(all,r,REG)
   2754       ppat(c,r) # private consumption price for commodity c in region r #;
   2755   Variable (all,c,COMM)(all,r,REG)
   2756       qpat(c,r) # private hhld demand for commodity c in region r #;
   2757    
   2758   Equation E_qpd
   2759   # private consumption demand for domestic goods #
   2760   (all,c,COMM)(all,r,REG)
   2761       qpd(c,r) = qpat(c,r) - ESUBD(c,r) * [ppd(c,r) - ppat(c,r)];
   2762    
   2763   Zerodivide default RNREG;
   2764   !<  Composite Tradeables >!
   2765   Coefficient (all,c,COMM)(all,r,REG)
   2766       PMSHR(c,r) # share of imports in private hhld cons. at purchaser's prices #;
   2767   Formula (all,c,COMM)(all,r,REG)
   2768       PMSHR(c,r) = VMPP(c,r) / VPPT(c,r);
   2769   Zerodivide off;
   2770    
   2771   Equation E_qpm
   2772   # private consumption demand for aggregate imports #
   2773   (all,c,COMM)(all,r,REG)
   2774       qpm(c,r) = qpat(c,r) - ESUBD(c,r) * [ppm(c,r) - ppat(c,r)];
   2775    
   2776   Equation E_ppat1
   2777   # private consumption price for composite commodities #
   2778   (all,c,COMM)(all,r,REG)
   2779       ppat(c,r) = [1 - PMSHR(c,r)] * ppd(c,r) + PMSHR(c,r) * ppm(c,r);
   2780    
   2781   !<
   2782       5-1.1 Notational Links
   2783       -----------------------
   2784   >!
   2785   Formula (all,c,COMM)(all,r,REG)
   2786       VPP(c,r) = VPPT(c,r);
   2787    
   2788   Equation E_ppat2
   2789   # prices into the private consumption system #
   2790   (all,c,COMM)(all,r,REG)
   2791       ppat(c,r) = ppa(c,r);
   2792    
   2793   Equation E_qpat
   2794   # quantities from the private consumption system #
   2795   (all,c,COMM)(all,r,REG)
   2796       qpat(c,r) = qpa(c,r);
   2797    
   2798   !<
   2799       5-1.2 Energy nest
   2800       -----------------
   2801   >!
   2802   Coefficient (all,c,ENYP)(all,r,REG)
   2803       PENYSHR(c,r) # share of c in cost of energy subutility #;
   2804   Zerodivide default RNREG;
   2805   Formula (all,c,ENYP)(all,r,REG)
   2806       PENYSHR(c,r) = VPP(c,r) / VPPS("eny",r);
   2807   Zerodivide off;
   2808   Coefficient (parameter) (all,r,REG)
   2809       ELPENY(r) # elasticity of substitution in energy subconsumption #;
   2810   Read
   2811       ELPENY from file GTAPPARM header "EPEN";
   2812    
   2813   Equation E_ppa1 # price of energy subutility #
   2814   (all,r,REG)
   2815       ppa("eny",r) = sum{k,ENYP, PENYSHR(k,r) * ppa(k,r)};
   2816    
   2817   Equation E_qpa2
   2818   # demand for commodities into energy subconsumption #
   2819   (all,c,ENYP)(all,r,REG)
   2820       qpa(c,r) = qpa("eny",r) - ELPENY(r) * [ppa(c,r) - ppa("eny",r)];
   2821    
   2822    
   2823   !< GTAP-Power: Add electricity nest >!
   2824   !<
   2825       5-1.3 Electricity nest
   2826       ----------------------
   2827   >!
   2828    
   2829   !<
   2830       5-2.3.1 Electricity (top-level) composite
   2831       -----------------------------------------
   2832   >!
   2833   Variable (all,c,ELEP)(all,r,REG)
   2834       ppac(c,r) # ACES-related private consumption price for commodity c in region r #;
   2835   Coefficient (parameter) (all,r,REG)
   2836       ELPELY(r) # priv. top level elasticity of substitution: electricity and TnD #;
   2837   Formula (initial) (all,r,REG)
   2838       ELPELY(r) = 0.0;
   2839   Read (ifheaderexists)
   2840       ELPELY from file GTAPPARM header "EPEL";
   2841   Zerodivide default RNREG;
   2842   Coefficient (all,c,ELYP)(all,r,REG)
   2843       PSHELY(c,r) # value share of c in private egen+TnD electricity composite #;
   2844   Formula (all,c,ELYP)(all,r,REG)
   2845       PSHELY(c,r) = VPP(c,r) / VPPE("ely",r);
   2846   !Coefficient (all,c,ELYP)(all,r,REG)
   2847       PSHELYVOL(c,r) # vol share of c in private egen+TnD electricity composite #;
   2848   (all,c,ELYP)(all,r,REG)
   2849       PSHELYVOL(c,r) = EPA(c,r) / EPAS("ely",r);!
   2850   Zerodivide off;
   2851    
   2852   Equation E_ppac1
   2853   # ACES-related private composite price for commodity c in region r #
   2854   (all,r,REG)
   2855   !    ppac("ely",r) = sum{c,ELYP, PSHELYVOL(c,r) * ppa(c,r)};!
   2856       ppac("ely",r) = ppa("ely",r);
   2857    
   2858   Equation E_ppa2
   2859   # price of  private (top-level) electricity composite #
   2860   (all,r,REG)
   2861       ppa("ely",r) = sum{c,ELYP, PSHELY(c,r) * ppa(c,r)};
   2862    
   2863   Equation E_qpa3
   2864   # input demand for private (top-level) electricity composite #
   2865   (all,c,ELYP)(all,r,REG)
   2866   !    qpa(c,r) = qpa("ely",r) - ELPELY(r) * [ppa(c,r) - ppac("ely",r)];!
   2867       qpa(c,r) = qpa("ely",r) - ELPELY(r) * [ppa(c,r) - ppa("ely",r)];
   2868    
   2869   !<
   2870       5-2.3.2 Base and Peak load composite
   2871       ------------------------------------
   2872   >!
   2873   Coefficient (parameter) (all,r,REG)
   2874       ELPEGEN(r) # elasticity of substitution in private base load power #;
   2875   !Formula (initial) (all,r,REG)
   2876       ELPEGEN(r) = 1.0;!
   2877   Read !(ifheaderexists)!
   2878       ELPEGEN from file GTAPPARM header "EPEG";
   2879    
   2880   Coefficient (all,c,EGENP)(all,r,REG)
   2881       PSHEGEN(c,r) # value share of c in private base&peak electricity composite #;
   2882   Coefficient (all,c,EGENP)(all,r,REG)
   2883       PSHEGENVOL(c,r) # vol share of c in private base&peak electricity composite #;
   2884   Zerodivide default RNREG;
   2885   Formula (all,c,EGENP)(all,r,REG)
   2886       PSHEGEN(c,r) = VPP(c,r) / VPPE("egen",r);
   2887   Formula (all,c,EGENP)(all,r,REG)
   2888       PSHEGENVOL(c,r) = EPA(c,r) / EPAS("egen",r);
   2889   Zerodivide off;
   2890    
   2891   Equation E_ppac2
   2892   # ACES-related private composite price for commodity c in region r #
   2893   (all,r,REG)
   2894       ppac("egen",r) = sum{c,EGENP, PSHEGENVOL(c,r) * ppa(c,r)};
   2895    
   2896   Equation E_ppa3
   2897   # price of private (base and peak load) electricity composite #
   2898   (all,r,REG)
   2899       ppa("egen",r) = sum{c,EGENP, PSHEGEN(c,r) * ppa(c,r)};
   2900    
   2901   Equation E_qpa4
   2902   # input demand for private (base and peak load) electricity composite #
   2903   (all,c,EGENP)(all,r,REG)
   2904   !    qpa(c,r) = qpa("egen",r) - ELPEGEN(r) * [ppa(c,r) - ppac("egen",r)];!
   2905       qpa(c,r) = qpa("egen",r) - ELPEGEN(r) * [ppa(c,r) - ppa("egen",r)];
   2906    
   2907   !<
   2908       5-2.3.3 Base load nest
   2909       ----------------------
   2910   >!
   2911   Coefficient (parameter) (all,r,REG)
   2912       ELPEBL(r) # elasticity of substitution in private base load power #;
   2913   !Formula (initial) (all,r,REG)
   2914       ELPEBL(r) = 2.0;!
   2915   Read !(ifheaderexists)!
   2916       ELPEBL from file GTAPPARM header "EPEB";
   2917    
   2918   Coefficient (all,c,EBLP)(all,r,REG)
   2919       PSHEBL(c,r) # value share of c in private base load electricity composite #;
   2920   Coefficient (all,c,EBLP)(all,r,REG)
   2921       PSHEBLVOL(c,r) # vol share of c in private base load electricity composite #;
   2922   Zerodivide default RNREG;
   2923   Formula (all,c,EBLP)(all,r,REG)
   2924       PSHEBL(c,r) = VPP(c,r) / VPPE("ebl",r);
   2925   Formula (all,c,EBLP)(all,r,REG)
   2926       PSHEBLVOL(c,r) = EPA(c,r) / EPAS("ebl",r);
   2927   Zerodivide off;
   2928    
   2929   Equation E_ppac3
   2930   # ACES-related private composite price for commodity c in region r #
   2931   (all,r,REG)
   2932       ppac("ebl",r) = sum{c,EBLP, PSHEBLVOL(c,r) * ppa(c,r)};
   2933    
   2934   Equation E_ppa4
   2935   # price of private energy subutility (baseload power) #
   2936   (all,r,REG)
   2937       ppa("ebl",r) = sum{c,EBLP, PSHEBL(c,r) * ppa(c,r)};
   2938    
   2939   Equation E_qpa5
   2940   # private input demand for baseload power #
   2941   (all,c,EBLP)(all,r,REG)
   2942   !    qpa(c,r) = qpa("ebl",r) - ELPEBL(r) * [ppa(c,r) - ppac("ebl",r)];!
   2943       qpa(c,r) = qpa("ebl",r) - ELPEBL(r) * [ppa(c,r) - ppa("ebl",r)];
   2944    
   2945   !<
   2946       5-2.3.4 Peak load nest
   2947       ----------------------
   2948   >!
   2949   Coefficient (parameter) (all,r,REG)
   2950       ELPEPL(r) # elasticity of substitution in private peak load power #;
   2951   !Formula (initial) (all,r,REG)
   2952       ELPEPL(r) = 1.0;!
   2953   Read !(ifheaderexists)!
   2954       ELPEPL from file GTAPPARM header "EPEP";
   2955    
   2956   Coefficient (all,c,EPLP)(all,r,REG)
   2957       PSHEPL(c,r) # value share of c in private peak load electricity composite #;
   2958   Coefficient (all,c,EPLP)(all,r,REG)
   2959       PSHEPLVOL(c,r) # vol share of c in private peak load electricity composite #;
   2960   Zerodivide default RNREG;
   2961   Formula (all,c,EPLP)(all,r,REG)
   2962       PSHEPL(c,r) = VPP(c,r) / VPPE("epl",r);
   2963   Formula (all,c,EPLP)(all,r,REG)
   2964       PSHEPLVOL(c,r) = EPA(c,r) / EPAS("epl",r);
   2965   Zerodivide off;
   2966    
   2967   Equation E_ppac4
   2968   # ACES-related private composite price for commodity c in region r #
   2969   (all,r,REG)
   2970       ppac("epl",r) = sum{c,EPLP, PSHEPLVOL(c,r) * ppa(c,r)};
   2971    
   2972   Equation E_ppa5
   2973   # price of private energy subutility (baseload power) #
   2974   (all,r,REG)
   2975       ppa("epl",r) = sum{c,EPLP, PSHEPL(c,r) * ppa(c,r)};
   2976    
   2977   Equation E_qpa6
   2978   # input demand for private baseload power #
   2979   (all,c,EPLP)(all,r,REG)
   2980   !    qpa(c,r) = qpa("epl",r) - ELPEPL(r) * [ppa(c,r) - ppac("epl",r)];!
   2981       qpa(c,r) = qpa("epl",r) - ELPEPL(r) * [ppa(c,r) - ppa("epl",r)];
   2982   !< GTAP-Power: Add electricity nest and ACET in private consumption (End) >!
   2983    
   2984   !<
   2985       5-2. Public expenditures
   2986       ------------------------
   2987   >!
   2988   Coefficient (all,c,ALLG)(all,r,REG)
   2989       VGP(c,r)
   2990       # government expend. on c in r valued at producer's prices  #;
   2991   Coefficient (all,c,SUBG)(all,r,REG)
   2992       VGPS(c,r)
   2993       # government expend. on c in r valued at producer's prices  #;
   2994    
   2995   Zerodivide default RNREG;
   2996   Coefficient (all,c,COMM)(all,r,REG)
   2997       VDGPNCSHR(c,r)
   2998       # share of carbon-tax-excl. value of gov. consumption of domestic c in r #;
   2999   Formula (all,c,COMM)(all,r,REG)
   3000       VDGPNCSHR(c,r) = VDGPNC(c,r) / VDGP(c,r);
   3001   Coefficient (all,c,COMM)(all,r,REG)
   3002       VMGPNCSHR(c,r)
   3003       # share of carbon-tax-excl. value of gov. consumption of imported c in r #;
   3004   Formula (all,c,COMM)(all,r,REG)
   3005       VMGPNCSHR(c,r) = VMGPNC(c,r) / VMGP(c,r);
   3006   Coefficient (all,c,COMM)(all,r,REG)
   3007       CO2DGVDGP(c,r)
   3008       # emissions intensity of government consumption of domestic c in r #;
   3009   Formula (all,c,COMM)(all,r,REG)
   3010       CO2DGVDGP(c,r) = CO2DG(c,r) / VDGP(c,r);
   3011   Coefficient (all,c,COMM)(all,r,REG)
   3012       CO2MGVMGP(c,r)
   3013       # emissions intensity of government consumption of imported c in r #;
   3014   Formula (all,c,COMM)(all,r,REG)
   3015       CO2MGVMGP(c,r) = CO2MG(c,r) / VMGP(c,r);
   3016   Zerodivide off;
   3017    
   3018   Equation E_pgd
   3019   # links basic and government consumption prices for domestic com. c #
   3020   (all,c,COMM)(all,r,REG)
   3021       pgd(c,r) = VDGPNCSHR(c,r) * (pds(c,r) + tgd(c,r))
   3022                + 100.0 * CO2DGVDGP(c,r) * del_nctaxb(REGTOBLOC(r));
   3023    
   3024   Equation E_pgm
   3025   # links basic and government consumption prices for imported com. c #
   3026   (all,c,COMM)(all,r,REG)
   3027       pgm(c,r) = VMGPNCSHR(c,r) * (pms(c,r) + tgm(c,r))
   3028                + 100.0 * CO2MGVMGP(c,r) * del_nctaxb(REGTOBLOC(r));
   3029    
   3030   Variable (all,c,ALLG)(all,r,REG)
   3031       pga(c,r) # government consumption price for commodity c in region r #;
   3032   Variable (all,c,ALLG)(all,r,REG)
   3033       qga(c,r) # government hhld demand for commodity c in region r #;
   3034   Variable (all,c,COMM)(all,r,REG)
   3035       pgat(c,r) # government consumption price for commodity c in region r #;
   3036   Variable (all,c,COMM)(all,r,REG)
   3037       qgat(c,r) # government hhld demand for commodity c in region r #;
   3038    
   3039   Coefficient (parameter)(all,r,REG)
   3040       ESUBG(r)
   3041       # region-specific elast. of subst. for composite government consumption #;
   3042   Read
   3043       ESUBG from file GTAPPARM header "ESBG";
   3044   Assertion (all,r,REG) ESUBG(r) ge 0;
   3045    
   3046   Equation E_ug
   3047   # utility from government consumption in r #
   3048   (all,r,REG)
   3049       ug(r) = yg(r) - pgov(r) - pop(r);
   3050    
   3051   Zerodivide default RNREG;
   3052   !<  Composite tradeables >!
   3053   Coefficient (all,c,COMM)(all,r,REG)
   3054       GMSHR(c,r) # share of imports for gov't hhld at purchaser's prices #;
   3055   Formula (all,c,COMM)(all,r,REG)
   3056       GMSHR(c,r) = VMGP(c,r) / VGPT(c,r);
   3057   Zerodivide off;
   3058    
   3059   Equation E_qgd
   3060   # government consumption demand for domestic goods #
   3061   (all,c,COMM)(all,r,REG)
   3062       qgd(c,r) = qgat(c,r) - ESUBD(c,r) * [pgd(c,r) - pgat(c,r)];
   3063    
   3064   Equation E_qgm
   3065   # government consumption demand for aggregate imports #
   3066   (all,c,COMM)(all,r,REG)
   3067       qgm(c,r) = qgat(c,r) - ESUBD(c,r) * [pgm(c,r) - pgat(c,r)];
   3068    
   3069   Equation E_pgat1
   3070   # government consumption price for composite commodities #
   3071   (all,c,COMM)(all,r,REG)
   3072       pgat(c,r) = [1 - GMSHR(c,r)] * pgd(c,r) + GMSHR(c,r) * pgm(c,r);
   3073    
   3074   !<
   3075       5-2.1 Notational Links
   3076       ----------------------
   3077   >!
   3078   Formula (all,c,ALLG)(all,r,REG)
   3079       VGP(c,r) = 0.0;
   3080   Formula (all,c,COMM)(all,r,REG)
   3081       VGP(c,r) = VGPT(c,r);
   3082    
   3083   Equation E_pgat2 # prices into the government consumption system #
   3084   (all,c,COMM)(all,r,REG)
   3085       pgat(c,r) = pga(c,r) ;
   3086    
   3087   Equation E_qgat # quantities from the government consumption system #
   3088   (all,c,COMM)(all,r,REG)
   3089       qgat(c,r) = qga(c,r) ;
   3090    
   3091   !< GTAP-Power: Electricity data assignment >!
   3092   Coefficient (all,c,ELEG)(all,r,REG)
   3093       VGPE(c,r) # value of government electricity use in r, at producer's prices #;
   3094   Formula (all,r,REG)
   3095       VGPE("ebl",r) = sum{c,EBLG, VGP(c,r)};
   3096   Formula (all,r,REG)
   3097       VGPE("epl",r) = sum{c,EPLG, VGP(c,r)};
   3098   Formula (all,r,REG)
   3099       VGP("ebl",r) = VGPE("ebl",r);
   3100   Formula (all,r,REG)
   3101       VGP("epl",r) = VGPE("epl",r);
   3102    
   3103   Formula (all,r,REG)
   3104       VGPE("egen",r) = sum{c,EGENG, VGP(c,r)};
   3105   Formula (all,r,REG)
   3106       VGP("egen",r) = VGPE("egen",r);
   3107   Formula (all,r,REG)
   3108       VGPE("ely",r) = sum{c,ELYG, VGP(c,r)};
   3109   Formula (all,r,REG)
   3110       VGP("ely",r) = VGPE("ely",r);
   3111    
   3112   !< GTAP-Power: Energy volume data assignment for ACES >!
   3113   Coefficient (all,c,EGYVOL)(all,r,REG)
   3114       EDG(c,r) # energy volume assoc w/ government demand for dom. c in r, MToE #;
   3115   Formula (initial)(all,c,EGYVOL)(all,r,REG)
   3116       EDG(c,r) = 0.0;
   3117   Read (ifheaderexists)
   3118       EDG from file GTAPDATA header "EDG";
   3119   Update (all,c,EGYVOL)(all,r,REG)
   3120       EDG(c,r) = qgd(c,r);
   3121   Coefficient (all,c,EGYVOL)(all,r,REG)
   3122       EMG(c,r) # energy volume assoc w/ government demand for imp. c in r, MToE #;
   3123   Formula (initial)(all,c,EGYVOL)(all,r,REG)
   3124       EMG(c,r) = 0.0;
   3125   Update (all,c,EGYVOL)(all,r,REG)
   3126       EMG(c,r) = qgm(c,r);
   3127   Read  (ifheaderexists)
   3128       EMG from file GTAPDATA header "EMG";
   3129   Coefficient (all,c,ALLG)(all,r,REG)
   3130       EGA(c,r) # energy volume assoc w/ aggregate government demand for c in r, MToE #;
   3131   Formula (all,c,ALLG)(all,r,REG)
   3132       EGA(c,r) = 0.0;
   3133   Formula (all,c,EGYVOL)(all,r,REG)
   3134       EGA(c,r) = EDG(c,r) + EMG(c,r);
   3135    
   3136   !< GTAP-Power: energy volume assoc w/ electricity sub-products for ACES >!
   3137   Coefficient (all,c,ALLG)(all,r,REG)
   3138       EGAS(c,r) # energy volume assoc w/ government sub-products in r  #;
   3139   Formula (all,c,ALLG)(all,r,REG)
   3140       EGAS(c,r) = 0.0;
   3141   Formula (all,r,REG)
   3142       EGAS("ebl",r) = sum{c,EBLG, EGA(c,r)};
   3143   Formula (all,r,REG)
   3144       EGA("ebl",r) = EGAS("ebl",r);
   3145   Formula (all,r,REG)
   3146       EGAS("epl",r) = sum{c,EPLG, EGA(c,r)};
   3147   Formula (all,r,REG)
   3148       EGA("epl",r) = EGAS("epl",r);
   3149   Formula (all,r,REG)
   3150       EGAS("egen",r) = sum{c,EGENG, EGA(c,r)};
   3151   Formula (all,r,REG)
   3152       EGA("egen",r)= EGAS("egen",r);
   3153   Formula (all,r,REG)
   3154       EGAS("ely",r) = sum{c,ELYG, EGA(c,r)};
   3155   Formula (all,r,REG)
   3156       EGA("ely",r) = EGAS("ely",r);
   3157    
   3158   !< GTAP-Power: End of electricity data assignment >!
   3159    
   3160   !<
   3161       5-2.2. Energy nest
   3162       ------------------
   3163   >!
   3164   Coefficient (parameter) (all,r,REG)
   3165       ELGENY(r) # elasticity of substitution in energy subconsumption #;
   3166   Read
   3167       ELGENY from file GTAPPARM header "EGEN";
   3168    
   3169   Formula (all,c,SUBG)(all,r,REG)
   3170       VGPS(c,r) = 0.0;
   3171   Formula (all,r,REG)
   3172       VGPS("eny",r) = sum{c,ENYG, VGP(c,r)};
   3173   Formula (all,r,REG)
   3174       VGP("eny",r) = VGPS("eny",r);
   3175    
   3176   Zerodivide default RNREG;
   3177   Coefficient (all,c,ENYG)(all,r,REG)
   3178       GSHENY(c,r) # share of c in cost of energy subutility #;
   3179   Formula (all,c,ENYG)(all,r,REG)
   3180       GSHENY(c,r) = VGP(c,r) / VGPS("eny",r);
   3181   Zerodivide off;
   3182    
   3183   Equation E_pga1 # price of energy subutility #
   3184   (all,r,REG)
   3185       pga("eny",r) = sum{c,ENYG, GSHENY(c,r)* pga(c,r)};
   3186    
   3187   Equation E_qga1 # demand for inputs into energy subconsumption #
   3188   (all,c,ENYG)(all,r,REG)
   3189       qga(c,r) = qga("eny",r) - ELGENY(r) * [pga(c,r) - pga("eny",r)];
   3190    
   3191   !<
   3192       5-2.3. Non-Energy nest
   3193       ----------------------
   3194   >!
   3195   Coefficient (parameter) (all,r,REG)
   3196       ELGNENY(r)
   3197       # elasticity of substitution in non-energy subconsumption #;
   3198   Read
   3199       ELGNENY from file GTAPPARM header "EGNN";
   3200    
   3201   Formula (all,r,REG)
   3202       VGPS("neny",r) = sum{c,NENYG, VGP(c,r)};
   3203   Formula (all,r,REG)
   3204       VGP("neny",r) = VGPS("neny",r);
   3205   Coefficient (all,c,NENYG)(all,r,REG)
   3206       GSHNENY(c,r)
   3207       # share of c in cost of non-energy subutility #;
   3208   Formula (all,c,NENYG)(all,r,REG)
   3209       GSHNENY(c,r) = VGP(c,r) / VGPS("neny",r);
   3210    
   3211   Equation E_pga2
   3212   # price of non-energy subutility #
   3213   (all,r,REG)
   3214       pga("neny",r) = sum{c,NENYG, GSHNENY(c,r) * pga(c,r)};
   3215    
   3216   Equation E_qga2
   3217   # demand for inputs into non-energy subconsumption #
   3218   (all,c,NENYG)(all,r,REG)
   3219       qga(c,r) = qga("neny",r) - ELGNENY(r) * [pga(c,r) - pga("neny",r)];
   3220    
   3221    
   3222   !< GTAP-Power: Add electricity nest >!
   3223   !<
   3224       5-2.4 Electricity nest
   3225       ----------------------
   3226   >!
   3227   Variable (all,c,ELEG)(all,r,REG)
   3228       pgac(c,r) # ACES-related government price for commodity c in region r #;
   3229    
   3230   !<
   3231       5-2.4.1 Electricity (top-level) composite
   3232       -----------------------------------------
   3233   >!
   3234   Coefficient (parameter) (all,r,REG)
   3235       ELGELY(r) # top level elasticity of substitution: electricity and TnD #;
   3236   !Formula (initial) (all,r,REG)
   3237       ELGELY(r) = 0.0;!
   3238   Read !(ifheaderexists)!
   3239       ELGELY from file GTAPPARM header "EGEL";
   3240   Zerodivide default RNREG;
   3241   Coefficient (all,c,ELYG)(all,r,REG)
   3242       GSHELY(c,r) # value share of c in gov. egen+TnD electricity composite #;
   3243   Formula (all,c,ELYG)(all,r,REG)
   3244       GSHELY(c,r) = VGP(c,r) / VGPE("ely",r);
   3245   !Coefficient (all,c,ELYG)(all,r,REG)
   3246       GSHELYVOL(c,r) # vol share of c in gov. egen+TnD electricity composite #;
   3247   Formula (all,c,ELYG)(all,r,REG)
   3248       GSHELYVOL(c,r) = EGA(c,r) / EGAS("ely",r);!
   3249   Zerodivide off;
   3250    
   3251   Equation E_pgac1
   3252   # ACES-related government composite price for commodity c in region r #
   3253   (all,r,REG)
   3254       pgac("ely",r) = pga("ely",r);
   3255    
   3256   Equation E_pga3
   3257   # price of  top level government electricity composite #
   3258   (all,r,REG)
   3259       pga("ely",r) = sum{c,ELYG, GSHELY(c,r) * pga(c,r)};
   3260    
   3261   Equation E_qga4
   3262   # input demand for top level government electricity composite #
   3263   (all,c,ELYG)(all,r,REG)
   3264   !    qga(c,r) = qga("ely",r) - ELGELY(r) * [pga(c,r) - pgac("ely",r)];!
   3265       qga(c,r) = qga("ely",r) - ELGELY(r) * [pga(c,r) - pga("ely",r)];
   3266    
   3267    
   3268   !<
   3269       5-2.4.2 Base and Peak load composite
   3270       ------------------------------------
   3271   >!
   3272   Coefficient (parameter) (all,r,REG)
   3273       ELGEGEN(r) # elasticity of substitution in government base load power #;
   3274   !Formula (initial) (all,r,REG)
   3275       ELGEGEN(r) = 1.0;!
   3276   Read !(ifheaderexists)!
   3277       ELGEGEN from file GTAPPARM header "EGEG";
   3278    
   3279   Coefficient (all,c,EGENG)(all,r,REG)
   3280       GSHEGEN(c,r) # value share of c in gov. base&peak electricity composite #;
   3281   Coefficient (all,c,EGENG)(all,r,REG)
   3282       GSHEGENVOL(c,r) # vol share of c in gov. base&peak electricity composite #;
   3283   Zerodivide default RNREG;
   3284   Formula (all,c,EGENG)(all,r,REG)
   3285       GSHEGEN(c,r) = VGP(c,r) / VGPE("egen",r);
   3286   Formula (all,c,EGENG)(all,r,REG)
   3287       GSHEGENVOL(c,r) = EGA(c,r) / EGAS("egen",r);
   3288   Zerodivide off;
   3289    
   3290   Equation E_pgac2
   3291   # ACES-related government composite price for commodity c in region r #
   3292   (all,r,REG)
   3293       pgac("egen",r) = sum{c,EGENG, GSHEGENVOL(c,r) * pga(c,r)};
   3294    
   3295   Equation E_pga4
   3296   # price of  (base and peak load) electricity composite #
   3297   (all,r,REG)
   3298       pga("egen",r) = sum{c,EGENG, GSHEGEN(c,r) * pga(c,r)};
   3299    
   3300   Equation E_qga5
   3301   # input demand for (base and peak load) electricity composite #
   3302   (all,c,EGENG)(all,r,REG)
   3303   !    qga(c,r) = qga("egen",r) - ELGEGEN(r) * [pga(c,r) - pgac("egen",r)];!
   3304       qga(c,r) = qga("egen",r) - ELGEGEN(r) * [pga(c,r) - pga("egen",r)];
   3305    
   3306   !<
   3307       5-2.4.3 Base load nest
   3308       ----------------------
   3309   >!
   3310   Coefficient (parameter) (all,r,REG)
   3311       ELGEBL(r) # elasticity of substitution in government base load power #;
   3312   !Formula (initial) (all,r,REG)
   3313       ELGEBL(r) = 1.0;!
   3314   Read !(ifheaderexists)!
   3315       ELGEBL from file GTAPPARM header "EGEB";
   3316    
   3317   Coefficient (all,c,EBLG)(all,r,REG)
   3318       GSHEBL(c,r) # value share of c in gov. base load electricity composite #;
   3319   Coefficient (all,c,EBLG)(all,r,REG)
   3320       GSHEBLVOL(c,r) # vol share of c in gov. base load electricity composite #;
   3321   Zerodivide default RNREG;
   3322   Formula (all,c,EBLG)(all,r,REG)
   3323       GSHEBL(c,r) = VGP(c,r) / VGPE("ebl",r);
   3324   Formula (all,c,EBLG)(all,r,REG)
   3325       GSHEBLVOL(c,r) = EGA(c,r) / EGAS("ebl",r);
   3326   Zerodivide off;
   3327    
   3328   Equation E_pgac3
   3329   # ACES-related government composite price for commodity c in region r #
   3330   (all,r,REG)
   3331       pgac("ebl",r) = sum{c,EBLG, GSHEBLVOL(c,r) * pga(c,r)};
   3332    
   3333   Equation E_pga5
   3334   # price of energy subutility (baseload power) #
   3335   (all,r,REG)
   3336       pga("ebl",r) = sum{c,EBLG, GSHEBL(c,r) * pga(c,r)};
   3337    
   3338   Equation E_qga6
   3339   # input demand for baseload power #
   3340   (all,c,EBLG)(all,r,REG)
   3341   !    qga(c,r) = qga("ebl",r) - ELGEBL(r) * [pga(c,r) - pgac("ebl",r)];!
   3342       qga(c,r) = qga("ebl",r) - ELGEBL(r) * [pga(c,r) - pga("ebl",r)];
   3343    
   3344   !<
   3345       5-2.4.4 Peak load nest
   3346       ----------------------
   3347   >!
   3348   Coefficient (parameter) (all,r,REG)
   3349       ELGEPL(r) # elasticity of substitution in government peak load power #;
   3350   !Formula (initial) (all,r,REG)
   3351       ELGEPL(r) = 1.0;!
   3352   Read !(ifheaderexists)!
   3353       ELGEPL from file GTAPPARM header "EGEP";
   3354    
   3355   Coefficient (all,c,EPLG)(all,r,REG)
   3356       GSHEPL(c,r) # value share of c in gov. peak load electricity composite #;
   3357   Coefficient (all,c,EPLG)(all,r,REG)
   3358       GSHEPLVOL(c,r) # vol share of c in gov. peak load electricity composite #;
   3359   Zerodivide default RNREG;
   3360   Formula (all,c,EPLG)(all,r,REG)
   3361       GSHEPL(c,r) = VGP(c,r) / VGPE("epl",r);
   3362   Formula (all,c,EPLG)(all,r,REG)
   3363       GSHEPLVOL(c,r) = EGA(c,r) / EGAS("epl",r);
   3364   Zerodivide off;
   3365    
   3366   Equation E_pgac4
   3367   # ACES-related government composite price for commodity c in region r #
   3368   (all,r,REG)
   3369       pgac("epl",r) = sum{c,EPLG, GSHEPLVOL(c,r) * pga(c,r)};
   3370    
   3371   Equation E_pga6
   3372   # price of energy subutility (baseload power) #
   3373   (all,r,REG)
   3374       pga("epl",r) = sum{c,EPLG, GSHEPL(c,r) * pga(c,r)};
   3375    
   3376   Equation E_qga7
   3377   # input demand for baseload power #
   3378   (all,c,EPLG)(all,r,REG)
   3379   !    qga(c,r) = qga("epl",r) - ELGEPL(r) * [pga(c,r) - pgac("epl",r)];!
   3380       qga(c,r) = qga("epl",r) - ELGEPL(r) * [pga(c,r) - pga("epl",r)];
   3381   !< GTAP-Power: Add electricity nest and ACET in government consumption (End) >!
   3382    
   3383   !<
   3384       5-2.5 Top of the Government Consumption Structure
   3385       -------------------------------------------------
   3386   >!
   3387    
   3388   Coefficient (parameter)(all,r,REG)
   3389       ELGUG(r)
   3390       # elasticity of substitution in the top of government consumption nest #;
   3391   Read
   3392       ELGUG from file GTAPPARM header "EGUG";
   3393    
   3394   Equation E_pgov
   3395   # definition of price index for aggregate gov't purchases #
   3396   (all,r,REG)
   3397       pgov(r) = sum{c,TOPG, [VGP(c,r) / GOVEXP(r)] * pga(c,r)};
   3398    
   3399   Equation E_qga3
   3400   # government consumption demands for top nest commodities #
   3401   (all,c,TOPG)(all,r,REG)
   3402       qga(c,r) = yg(r) - pgov(r) - ELGUG(r) * [pga(c,r) - pgov(r)];
   3403    
   3404    
   3405   !<
   3406       5-3. Investment expenditures
   3407       ----------------------------
   3408   >!
   3409   Variable (all,r,REG)
   3410       qinv(r) # demand for investment/capital goods in region r #;
   3411   Coefficient (all,c,ALLI)(all,r,REG)
   3412       VIP(c,r)
   3413       # investment expend. on c in r valued at producer's prices  #;
   3414   Coefficient (all,c,SUBI)(all,r,REG)
   3415       VIPS(c,r)
   3416       # investment expend. on c in r valued at producer's prices  #;
   3417    
   3418   Zerodivide default RNREG;
   3419   Coefficient (all,c,COMM)(all,r,REG)
   3420       VDIPNCSHR(c,r)
   3421       # share of carbon-tax-excl. value of inv. consumption of domestic c in r #;
   3422   Formula (all,c,COMM)(all,r,REG)
   3423       VDIPNCSHR(c,r) = VDIPNC(c,r) / VDIP(c,r);
   3424   Coefficient (all,c,COMM)(all,r,REG)
   3425       VMIPNCSHR(c,r)
   3426       # share of carbon-tax-excl. value of inv. consumption of imported c in r #;
   3427   Formula (all,c,COMM)(all,r,REG)
   3428       VMIPNCSHR(c,r) = VMIPNC(c,r) / VMIP(c,r);
   3429    
   3430   Coefficient (all,c,COMM)(all,r,REG)
   3431       CO2DIVDIP(c,r)
   3432       # emissions intensity of investment consumption of domestic c in r #;
   3433   Formula (all,c,COMM)(all,r,REG)
   3434       CO2DIVDIP(c,r) = CO2DI(c,r) / VDIP(c,r);
   3435   Coefficient (all,c,COMM)(all,r,REG)
   3436       CO2MIVMIP(c,r)
   3437       # emissions intensity of investment consumption of imported c in r #;
   3438   Formula (all,c,COMM)(all,r,REG)
   3439       CO2MIVMIP(c,r) = CO2MI(c,r) / VMIP(c,r);
   3440   Zerodivide off;
   3441    
   3442   Variable (all,c,ALLI)(all,r,REG)
   3443       pia(c,r) # price of investment commodity in region r #;
   3444   Variable (all,c,ALLI)(all,r,REG)
   3445       qia(c,r) # demand for investment commodity c in region r #;
   3446    
   3447   Equation E_pid
   3448   # links basic and investment consumption prices for domestic com. c #
   3449   (all,c,COMM)(all,r,REG)
   3450       pid(c,r) = VDIPNCSHR(c,r) * (pds(c,r) + tid(c,r))
   3451                + 100.0 * CO2DIVDIP(c,r) * del_nctaxb(REGTOBLOC(r));
   3452    
   3453   Equation E_pim
   3454   # links basic and investment consumption prices for imported com. c #
   3455   (all,c,COMM)(all,r,REG)
   3456       pim(c,r) = VMIPNCSHR(c,r) * (pms(c,r) + tim(c,r))
   3457                + 100.0 * CO2MIVMIP(c,r) * del_nctaxb(REGTOBLOC(r));
   3458    
   3459   Variable (all,c,COMM)(all,r,REG)
   3460       piat(c,r) # investment consumption price for commodity c in region r #;
   3461   Variable (all,c,COMM)(all,r,REG)
   3462       qiat(c,r) # investment hhld demand for commodity c in region r #;
   3463    
   3464   Zerodivide default RNREG;
   3465   !<  Composite tradeables >!
   3466   Coefficient (all,c,COMM)(all,r,REG)
   3467       IMSHR(c,r) # share of imports in investment expenditure at purchaser's prices #;
   3468   Formula (all,c,COMM)(all,r,REG)
   3469       IMSHR(c,r) = VMIP(c,r) / VIPT(c,r);
   3470   Zerodivide off;
   3471    
   3472   Equation E_qid
   3473   # investment consumption demand for domestic goods #
   3474   (all,c,COMM)(all,r,REG)
   3475       qid(c,r) = qiat(c,r) - ESUBD(c,r) * [pid(c,r) - piat(c,r)];
   3476    
   3477   Equation E_qim
   3478   # investment consumption demand for aggregate imports #
   3479   (all,c,COMM)(all,r,REG)
   3480       qim(c,r) = qiat(c,r) - ESUBD(c,r) * [pim(c,r) - piat(c,r)];
   3481    
   3482   Equation E_piat1
   3483   # investment consumption price for composite commodities #
   3484   (all,c,COMM)(all,r,REG)
   3485       piat(c,r) = [1 - IMSHR(c,r)] * pid(c,r) + IMSHR(c,r) * pim(c,r);
   3486    
   3487   !<
   3488        5-3.1 Notational Links
   3489       -----------------------
   3490   >!
   3491   Formula (all,c,ALLI)(all,r,REG)
   3492       VIP(c,r) = 0.0;
   3493   Formula (all,c,COMM)(all,r,REG)
   3494       VIP(c,r) = VIPT(c,r);
   3495    
   3496   Equation E_piat2 # prices into the investment consumption system #
   3497   (all,c,COMM)(all,r,REG)
   3498       piat(c,r) = pia(c,r) ;
   3499    
   3500   Equation E_qiat # quantities from the investment consumption system #
   3501   (all,c,COMM)(all,r,REG)
   3502       qiat(c,r) = qia(c,r);
   3503    
   3504   !<
   3505       5-3.2 Energy nest
   3506       ----------------
   3507   >!
   3508    
   3509   !< GTAP-Power: Electricity data assignment >!
   3510   Coefficient (all,c,ELEI)(all,r,REG)
   3511       VIPE(c,r) # value of electricity use by investment agent in r, at producer's prices #;
   3512   Formula (all,r,REG)
   3513       VIPE("ebl",r) = sum{c,EBLI, VIP(c,r)};
   3514   Formula (all,r,REG)
   3515       VIPE("epl",r) = sum{c,EPLI, VIP(c,r)};
   3516   Formula (all,r,REG)
   3517       VIP("ebl",r) = VIPE("ebl",r);
   3518   Formula (all,r,REG)
   3519       VIP("epl",r) = VIPE("epl",r);
   3520   Formula (all,r,REG)
   3521       VIPE("egen",r) = sum{c,EGENI, VIP(c,r)};
   3522   Formula (all,r,REG)
   3523       VIP("egen",r) = VIPE("egen",r);
   3524   Formula (all,r,REG)
   3525       VIPE("ely",r) = sum{c,ELYI, VIP(c,r)};
   3526   Formula (all,r,REG)
   3527       VIP("ely",r) = VIPE("ely",r);
   3528    
   3529   !< GTAP-Power: Energy volume data assignment for ACES >!
   3530   Coefficient (all,c,EGYVOL)(all,r,REG)
   3531       EDI(c,r) # energy volume assoc w/ investment demand for dom. c in r, MToE #;
   3532   Formula (initial)(all,c,EGYVOL)(all,r,REG)
   3533       EDI(c,r) = 0.0;
   3534   Read (ifheaderexists)
   3535       EDI from file GTAPDATA header "EDI";
   3536   Update (all,c,EGYVOL)(all,r,REG)
   3537       EDI(c,r) = qid(c,r);
   3538   Coefficient (all,c,EGYVOL)(all,r,REG)
   3539       EMI(c,r) # energy volume assoc w/ investment demand for imp. c in r, MToE #;
   3540   Formula (initial)(all,c,EGYVOL)(all,r,REG)
   3541       EMI(c,r) = 0.0;
   3542   Update (all,c,EGYVOL)(all,r,REG)
   3543       EMI(c,r) = qim(c,r);
   3544   Read  (ifheaderexists)
   3545       EMI from file GTAPDATA header "EMI";
   3546   Coefficient (all,c,ALLI)(all,r,REG)
   3547       EIA(c,r) # energy volume assoc w/ aggregate investment demand for c in r, MToE #;
   3548   Formula (all,c,ALLI)(all,r,REG)
   3549       EIA(c,r) = 0.0;
   3550   Formula (all,c,EGYVOL)(all,r,REG)
   3551       EIA(c,r) = EDI(c,r) + EMI(c,r);
   3552    
   3553   !< GTAP-Power: energy volume assoc w/ electricity sub-products for ACES >!
   3554   Coefficient (all,c,ALLI)(all,r,REG)
   3555       EIAS(c,r) # energy volume assoc w/ investment sub-products in r  #;
   3556   Formula (all,c,ALLI)(all,r,REG)
   3557       EIAS(c,r) = 0.0;
   3558   Formula (all,r,REG)
   3559       EIAS("ebl",r) = sum{c,EBLI, EIA(c,r)};
   3560   Formula (all,r,REG)
   3561       EIA("ebl",r) = EIAS("ebl",r);
   3562   Formula (all,r,REG)
   3563       EIAS("epl",r) = sum{c,EPLI, EIA(c,r)};
   3564   Formula (all,r,REG)
   3565       EIA("epl",r) = EIAS("epl",r);
   3566   Formula (all,r,REG)
   3567       EIAS("egen",r) = sum{c,EGENI, EIA(c,r)};
   3568   Formula (all,r,REG)
   3569       EIA("egen",r)= EIAS("egen",r);
   3570   Formula (all,r,REG)
   3571       EIAS("ely",r) = sum{c,ELYI, EIA(c,r)};
   3572   Formula (all,r,REG)
   3573       EIA("ely",r) = EIAS("ely",r);
   3574   !< GTAP-Power: End of electricity data assignment >!
   3575    
   3576   Coefficient (parameter) (all,r,REG)
   3577       ELIENY(r) # elasticity of substitution in energy subconsumption #;
   3578   !Formula (initial) (all,r,REG)
   3579       ELIENY(r) = 0.0;!
   3580   Read !(ifheaderexists)!
   3581       ELIENY from file GTAPPARM header "EIEL";
   3582    
   3583   Formula (all,c,SUBI)(all,r,REG)
   3584       VIPS(c,r) = 0.0;
   3585   Formula (all,r,REG)
   3586       VIPS("eny",r) = sum{c,ENYI, VIP(c,r)};
   3587   Formula (all,r,REG)
   3588       VIP("eny",r) = VIPS("eny",r);
   3589    
   3590   Zerodivide default RNREG;
   3591   Coefficient (all,c,ENYI)(all,r,REG)
   3592       ISHENY(c,r) # share of c in cost of energy subutility #;
   3593   Formula (all,c,ENYI)(all,r,REG)
   3594       ISHENY(c,r) = VIP(c,r) / VIPS("eny",r);
   3595   Zerodivide off;
   3596    
   3597   Equation E_pia1 # price of energy subutility #
   3598   (all,r,REG)
   3599       pia("eny",r) = sum{c,ENYI, ISHENY(c,r) * pia(c,r)};
   3600    
   3601   Equation E_qia1 # demand for inputs into energy subconsumption #
   3602   (all,c,ENYI)(all,r,REG)
   3603       qia(c,r) = qia("eny",r) - ELIENY(r) * [pia(c,r) - pia("eny",r)];
   3604    
   3605   !<
   3606       5-3.3 Non-Energy nest
   3607       ---------------------
   3608   >!
   3609   Coefficient (parameter) (all,r,REG)
   3610       ELINENY(r)
   3611       # elasticity of substitution in non-energy subconsumption #;
   3612   Formula (initial) (all,r,REG)
   3613       ELINENY(r) = 0.0;
   3614   Read (ifheaderexists)
   3615       ELINENY from file GTAPPARM header "EINN";
   3616    
   3617   Formula (all,r,REG)
   3618       VIPS("neny",r) = sum{c,NENYI, VIP(c,r)};
   3619   Formula (all,r,REG)
   3620       VIP("neny",r) = VIPS("neny",r);
   3621    
   3622   Coefficient (all,c,NENYI)(all,r,REG)
   3623       ISHNENY(c,r)
   3624       # share of c in cost of non-energy subutility #;
   3625   Formula (all,c,NENYI)(all,r,REG)
   3626       ISHNENY(c,r) = VIP(c,r) / VIPS("neny",r);
   3627    
   3628   Equation E_pia2
   3629   # price of non-energy subutility #
   3630   (all,r,REG)
   3631       pia("neny",r) = sum{c,NENYI, ISHNENY(c,r) * pia(c,r)};
   3632    
   3633   Equation E_qia2
   3634   # demand for inputs into non-energy subconsumption #
   3635   (all,c,NENYI)(all,r,REG)
   3636       qia(c,r) = qia("neny",r) - ELINENY(r) * [pia(c,r) - pia("neny",r)];
   3637    
   3638   !<
   3639       5-2.4 Electricity nest
   3640       ----------------------
   3641   >!
   3642   Variable (all,c,ELEG)(all,r,REG)
   3643       piac(c,r) # ACES-related investment price for commodity c in region r #;
   3644    
   3645   !<
   3646       5-2.4.1 Electricity (top-level) composite
   3647       -----------------------------------------
   3648   >!
   3649   Coefficient (parameter) (all,r,REG)
   3650       ELIELY(r) # top level elasticity of substitution: electricity and TnD #;
   3651   !Formula (initial) (all,r,REG)
   3652       ELIELY(r) = 0.0;!
   3653   Read !(ifheaderexists)!
   3654       ELIELY from file GTAPPARM header "EIEL";
   3655   Zerodivide default RNREG;
   3656   Coefficient (all,c,ELYI)(all,r,REG)
   3657       ISHELY(c,r) # value share of c in investment's egen+TnD electricity composite #;
   3658   Formula (all,c,ELYI)(all,r,REG)
   3659       ISHELY(c,r) = VIP(c,r) / VIPE("ely",r);
   3660   !Coefficient (all,c,ELYI)(all,r,REG)
   3661       ISHELYVOL(c,r) # vol share of c in investment's egen+TnD electricity composite #;
   3662   Formula (all,c,ELYI)(all,r,REG)
   3663       ISHELYVOL(c,r) = EIA(c,r) / EIAS("ely",r);!
   3664   Zerodivide off;
   3665    
   3666   Equation E_piac1
   3667   # ACES-related investment price for commodity c in region r #
   3668   (all,r,REG)
   3669       piac("ely",r) = pia("ely",r);
   3670    
   3671   Equation E_pia3
   3672   # price of  top level investment electricity composite #
   3673   (all,r,REG)
   3674       pia("ely",r) = sum{c,ELYI, ISHELY(c,r) * pia(c,r)};
   3675    
   3676   Equation E_qia4
   3677   # input demand for top level investment electricity composite #
   3678   (all,c,ELYI)(all,r,REG)
   3679   !    qia(c,r) = qia("ely",r) - ELIELY(r) * [pia(c,r) - piac("ely",r)];!
   3680       qia(c,r) = qia("ely",r) - ELIELY(r) * [pia(c,r) - pia("ely",r)];
   3681    
   3682   !<
   3683       5-2.4.2 Base and Peak load composite
   3684       ------------------------------------
   3685   >!
   3686   Coefficient (parameter) (all,r,REG)
   3687       ELIEGEN(r) # elasticity of substitution in investment base load power #;
   3688   !Formula (initial) (all,r,REG)
   3689       ELIEGEN(r) = 1.0;!
   3690   Read !(ifheaderexists)!
   3691       ELIEGEN from file GTAPPARM header "EIEG";
   3692    
   3693   Coefficient (all,c,EGENI)(all,r,REG)
   3694       ISHEGEN(c,r) # value share of c in investment's base&peak electricity composite #;
   3695   Coefficient (all,c,EGENI)(all,r,REG)
   3696       ISHEGENVOL(c,r) # vol share of c in investment's base&peak electricity composite #;
   3697   Zerodivide default RNREG;
   3698   Formula (all,c,EGENI)(all,r,REG)
   3699       ISHEGEN(c,r) = VIP(c,r) / VIPE("egen",r);
   3700   Formula (all,c,EGENI)(all,r,REG)
   3701       ISHEGENVOL(c,r) = EIA(c,r) / EIAS("egen",r);
   3702   Zerodivide off;
   3703    
   3704   Equation E_piac2
   3705   # ACES-related investment price for commodity c in region r #
   3706   (all,r,REG)
   3707       piac("egen",r) = sum{c,EGENI, ISHEGENVOL(c,r) * pia(c,r)};
   3708    
   3709   Equation E_pia4
   3710   # price of  (base and peak load) electricity composite #
   3711   (all,r,REG)
   3712       pia("egen",r) = sum{c,EGENI, ISHEGEN(c,r) * pia(c,r)};
   3713    
   3714   Equation E_qia5
   3715   # input demand for (base and peak load) electricity composite #
   3716   (all,c,EGENI)(all,r,REG)
   3717   !    qia(c,r) = qia("egen",r) - ELIEGEN(r) * [pia(c,r) - piac("egen",r)];!
   3718       qia(c,r) = qia("egen",r) - ELIEGEN(r) * [pia(c,r) - pia("egen",r)];
   3719    
   3720   !<
   3721       5-2.4.3 Base load nest
   3722       ----------------------
   3723   >!
   3724   Coefficient (parameter) (all,r,REG)
   3725       ELIEBL(r) # elasticity of substitution in investment's base load power #;
   3726   !Formula (initial) (all,r,REG)
   3727       ELIEBL(r) = 2.0;!
   3728   Read !(ifheaderexists)!
   3729       ELIEBL from file GTAPPARM header "EIEB";
   3730    
   3731   Coefficient (all,c,EBLI)(all,r,REG)
   3732       ISHEBL(c,r) # value share of c in investment's base load electricity composite #;
   3733   Coefficient (all,c,EBLI)(all,r,REG)
   3734       ISHEBLVOL(c,r) # vol share of c in investment's base load electricity composite #;
   3735   Zerodivide default RNREG;
   3736   Formula (all,c,EBLI)(all,r,REG)
   3737       ISHEBL(c,r) = VIP(c,r) / VIPE("ebl",r);
   3738   Formula (all,c,EBLI)(all,r,REG)
   3739       ISHEBLVOL(c,r) = EIA(c,r) / EIAS("ebl",r);
   3740   Zerodivide off;
   3741    
   3742   Equation E_piac3
   3743   # ACES-related investment price for commodity c in region r #
   3744   (all,r,REG)
   3745       piac("ebl",r) = sum{c,EBLI, ISHEBLVOL(c,r) * pia(c,r)};
   3746    
   3747   Equation E_pia5
   3748   # price of energy subutility (baseload power) #
   3749   (all,r,REG)
   3750       pia("ebl",r) = sum{c,EBLI, ISHEBL(c,r) * pia(c,r)};
   3751    
   3752   Equation E_qia6
   3753   # input demand for baseload power #
   3754   (all,c,EBLI)(all,r,REG)
   3755   !    qia(c,r) = qia("ebl",r) - ELIEBL(r) * [pia(c,r) - piac("ebl",r)];!
   3756       qia(c,r) = qia("ebl",r) - ELIEBL(r) * [pia(c,r) - pia("ebl",r)];
   3757    
   3758   !<
   3759       5-2.4.4 Peak load nest
   3760       ----------------------
   3761   >!
   3762   Coefficient (parameter) (all,r,REG)
   3763       ELIEPL(r) # elasticity of substitution in investment peak load power #;
   3764   !Formula (initial) (all,r,REG)
   3765       ELIEPL(r) = 1.0;!
   3766   Read !(ifheaderexists)!
   3767       ELIEPL from file GTAPPARM header "EIEP";
   3768    
   3769   Coefficient (all,c,EPLI)(all,r,REG)
   3770       ISHEPL(c,r) # value share of c in investment's peak load electricity composite #;
   3771   Coefficient (all,c,EPLI)(all,r,REG)
   3772       ISHEPLVOL(c,r) # vol share of c in investment's peak load electricity composite #;
   3773   Zerodivide default RNREG;
   3774   Formula (all,c,EPLI)(all,r,REG)
   3775       ISHEPL(c,r) = VIP(c,r) / VIPE("epl",r);
   3776   Formula (all,c,EPLI)(all,r,REG)
   3777       ISHEPLVOL(c,r) = EIA(c,r) / EIAS("epl",r);
   3778   Zerodivide off;
   3779    
   3780   Equation E_piac4
   3781   # ACES-related investment price for commodity c in region r #
   3782   (all,r,REG)
   3783       piac("epl",r) = sum{c,EPLI, ISHEPLVOL(c,r) * pia(c,r)};
   3784    
   3785   Equation E_pia6
   3786   # price of energy subutility (baseload power) #
   3787   (all,r,REG)
   3788       pia("epl",r) = sum{c,EPLI, ISHEPL(c,r) * pia(c,r)};
   3789    
   3790   Equation E_qia7
   3791   # input demand for baseload power #
   3792   (all,c,EPLI)(all,r,REG)
   3793   !    qia(c,r) = qia("epl",r) - ELIEPL(r) * [pia(c,r) - piac("epl",r)];!
   3794       qia(c,r) = qia("epl",r) - ELIEPL(r) * [pia(c,r) - pia("epl",r)];
   3795    
   3796   !<
   3797       5-3.5 Top of the investment Consumption Structure
   3798       -------------------------------------------------
   3799   >!
   3800   Equation E_pinv
   3801   # definition of price index for aggregate gov't purchases #
   3802   (all,r,REG)
   3803       pinv(r) = sum{c,TOPI, [VIP(c,r) / REGINV(r)] * pia(c,r)};
   3804    
   3805   Equation E_qia3
   3806   # investment consumption demands for top nest commodities #
   3807   (all,c,TOPI)(all,r,REG)
   3808       qia(c,r) = qinv(r);
   3809    
   3810   !<
   3811       -----------------------------------------------
   3812       6-0. Trade, goods market equilibrium and prices
   3813       -----------------------------------------------
   3814   >!
   3815    
   3816   !<
   3817       6-1. Sourcing of imports
   3818       ------------------------
   3819   >!
   3820    
   3821   Coefficient (all,c,COMM)(all,r,REG)
   3822       VMB(c,r) # value of aggregate imports of commodity c in r #;
   3823   Formula (all,c,COMM)(all,r,REG)
   3824       VMB(c,r) = sum{a,ACTS, VMFB(c,a,r)} + VMIB(c,r)
   3825                + VMPB(c,r) + VMGB(c,r);
   3826    
   3827   Zerodivide default RNREG;
   3828   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   3829       FMCSHR(c,a,r) # share of import c used by act. a in r #;
   3830   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   3831       FMCSHR(c,a,r) = VMFB(c,a,r) / VMB(c,r);
   3832    
   3833   Coefficient (all,c,COMM)(all,r,REG)
   3834       PMCSHR(c,r) # share of import c used by priv. hhlds in total imports in r #;
   3835   Formula (all,c,COMM)(all,r,REG)
   3836       PMCSHR(c,r) = VMPB(c,r) / VMB(c,r);
   3837    
   3838   Coefficient (all,c,COMM)(all,r,REG)
   3839       GMCSHR(c,r) # the share of import c by gov't hhlds in total imports in r #;
   3840   Formula (all,c,COMM)(all,r,REG)
   3841       GMCSHR(c,r) = VMGB(c,r) / VMB(c,r);
   3842    
   3843   Coefficient (all,c,COMM)(all,r,REG)
   3844       IMCSHR(c,r) # share of import c by investment agent in total imports in r #;
   3845   Formula (all,c,COMM)(all,r,REG)
   3846       IMCSHR(c,r) = VMIB(c,r) / VMB(c,r);
   3847   Zerodivide off;
   3848    
   3849   Equation E_qms
   3850   # assures mkt clearing for imported goods entering each region #
   3851   (all,c,COMM)(all,r,REG)
   3852       qms(c,r)
   3853           = sum{a,ACTS, FMCSHR(c,a,r) * qfm(c,a,r)}
   3854           + PMCSHR(c,r) * qpm(c,r)
   3855           + GMCSHR(c,r) * qgm(c,r)
   3856           + IMCSHR(c,r) * qim(c,r);
   3857    
   3858   Variable (all,c,COMM)(all,s,REG)(all,d,REG)
   3859       ams(c,s,d) # commodity c augmenting tech change from s to d #;
   3860   Coefficient (parameter)(all,c,COMM)(all,r,REG)
   3861       ESUBM(c,r)
   3862       # region-specific elast. of sub. among imports c in Armington structure #;
   3863   Read
   3864       ESUBM from file GTAPPARM header "ESBM";
   3865   Assertion (all,c,COMM)(all,r,REG) ESUBM(c,r) ge 0;
   3866    
   3867   Equation E_qxs
   3868   # regional demand for disaggregated imported commodities by source #
   3869   (all,c,COMM)(all,s,REG)(all,d,REG)
   3870       qxs(c,s,d)
   3871           = -ams(c,s,d) + qms(c,d)
   3872           - ESUBM(c,d) * [pmds(c,s,d) - ams(c,s,d) - pms(c,d)];
   3873    
   3874   Coefficient (all,c,COMM)(all,d,REG)
   3875       IMPBASIC(c,d) # total imports of good c by DEST region d, at basic prices #;
   3876   Formula (all,c,COMM)(all,d,REG)
   3877       IMPBASIC(c,d) = sum{s,REG, VMSB(c,s,d)};
   3878   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)
   3879       MSHRS(c,s,d) # share of imports from s in imp. bill of r at basic prices #;
   3880   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   3881       MSHRS(c,s,d) = VMSB(c,s,d) / IMPBASIC(c,d);
   3882    
   3883   Equation E_pms
   3884   # price for aggregate imports #
   3885   (all,c,COMM)(all,d,REG)
   3886       pms(c,d) = sum{s,REG, MSHRS(c,s,d) * [pmds(c,s,d) - ams(c,s,d)]};
   3887    
   3888   !<
   3889       6-2. International trade and transport margins
   3890       ----------------------------------------------
   3891   >!
   3892    
   3893   !<
   3894       6-2-1. Demand for Global Transport Services
   3895       -------------------------------------------
   3896   >!
   3897    
   3898   Variable (all,c,COMM)(all,s,REG)(all,d,REG)
   3899       ptrans(c,s,d) # cost index for international transport of c from s to d #;
   3900   Variable (all,m,MARG)(all,c,COMM)(all,s,REG)(all,d,REG)
   3901       qtmfsd(m,c,s,d) # international usage margin m on c from s to d #;
   3902   !<
   3903       International margin usage, by Margin, Freight, Source, and Destination,
   3904       i.e., the percent change in usage of m in transport of c from s to d.
   3905   >!
   3906    
   3907   Variable (all,m,MARG)
   3908       pt(m) # price index of composite margins services, by margin mode m #;
   3909   Variable (all,m,MARG)
   3910       qtm(m) # global margin usage #;
   3911   Variable (all,m,MARG)(all,c,COMM)(all,s,REG)(all,d,REG)
   3912       atmfsd(m,c,s,d) # tech change in m's shipping of c from region s to d #;
   3913   !<
   3914       Technical progress in shipping by Margin, Freight, Source, and
   3915       Destination.  This is endogenous and driven by the following mode-,
   3916       commodity-, source-, and destination-specific determinants.
   3917   >!
   3918    
   3919   Equation E_qtmfsd
   3920   # bilateral demand for transport services #
   3921   (all,m,MARG)(all,c,COMM)(all,s,REG)(all,d,REG)
   3922       qtmfsd(m,c,s,d) = qxs(c,s,d) - atmfsd(m,c,s,d);
   3923   !<
   3924       E_qtmfsd equation computes the bilateral demand for international
   3925       transportation services.  It reflects the fact that the demand for
   3926       services along any particular route is proportional to the quantity of
   3927       merchandise shipped [i.e., QXS(c,s,d)].  It is here that we introduce the
   3928       potential for input-augmenting tech change, atmfsd(m,c,s,d), which is
   3929       commodity- and route-specific.  Thus, in the levels:
   3930               ATMFSD(m,c,s,d) * QTMFSD(m,c,s,d) = QXS(c,s,d)
   3931       where QTMFSD is the amount of composite margins services m used along this
   3932       route.  Technological improvements are reflected by atmfsd(c,s,d) > 0, and
   3933       these reduce the margins services required for this c,s,d triplet.  Tech.
   3934       change also dampens the cost of shipping, thereby lowering the CIF price
   3935       implied by a given FOB value (see 6-2-2).
   3936   >!
   3937    
   3938   Coefficient (ge 0) (all,m,MARG)(all,c,COMM)(all,s,REG)(all,d,REG)
   3939       VTMFSD(m,c,s,d)
   3940       # int'l margin usage, by margin, freight, source, and destination #;
   3941   Read
   3942       VTMFSD from file GTAPDATA header "VTWR";
   3943   Update (all,m,MARG)(all,c,COMM)(all,s,REG)(all,d,REG)
   3944       VTMFSD(m,c,s,d) = pt(m) * qtmfsd(m,c,s,d);
   3945    
   3946   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)
   3947       VTFSD(c,s,d) # aggregate value of svces in the shipment of c from s to d #;
   3948   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   3949       VTFSD(c,s,d) = sum{m,MARG, VTMFSD(m,c,s,d)};
   3950   !<
   3951       In a balanced data base, (all,c,COMM)(all,s,REG)(all,d,REG),
   3952       VCIF(c,s,d) = VFOB(c,s,d) + VTFSD(c,s,d).
   3953   >!
   3954    
   3955   Coefficient
   3956       VTUSE # international margin services usage #;
   3957   Formula
   3958       VTUSE = sum{m,MARG, sum{c,COMM, sum{s,REG, sum{d,REG, VTMFSD(m,c,s,d)}}}};
   3959   Coefficient (all,m,MARG)
   3960       VTMUSE(m) # international margin services usage, by type #;
   3961   Formula (all,m,MARG)
   3962       VTMUSE(m) = sum{c,COMM, sum{s,REG, sum{d,REG, VTMFSD(m,c,s,d)}}};
   3963    
   3964   Coefficient (all,m,MARG)(all,c,COMM)(all,s,REG)(all,d,REG)
   3965       VTFSD_MSH(m,c,s,d) # share of margin m in cost of getting c from s to d #;
   3966   Formula (all,m,MARG)(all,c,COMM)(all,r,REG)
   3967           (all,d,REG: VTFSD(c,r,d) > 0.0)
   3968       VTFSD_MSH(m,c,r,d) = VTMFSD(m,c,r,d) / VTFSD(c,r,d);
   3969   Formula (all,m,MARG)(all,c,COMM)(all,s,REG)
   3970           (all,d,REG: VTFSD(c,s,d) = 0.0)
   3971       VTFSD_MSH(m,c,s,d) = VTMUSE(m) / VTUSE;
   3972    
   3973   Equation E_ptrans
   3974   #  generates flow-specific modal average cost of transport index (cf. HT7) #
   3975   (all,c,COMM)(all,s,REG)(all,d,REG)
   3976       ptrans(c,s,d)
   3977           = sum{m,MARG, VTFSD_MSH(m,c,s,d) * [pt(m) - atmfsd(m,c,s,d)]};
   3978   !<
   3979       average cost index for margin services used in getting c from s to d
   3980   >!
   3981    
   3982   Coefficient (all,m,MARG)
   3983       VTMPROV(m) # international margin services provision #;
   3984   Formula (all,m,MARG)
   3985       VTMPROV(m) = sum{r,REG, VST(m,r)};
   3986   !<
   3987       In a balanced data base, VTMPROV = VTMUSE.
   3988   >!
   3989   Coefficient (all,r,REG)
   3990       VTRPROV(r) # international margin supply, by region #;
   3991   Formula (all,r,REG)
   3992       VTRPROV(r) = sum{m,MARG, VST(m,r)};
   3993   Coefficient
   3994       VT # international margin supply #;
   3995   Formula
   3996       VT = sum{m,MARG, sum{r,REG, VST(m,r)}};
   3997    
   3998   Coefficient (all,m,MARG)(all,c,COMM)(all,s,REG)(all,d,REG)
   3999       VTMUSESHR(m,c,s,d) # share of c,s,d usage in global demand for m #;
   4000   Formula (all,m,MARG)(all,c,COMM)(all,s,REG)(all,d,REG)
   4001       VTMUSESHR(m,c,s,d) = VTFSD(c,s,d) / VT;
   4002   Formula
   4003       (all,m,MARG: VTMUSE(m) <> 0.0)(all,c,COMM)(all,s,REG)(all,d,REG)
   4004       VTMUSESHR(m,c,s,d) = VTMFSD(m,c,s,d) / VTMUSE(m);
   4005    
   4006   Equation E_qtm
   4007   # global demand for margin m #
   4008   (all,m,MARG)
   4009       qtm(m)
   4010           = sum{c,COMM, sum{s,REG, sum{d,REG,
   4011             VTMUSESHR(m,c,s,d) * qtmfsd(m,c,s,d)}}};
   4012    
   4013   Coefficient (parameter)(all,m,MARG)
   4014       ESUBS(m)
   4015       # elasticity of sub. among transportation service inputs #;
   4016   Read
   4017       ESUBS from file GTAPPARM header "ESBS";
   4018   Assertion (all,m,MARG) ESUBS(m) ge 0;
   4019    
   4020   Equation E_qst
   4021   # generate demand for regional supply of global transportation service #
   4022   (all,m,MARG)(all,r,REG)
   4023       qst(m,r) = qtm(m) - ESUBS(m)*[pds(m,r) - pt(m)];
   4024    
   4025   !<
   4026       6-2-2. Supply of Transport Services
   4027       -----------------------------------
   4028   >!
   4029    
   4030   Coefficient (all,m,MARG)(all,r,REG)
   4031       VTSUPPSHR(m,r) # share of region r in global supply of margin m #;
   4032   Formula (all,m,MARG)(all,r,REG)
   4033       VTSUPPSHR(m,r) = VTRPROV(r) / VT;
   4034   Formula (all,m,MARG: VTMPROV(m) <> 0.0)(all,r,REG)
   4035       VTSUPPSHR(m,r) = VST(m,r) / VTMPROV(m);
   4036    
   4037   Equation E_pt
   4038   # generate price index for composite transportation services #
   4039   (all,m,MARG)
   4040       pt(m) = sum{r,REG, VTSUPPSHR(m,r) * pds(m,r)};
   4041   !<
   4042       E_pt equation generates a price index for transportation services based on
   4043       zero profits.  NOTE:
   4044       (1) Sales to international transportation are not subject to export tax.
   4045           This is why we base the costs to the transport sector at basic prices
   4046           of the goods sold to international transportation.
   4047       (2) We assume that the supply shares for margin services are uniform
   4048           across freight, source of freight, and destination.
   4049   >!
   4050    
   4051   Variable (all,m,COMM)
   4052       atm(m) # tech change in mode m, worldwide #;
   4053   Variable (all,c,COMM)
   4054       atf(c) # tech change shipping of c, worldwide #;
   4055   Variable (all,r,REG)
   4056       ats(r) # tech change shipping from region r #;
   4057   Variable (all,d,REG)
   4058       atd(d) # tech change shipping to d #;
   4059   Variable (all,m,MARG)(all,c,COMM)(all,s,REG)(all,d,REG)
   4060       atall(m,c,s,d) # tech change in m's shipping of c from region s to d #;
   4061    
   4062   Equation E_atmfsd
   4063   #  generates flow-specific average rate of technical change #
   4064   (all,m,MARG)(all,c,COMM)(all,s,REG)(all,d,REG)
   4065       atmfsd(m,c,s,d) = atm(m) + atf(c) + ats(s) + atd(d) + atall(m,c,s,d);
   4066    
   4067   !<
   4068       6-3. Trade prices
   4069       -----------------
   4070   >!
   4071    
   4072   !<
   4073       6-3-1. Export Prices
   4074       --------------------
   4075   >!
   4076    
   4077   Variable (all,c,COMM)(all,r,REG)
   4078       tx(c,r) # dest.-gen. change in subsidy on exports of c from r #;
   4079   Variable (all,c,COMM)(all,s,REG)(all,d,REG)
   4080       txs(c,s,d) # dest.-spec. change in subsidy on exports of c from s to d #;
   4081   !<
   4082       The variable txs captures changes in the power of bilateral export taxes.
   4083       However, the presence of a destination-generic export subsidy shift (tx)
   4084       also permits the user to swap a single export tax shock with another
   4085       target variable.  It is most naturally swapped with the variable qo to
   4086       insulate domestic producers from the world market.
   4087    
   4088       The sign of tx(c,r) and txs(c,s,d) has been CHANGED in GTAP model version 7
   4089       tx(c,r)  > 1 in the case of a tax
   4090       txs(c,r) > 1 in the case of a tax
   4091       tx(c,r)  < 1 in the case of a subsidy.
   4092       txs(c,r) < 1 in the case of a subsidy.
   4093   >!
   4094    
   4095   Equation E_pfob
   4096   # links basic and FOB exports prices #
   4097   (all,c,COMM)(all,s,REG)(all,d,REG)
   4098       pfob(c,s,d) = pds(c,s) + tx(c,s) + txs(c,s,d);
   4099    
   4100   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)
   4101       VCIFCOST(c,s,d) # value of imports calculated as total cost of imports #;
   4102   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   4103       VCIFCOST(c,s,d) = VFOB(c,s,d) + VTFSD(c,s,d);
   4104    
   4105   Zerodivide default RNREG;
   4106   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)
   4107       FOBSHR(c,s,d) # FOB share in (com. and margin) imports at CIF prices #;
   4108   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   4109       FOBSHR(c,s,d) = VFOB(c,s,d) / VCIFCOST(c,s,d);
   4110   Zerodivide off;
   4111    
   4112   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)
   4113       TRNSHR(c,s,d) # Intl. transp. share in (com. and marg) imp. at CIF prices #;
   4114   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   4115       TRNSHR(c,s,d) = 1 - FOBSHR(c,s,d);
   4116    
   4117   Equation E_pcif
   4118   # links FOB and CIF prices for good c shipped from region s to d #
   4119   (all,c,COMM)(all,s,REG)(all,d,REG)
   4120       pcif(c,s,d) = FOBSHR(c,s,d) * pfob(c,s,d) + TRNSHR(c,s,d) * ptrans(c,s,d);
   4121   !<
   4122       This equation links export and import prices for each commodity/route
   4123       triplet.  Note that technical change is embodied in ptrans(c,s,d) which is
   4124       a cost index.
   4125   >!
   4126    
   4127   Variable (all,c,COMM)(all,r,REG)
   4128       tm(c,r) # source-gen. change in tax on imports of c into r #;
   4129   Variable (all,c,COMM)(all,s,REG)(all,d,REG)
   4130       tms(c,s,d) # source-spec. change in tax on imports of c from s to d #;
   4131   !<
   4132       The variable tms captures changes in the power of bilateral import taxes.
   4133       However, the presence of a source-generic import tariff shift (tm) also
   4134       permits the user to swap a single import tariff shock with another target
   4135       variable.  In particular, to insulate domestic producers from import price
   4136       changes, it may be swapped with the relative price variable pr -- see
   4137       below.
   4138   >!
   4139    
   4140   Equation E_pmds
   4141   # links basic domestic import prices and CIF import prices #
   4142   (all,c,COMM)(all,s,REG)(all,d,REG)
   4143       pmds(c,s,d) = pcif(c,s,d) + tm(c,d) + tms(c,s,d);
   4144    
   4145   Variable (orig_level=1.0)(all,c,COMM)(all,r,REG)
   4146       pr(c,r) # ratio of domestic to imported prices in r #;
   4147   Equation E_pr
   4148   # defines target price ratio to be attained via the variable levy #
   4149   (all,c,COMM)(all,r,REG)
   4150       pr(c,r) = pds(c,r) - pms(c,r);
   4151   !<
   4152       E_pr equation defines the target price ratio to be attained via the
   4153       variable levy.  This price ratio is the ratio of domestic to average
   4154       imported goods' price.  Note that the way this price ratio is defined, it
   4155       includes intraregional imports as well.  In most applications, regions
   4156       will represent groups of individual countries.  However, in the case of
   4157       the EU, this is problematic, since recent versions of the database have
   4158       incorporated intra-EU trade flows.  Therefore, when aggregated to the EU
   4159       level, the composite import price includes both intra-EU and outside
   4160       imports.  So some modification is needed to handle the EU case.
   4161   >!
   4162    
   4163   !<
   4164       6-4. Goods market equilibrium
   4165       -----------------------------
   4166   >!
   4167   zerodivide default RNREG;
   4168   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4169       FDCSHR(c,a,r) # share of dom. prod. c used by act. a in r #;
   4170   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4171       FDCSHR(c,a,r) = VDFB(c,a,r) / VDB(c,r);
   4172   Coefficient (all,c,COMM)(all,r,REG)
   4173       PDCSHR(c,r) # share of domestic prod. of c used by private hhlds in r #;
   4174   Formula (all,c,COMM)(all,r,REG)
   4175       PDCSHR(c,r) = VDPB(c,r) / VDB(c,r);
   4176   Coefficient (all,c,COMM)(all,r,REG)
   4177       GDCSHR(c,r) # share of imports of c used by gov't hhlds in r #;
   4178   Formula (all,c,COMM)(all,r,REG)
   4179       GDCSHR(c,r) = VDGB(c,r) / VDB(c,r);
   4180   Coefficient (all,c,COMM)(all,r,REG)
   4181       IDCSHR(c,r) # share of domestic prod. of c used by investment in r #;
   4182   Formula (all,c,COMM)(all,r,REG)
   4183       IDCSHR(c,r) = VDIB(c,r) / VDB(c,r);
   4184   zerodivide off;
   4185    
   4186   Variable (orig_level=VDB)(all,c,COMM)(all,r,REG)
   4187       qds(c,r) # domestic sales of commodity c in r #;
   4188   Equation E_qds
   4189   # assures market clearing for domestic sales #
   4190   (all,c,COMM)(all,r,REG)
   4191       qds(c,r) = sum{a,ACTS, FDCSHR(c,a,r) * qfd(c,a,r)}
   4192                + PDCSHR(c,r) * qpd(c,r)
   4193                + GDCSHR(c,r) * qgd(c,r)
   4194                + IDCSHR(c,r) * qid(c,r);
   4195    
   4196   Variable (all,c,COMM)(all,r,REG)
   4197       tradslack(c,r) # slack variable in tradeables market clearing condition #;
   4198   !<
   4199       tradslack is exogenous unless the user wishes to specify the price of
   4200       tradeables exogenously, in which case the analysis becomes partial
   4201       equilibrium and walraslack must be exogenized.
   4202   >!
   4203   Zerodivide default RNREG;
   4204   Coefficient (all,c,COMM)(all,r,REG)
   4205       DSSHR(c,r) # share of domestic sales of c in r #;
   4206   Formula (all,c,COMM)(all,r,REG)
   4207       DSSHR(c,r) = VDB(c,r) / VCB(c,r);
   4208   Coefficient (all,m,MARG)(all,r,REG)
   4209       STSHR(m,r) # share of sales of m to global transport services in r #;
   4210   Formula (all,m,MARG)(all,r,REG)
   4211       STSHR(m,r) = VST(m,r) / VCB(m,r);
   4212   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)
   4213       XSSHR(c,s,d) # share of export sales of c to s in r #;
   4214   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   4215       XSSHR(c,s,d) = VXSB(c,s,d) / VCB(c,s);
   4216   Zerodivide off;
   4217    
   4218   Equation E_pds1
   4219   # assures market clearing for commodities #
   4220   (all,c,COMM)(all,r,REG)
   4221       qc(c,r) = DSSHR(c,r) * qds(c,r) + sum{d,REG, XSSHR(c,r,d) * qxs(c,r,d)}
   4222               + IF[c in MARG, STSHR(c,r) * qst(c,r)]
   4223               + tradslack(c,r);
   4224    
   4225   !<
   4226       6-5. Agents' prices for goods
   4227       -----------------------------
   4228   >!
   4229   Zerodivide default RNREG;
   4230   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4231       VDFPNCSHR(c,a,r)
   4232       # share of carbon-tax-excl. value of firm consumption of domestic c in r #;
   4233   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4234       VDFPNCSHR(c,a,r) = VDFPNC(c,a,r) / VDFP(c,a,r);
   4235   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4236       VMFPNCSHR(c,a,r)
   4237       # share of carbon-tax-excl. value of firm consumption of imported c in r #;
   4238   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4239       VMFPNCSHR(c,a,r) = VMFPNC(c,a,r) / VMFP(c,a,r);
   4240   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4241       CO2DFVDFP(c,a,r)
   4242       # emissions intensity of firm consumption of domestic c in r #;
   4243   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4244       CO2DFVDFP(c,a,r) = CO2DF(c,a,r) / VDFP(c,a,r);
   4245   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4246       CO2MFVMFP(c,a,r)
   4247       # emissions intensity of firm consumption of imported c in r #;
   4248   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4249       CO2MFVMFP(c,a,r) = CO2MF(c,a,r) / VMFP(c,a,r);
   4250   Zerodivide off;
   4251    
   4252   Equation E_pfd
   4253   # links domestic basic and firm prices #
   4254   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4255       pfd(c,a,r) = VDFPNCSHR(c,a,r) * [pds(c,r) + tfd(c,a,r)]
   4256                  + 100.0 * CO2DFVDFP(c,a,r) * del_nctaxb(REGTOBLOC(r));
   4257   !<
   4258       E_pfd  links domestic basic and firm prices. It holds only for domestic
   4259       goods and it captures the effect of commodity taxation of firms.
   4260   >!
   4261    
   4262   Equation E_pfm
   4263   # links domestic basic and firm prices #
   4264   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4265       pfm(c,a,r) = VMFPNCSHR(c,a,r) * [pms(c,r) + tfm(c,a,r)]
   4266                  + 100.0 * CO2MFVMFP(c,a,r) * del_nctaxb(REGTOBLOC(r));
   4267    
   4268   !<
   4269       E_pfm links domestic basic and firm prices.  It holds only for imported
   4270       goods and it captures the effect of commodity taxation of firms.
   4271   >!
   4272    
   4273   Zerodivide default RNREG;
   4274   Coefficient (all,c,COMM)(all,r,REG)
   4275       VDPPNCSHR(c,r)
   4276       # share of carbon-tax-excl. value of priv. consumption of dom. product #;
   4277   Formula (all,c,COMM)(all,r,REG)
   4278       VDPPNCSHR(c,r) = VDPPNC(c,r) / VDPP(c,r);
   4279    
   4280   Coefficient (all,c,COMM)(all,r,REG)
   4281       CO2DPVDPP(c,r)
   4282       # emissions intensity of private consumption of domestic product #;
   4283   Formula (all,c,COMM)(all,r,REG)
   4284       CO2DPVDPP(c,r) = CO2DP(c,r) / VDPP(c,r);
   4285    
   4286   Coefficient (all,c,COMM)(all,r,REG)
   4287       VMPPNCSHR(c,r)
   4288       # share of carbon-tax-excl. value of priv. consumption of imports #;
   4289   Formula (all,c,COMM)(all,r,REG)
   4290       VMPPNCSHR(c,r) = VMPPNC(c,r) / VMPP(c,r);
   4291   Coefficient (all,c,COMM)(all,r,REG)
   4292       CO2MPVMPP(c,r)
   4293       # emissions intensity of private consumption of imports #;
   4294   Formula (all,c,COMM)(all,r,REG)
   4295       CO2MPVMPP(c,r) = CO2MP(c,r) / VMPP(c,r);
   4296   Zerodivide off;
   4297    
   4298   Equation E_ppd
   4299   # links basic and private household consumption prices for domestic com. c #
   4300   (all,c,COMM)(all,r,REG)
   4301       ppd(c,r) = VDPPNCSHR(c,r) * [pds(c,r) + tpd(c,r)]
   4302                + 100 * CO2DPVDPP(c,r) * del_nctaxb(REGTOBLOC(r));
   4303    
   4304   Equation E_ppm
   4305   # links basic and private household consumption prices for imported com. c #
   4306   (all,c,COMM)(all,r,REG)
   4307       ppm(c,r) = VMPPNCSHR(c,r) * [pms(c,r) + tpm(c,r)]
   4308                + 100.0 * CO2MPVMPP(c,r) * del_nctaxb(REGTOBLOC(r));
   4309    
   4310   !<
   4311       6-6. Private hhld tax shifter
   4312       -----------------------------
   4313   >!
   4314   Variable  (all,c,COMM)(all,r,REG)
   4315       tpdall(c,r) # comm.-, source-spec. shifter in private cons. tax of dom. c #;
   4316   Variable (all,c,COMM)(all,r,REG)
   4317       tpmall(c,r) # comm.-, source-spec. shifter in private cons. tax of imp. c #;
   4318   Variable (all,r,REG)
   4319       tpreg(r) # source-generic tax shifter on private cons. #;
   4320   !<
   4321       The variable tpreg(r) can be swapped with del_ttaxr(r) in order to generate
   4322       a tax replacement scenario, whereby taxes remain a constant share of
   4323       national income.
   4324   >!
   4325    
   4326   Equation E_tpd
   4327   # permits uniform consumption tax change #
   4328   (all,c,COMM)(all,r,REG)
   4329       tpd(c,r) = tpdall(c,r) + tpreg(r);
   4330    
   4331   Equation E_tpm
   4332   # permits uniform consumption tax change #
   4333   (all,c,COMM)(all,r,REG)
   4334       tpm(c,r) = tpmall(c,r) + tpreg(r);
   4335    
   4336   !<
   4337       ----------------------------
   4338       7. Factor market equilibrium
   4339       ----------------------------
   4340   >!
   4341    
   4342   Variable (all,e,ENDWMS)(all,r,REG)
   4343       pe(e,r) # price of mobile and sluggish endowment e in region r #;
   4344   Variable (all,e,ENDWMS)(all,r,REG)
   4345       qe(e,r) # supply of mobile and sluggish endowment e in region r #;
   4346    
   4347   !<
   4348       7-1. Mobile endowments
   4349       ----------------------
   4350   >!
   4351   Coefficient (all,e,ENDWM)(all,a,ACTS)(all,r,REG)
   4352       ENDWMSHR(e,a,r) # share of mobile endow. e used by act. a at supply prices #;
   4353   Formula (all,e,ENDWM)(all,a,ACTS)(all,r,REG)
   4354       ENDWMSHR(e,a,r) = EVOS(e,a,r) / VES(e,r);
   4355    
   4356   Equation E_pe1
   4357   # mkt clearing for perfectly mobile endowments in each r #
   4358   (all,e,ENDWM)(all,r,REG)
   4359       qe(e,r) = sum{a,ACTS, ENDWMSHR(e,a,r) * qfe(e,a,r)} + endwslack(e,r);
   4360    
   4361   Equation E_qes1
   4362   # basic price of mobile endowments in a in r #
   4363   (all,e,ENDWM)(all,a,ACTS)(all,r,REG)
   4364       pes(e,a,r) = pe(e,r);
   4365    
   4366   !<
   4367       7-2. Sluggish endowments
   4368       ------------------------
   4369   >!
   4370    
   4371   Coefficient (parameter)(all,e,ENDW)(all,r,REG)
   4372       ETRAE(e,r)
   4373       # region-specific elast. of transformation for sluggish factor endowments #;
   4374   Read
   4375       ETRAE from file GTAPPARM header "ETRE";
   4376   Assertion (all,e,ENDWS)(all,r,REG) ETRAE(e,r) lt 0;
   4377    
   4378   Equation E_qes2
   4379   # allocation of sluggish endowments across sectors #
   4380   (all,e,ENDWS)(all,a,ACTS)(all,r,REG)
   4381       qes(e,a,r) = qe(e,r) - ETRAE(e,r) * [pes(e,a,r) - pe(e,r)]
   4382                  - endwslack(e,r);
   4383    
   4384   Coefficient (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   4385       REVSHR(e,a,r) # Share of endowment e in total endowment revenue/supply #;
   4386   Formula (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   4387       REVSHR(e,a,r) = EVOS(e,a,r) / VES(e,r);
   4388    
   4389   Equation E_pe2
   4390   # composite price for sluggish endowments #
   4391   (all,e,ENDWS)(all,r,REG)
   4392       pe(e,r) = sum{a,ACTS, REVSHR(e,a,r) * pes(e,a,r)};
   4393    
   4394   !<
   4395       7-3. Sector-specific endowments
   4396       -------------------------------
   4397   >!
   4398   Variable (all,e,ENDWF)(all,a,ACTS)(all,r,REG)
   4399       qesf(e,a,r) # supply of fixed (natural resource) endowment e in a in r #;
   4400    
   4401   Equation E_qes3
   4402   # equation to assist use of TABmate's automatic closure tool #
   4403   (all,e,ENDWF)(all,a,ACTS)(all,r,REG)
   4404       qes(e,a,r) = qesf(e,a,r);
   4405   !<
   4406       For convenience, variable qesf and equation E_qesf are added to assist use
   4407      of TABmate's automatic closure tool
   4408   >!
   4409    
   4410   !<
   4411       7-4. Price of endowments
   4412       ------------------------
   4413   >!
   4414   Variable (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   4415       tfe(e,a,r) # tax on primary factor e used by act. a in region r #;
   4416    
   4417   Equation E_pfe
   4418   # links basic and firm demand prices for mobile endowments #
   4419   (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   4420       pfe(e,a,r) = peb(e,a,r) + tfe(e,a,r);
   4421    
   4422   Equation E_pes
   4423   # links supply (pre-) and basic (post-tax) endowment prices #
   4424   (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   4425       peb(e,a,r) = pes(e,a,r) + tinc(e,a,r);
   4426    
   4427   Equation E_peb !< This equation assures market clearing for all endowments >!
   4428   # market clearing for endowments in each r #
   4429   (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   4430       qfe(e,a,r) = qes(e,a,r);
   4431    
   4432   !<
   4433       8. Allocation of global saving
   4434       -------------------------------
   4435   >!
   4436    
   4437   !<
   4438       8-1. Investment preliminaries
   4439       -----------------------------
   4440   >!
   4441   Variable (all,r,REG)
   4442       ke(r) # end-of-period capital stock in r #;
   4443   Coefficient (ge 0)(all,r,REG)
   4444       VKB(r) # value of beginning-of-period capital stock in region r #;
   4445   Read
   4446       VKB from file GTAPDATA header "VKB";
   4447   Update (all,r,REG)
   4448       VKB(r) = pinv(r) * kb(r);
   4449   !<
   4450       VKB(r) is used only in this sub-module, so its data are read here.  The
   4451       associated variables, pinv(r) and kb(r), are used across modules, so they
   4452       have been defined as common variables.
   4453   >!
   4454    
   4455   Coefficient (all,r,REG)
   4456       INVKERATIO(r)
   4457       # ratio of gross investment to end-of-period capital stock in r #;
   4458   Formula (all,r,REG)
   4459       INVKERATIO(r) = REGINV(r) / [VKB(r) + NETINV(r)];
   4460    
   4461   Equation E_ke
   4462   # ending capital stock equals beginning stock plus net investment #
   4463   (all,r,REG)
   4464       ke(r) = INVKERATIO(r) * qinv(r) + [1.0 - INVKERATIO(r)] * kb(r);
   4465    
   4466   Coefficient (all,r,REG)
   4467       GROSSCAP(r) # gross return to capital #;
   4468   Formula (all,r,REG)
   4469       GROSSCAP(r) = sum{e,ENDWC, VES(e,r)};
   4470    
   4471   Coefficient (all,r,REG)
   4472       GRNETRATIO(r) # ratio of GROSS/NET rates of return on capital in r #;
   4473   Formula (all,r,REG)
   4474       GRNETRATIO(r) = GROSSCAP(r) / [GROSSCAP(r) - VDEP(r)];
   4475   !<
   4476       NOTE: [GROSSCAP(r) - VDEP(r)] is net returns to capital.
   4477   >!
   4478    
   4479   Variable (all,r,REG)
   4480       rore(r) # expected net rate of return on capital stock in r #;
   4481   Variable (all,r,REG)
   4482       rorc(r) # current net rate of return on capital stock in r #;
   4483   Variable (all,r,REG)
   4484       rental(r) # rental rate on capital = ps("capital",r) #;
   4485    
   4486   Equation E_rental
   4487   # defines a variable for capital rental rate #
   4488   (all,r,REG)
   4489       rental(r) = sum{e,ENDWC, [VES(e,r) / GROSSCAP(r)] * pe(e,r)};
   4490    
   4491   Equation E_rorc
   4492   # current rate of return on capital in region r #
   4493   (all,r,REG)
   4494       rorc(r) = GRNETRATIO(r) * [rental(r) - pinv(r)];
   4495    
   4496   Equation E_kb
   4497   # associates change in cap. services w/ change in cap. stock #
   4498   (all,r,REG)
   4499       kb(r) = sum{e,ENDWC, [VES(e,r) / GROSSCAP(r)] * qe(e,r)};
   4500   !<
   4501       E_kb equation associates any change in capital services during the period
   4502       with a change in capital stock.  Full capacity utilization is assumed.
   4503   >!
   4504    
   4505   !<
   4506       8-2. Rate-of-return sensitive investment allocation
   4507       ---------------------------------------------------
   4508   >!
   4509    
   4510   Coefficient (parameter)(all,r,REG)
   4511       RORFLEX(r)
   4512       # flexibility of expected net ROR on capital stock in r wrt investment #;
   4513   Read
   4514       RORFLEX from file GTAPPARM header "RFLX";
   4515   !<
   4516       RORFLEX is the flexibility of the expected net rate of return on the
   4517       capital stock, in region r, with respect to investment.  If a region's
   4518       capital stock increases by 1%, then it is expected that the net rate of
   4519       return on capital will decline by RORFLEX %.  A larger absolute value for
   4520       this parameter will reduce the tendency of international investment flows
   4521       to respond to changes in expected rates of return.
   4522   >!
   4523    
   4524   Equation E_rore
   4525   # expected rate of return depends on the current return and investment #
   4526   (all,r,REG)
   4527       rore(r) = rorc(r) - RORFLEX(r) * [ke(r) - kb(r)];
   4528    
   4529   Coefficient (integer,parameter)
   4530       RORDELTA
   4531       # binary coefficient to switch mechanism of allocating investment funds #;
   4532   Read
   4533       RORDELTA from file GTAPPARM header "RDLT";
   4534   !<
   4535       RORDELTA is a binary coefficient which determines the mechanism of
   4536       allocating investment funds across regions.  When RORDELTA = 1, investment
   4537       funds are allocated across regions to equate the change in the expected
   4538       rates of return (i.e., rore(r)).  When RORDELTA = 0, investment funds are
   4539       allocated across regions to maintain the existing composition of capital
   4540       stocks.
   4541   >!
   4542    
   4543   Variable
   4544       rorg # global net rate of return on capital stock #;
   4545   Variable (all,r,REG)
   4546       cgdslack(r) # slack variable for qinv(r) #;
   4547   !<
   4548       cgdslack is exogenous, unless the user wishes to exogenously fix the level
   4549       of gross investment in a region, in which case it can be swapped with
   4550       cgdslack.
   4551   >!
   4552    
   4553   Equation E_qinv
   4554   # either gross investment or expected rate of return in region r #
   4555   (all,r,REG)
   4556       RORDELTA * rore(r)
   4557       + [1 - RORDELTA]
   4558       * [[REGINV(r) / NETINV(r)] * qinv(r) - [VDEP(r) / NETINV(r)] * kb(r)]
   4559           = RORDELTA * rorg + [1 - RORDELTA] * globalcgds + cgdslack(r);
   4560   !<
   4561       This equation determines either gross investment or the expected rate of
   4562       return in each region, depending on the setting for the binary RORDELTA
   4563       parameter.
   4564   >!
   4565    
   4566   Variable (all,e,ENDWC)(all,r,REG)
   4567       expand(e,r) # change in investment relative to endowment stock #;
   4568   Equation E_expand
   4569   # change in investment relative to endowment stock #
   4570   (all,e,ENDWC)(all,r,REG)
   4571       expand(e,r) = qinv(r) - qe(e,r);
   4572   !<
   4573       Capital Accumulation
   4574       (based on the theory laid out in GTAP Technical Paper #7)
   4575   >!
   4576    
   4577   !<
   4578       8-3. Investment allocation based on initial capital shares
   4579       ----------------------------------------------------------
   4580   >!
   4581    
   4582   Equation E_globalcgds
   4583   # either expected global rate of return or global net investment #
   4584       RORDELTA * globalcgds + [1 - RORDELTA] * rorg
   4585           = RORDELTA
   4586           * sum{r,REG,
   4587               [REGINV(r) / GLOBINV] * qinv(r) - [VDEP(r) / GLOBINV] * kb(r)}
   4588           + [1 - RORDELTA] * sum{r,REG, [NETINV(r) / GLOBINV] * rore(r)};
   4589   !<
   4590       E_globalcgds equation computes either the change in global net investment
   4591       (when RORDELTA = 1), or the change in the expected global rate of return on
   4592       capital (when RORDELTA = 0).
   4593   >!
   4594    
   4595   !<
   4596       8-4. Price of saving
   4597       ---------------------
   4598   >!
   4599    
   4600   Variable (all,r,REG)
   4601       psaveslack(r) # slack variable for the saving price equation #;
   4602   !<
   4603       psaveslack is exogenous under the normal closure.  However, in order to
   4604       replicate simulations from the GTAP book, where there was a single saving
   4605       price, psaveslack may be swapped with psave in order to fix the latter.
   4606       In this case, pcgdswld must be the numeraire so that each region faces the
   4607       same price of saving.
   4608   >!
   4609    
   4610   Equation E_psave
   4611   # price of saving #
   4612   (all,r,REG)
   4613       psave(r)
   4614           = pinv(r)
   4615           + sum{s,REG, [[NETINV(s) - SAVE(s)] / GLOBINV] * pinv(s)}
   4616           + psaveslack(r);
   4617   !<
   4618       In contrast to the GTAP book, the price of saving is now region-specific
   4619       and it changes at the same rate as the price of regional investment, plus
   4620       an adjustment factor which accounts for the fact that saving and
   4621       investment are not equal at the regional level.
   4622   >!
   4623    
   4624   Equation E_pcgdswld
   4625   # price index for the aggregate global cgds composite #
   4626       pcgdswld = sum{r,REG, [NETINV(r) / GLOBINV] * pinv(r)};
   4627    
   4628    
   4629   !<
   4630       8-5. International Emissions Trade
   4631       ----------------------------------
   4632   >!
   4633    
   4634    
   4635   Variable (all,r,REG)
   4636       pemp(r) # power of emissions purchases#;
   4637   Equation E_gco2q
   4638   # power of emissions purchases #
   4639   (all,r,REG)
   4640       pemp(r) = gco2t(r) - gco2q(r);
   4641    
   4642   Equation E_del_dvco2tra
   4643   # net emissions trading revenue #
   4644   (all,r,REG)
   4645       del_dvco2tra(r)
   4646           = CO2Q(r) * NCTAXLEV(r) * 0.01 * gco2q(r)
   4647           - CO2T(r) * NCTAXLEV(r) * 0.01 * gco2t(r)
   4648           + [CO2Q(r) - CO2T(r)] * del_nctaxb(REGTOBLOC(r));
   4649    
   4650   Variable (all,b,BLOC)
   4651       gco2tb(b) # carbon dioxide emissions #;
   4652   Variable (all,b,BLOC)
   4653       gco2qb(b) # emissions quota#;
   4654    
   4655   Equation E_gco2tb
   4656   # CO2 emissions #
   4657   (all,b,BLOC)
   4658       CO2TB(b) * gco2tb(b) = sum{r,REG: REGTOBLOC(r) = b, CO2T(r) * gco2t(r)};
   4659    
   4660   Coefficient (all,b,BLOC)
   4661       CO2QB(b) # emissions quota (millions of tonnes of CO2)#;
   4662   Formula (all,b,BLOC)
   4663       CO2QB(b) = sum{r, REG: REGTOBLOC(r)=b, CO2Q(r)};
   4664    
   4665   Equation E_gco2qb
   4666   # emissions quota #
   4667   (all,b,BLOC)
   4668       CO2QB(b) * gco2qb(b) = sum{r, REG: REGTOBLOC(r) = b, CO2Q(r) * gco2q(r)};
   4669    
   4670   Variable (all,b,BLOC)
   4671       pempb(b) # power of emissions purchases#;
   4672   Equation E_pempb
   4673   # power of emissions purchases#
   4674   (all,b,BLOC)
   4675       pempb(b) = gco2tb(b) - gco2qb(b);
   4676    
   4677   !<
   4678       9. Tax revenue streams
   4679       ----------------------
   4680   >!
   4681    
   4682   !<
   4683       9-1. Tax revenues generated in production
   4684       -----------------------------------------
   4685   >!
   4686    
   4687   !<
   4688       The following variables could be dropped when converting to levels
   4689       equation for income.  They are only needed for the linearized equation.
   4690       The idea here is to look at the ratio of taxes to income in order to
   4691       preserve homogeneity in prices.  (We could also look at changes in tax
   4692       revenue, but then a uniform price increase would change this variable.)
   4693       Obviously a simple percentage change variable doesn't work, since many
   4694       taxes are initially zero.  The basic logic of this approach is as follows:
   4695    
   4696       Let R be the ratio of taxes to income: R = T/Y, then:
   4697           dR = d(T/Y) = R(t - y)/100
   4698       multiply through by Y to get:
   4699           YdR = dT - Ty/100
   4700       This ratio change is computed for each tax type and for total taxes.  Then
   4701       the change in tax revenue itself may be computed as:
   4702           dT = YdR + Ty/100
   4703       in order to determine regional income.
   4704   >!
   4705    
   4706   Variable (change) (all,r,REG)
   4707       del_taxrout(r) # change in ratio of output tax to INCOME #;
   4708   Variable (change) (all,r,REG)
   4709       del_taxrfu(r) # change in ratio of tax on primary factor usage to INCOME #;
   4710   Variable (change) (all,r,REG)
   4711       del_taxriu(r) # change in ratio of tax on intermediate usage to INCOME #;
   4712   Variable (change) (all,r,REG)
   4713       del_taxrpc(r) # change in ratio of private consumption tax to INCOME #;
   4714   Variable (change) (all,r,REG)
   4715       del_taxrgc(r) # change in ratio of government consumption tax to INCOME #;
   4716   Variable (change) (all,r,REG)
   4717       del_taxric(r) # change in ratio of investment consumption tax to INCOME #;
   4718   Variable (change) (all,r,REG)
   4719       del_taxrexp(r) # change in ratio of export tax to INCOME #;
   4720   Variable (change) (all,r,REG)
   4721       del_taxrimp(r) # change in ratio of import tax to INCOME #;
   4722   Variable (change) (all,r,REG)
   4723       del_taxrinc(r) # change in ratio of income tax to INCOME #;
   4724   Variable (change)(all,r,REG)
   4725       del_ctaxr(r) # change in ratio of carbon tax to INCOME #;
   4726    
   4727   Equation E_del_taxrout
   4728   # change in ratio of output tax payments to regional income #
   4729   (all,r,REG)
   4730       100.0 * INCOME(r) * del_taxrout(r) + TAXROUT(r) * y(r)
   4731           = sum{c,COMM, sum{a,ACTS,
   4732              MAKEB(c,a,r) * to(c,a,r) + PTAX(c,a,r) * [ps(c,a,r) + qca(c,a,r)]}};
   4733    
   4734   Equation E_del_taxrfu
   4735   # change in ratio of tax payments on factor usage to regional income #
   4736   (all,r,REG)
   4737       100.0 * INCOME(r) * del_taxrfu(r) + TAXRFU(r) * y(r)
   4738           = sum{e,ENDW, sum{a,ACTS,
   4739              VFP(e,a,r) * tfe(e,a,r) + ETAX(e,a,r) * [peb(e,a,r) + qfe(e,a,r)]}};
   4740    
   4741   Equation E_del_taxriu
   4742   # change in ratio of tax payments on intermediate goods to regional income #
   4743   (all,r,REG)
   4744       100.0 * INCOME(r) * del_taxriu(r) + TAXRIU(r) * y(r)
   4745           = sum{c,COMM, sum{a,ACTS,
   4746               VDFPNC(c,a,r) * tfd(c,a,r) + DFTAX(c,a,r) * [pds(c,r) + qfd(c,a,r)]}}
   4747           + sum{c,COMM, sum{a,ACTS,
   4748               VMFPNC(c,a,r) * tfm(c,a,r) + MFTAX(c,a,r) * [pms(c,r) + qfm(c,a,r)]}};
   4749    
   4750   !<
   4751       9-2. Tax revenues generated in domestic final demand
   4752       ----------------------------------------------------
   4753   >!
   4754    
   4755   Equation E_del_taxrpc
   4756   # change in ratio of private consumption tax payments to regional income #
   4757   (all,r,REG)
   4758       100.0 * INCOME(r) * del_taxrpc(r) + TAXRPC(r) * y(r)
   4759           = sum{c,COMM,
   4760               VDPPNC(c,r) * tpd(c,r) + DPTAX(c,r) * [pds(c,r) + qpd(c,r)]}
   4761           + sum{c,COMM,
   4762               VMPPNC(c,r) * tpm(c,r) + MPTAX(c,r) * [pms(c,r) + qpm(c,r)]};
   4763    
   4764   Equation E_del_taxrgc
   4765   # change in ratio of government consumption tax payments to regional income #
   4766   (all,r,REG)
   4767       100.0 * INCOME(r) * del_taxrgc(r) + TAXRGC(r) * y(r)
   4768           = sum{c,COMM,
   4769               VDGPNC(c,r) * tgd(c,r) + DGTAX(c,r) * [pds(c,r) + qgd(c,r)]}
   4770           + sum{c,COMM,
   4771               VMGPNC(c,r) * tgm(c,r) + MGTAX(c,r) * [pms(c,r) + qgm(c,r)]};
   4772    
   4773   Equation E_del_taxric
   4774   # change in ratio of investment tax payments to regional income #
   4775   (all,r,REG)
   4776       100.0 * INCOME(r) * del_taxric(r) + TAXRIC(r) * y(r)
   4777           = sum{c,COMM,
   4778               VDIPNC(c,r) * tid(c,r) + DITAX(c,r) * [pds(c,r) + qid(c,r)]}
   4779           + sum{c,COMM,
   4780               VMIPNC(c,r) * tim(c,r) + MITAX(c,r) * [pms(c,r) + qim(c,r)]};
   4781    
   4782   !<
   4783       9-3. Tax revenues generated in international trade
   4784       --------------------------------------------------
   4785   >!
   4786    
   4787   Equation E_del_taxrexp
   4788   # change in ratio of export tax payments to regional income #
   4789   (all,s,REG)
   4790       100.0 * INCOME(s) * del_taxrexp(s) + TAXREXP(s) * y(s)
   4791           = sum{c,COMM, sum{d,REG, VFOB(c,s,d) * [tx(c,s) + txs(c,s,d)]
   4792           + XTAXD(c,s,d) * [pds(c,s) + qxs(c,s,d)]}};
   4793    
   4794   Equation E_del_taxrimp
   4795   # change in ratio of import tax payments to regional income #
   4796   (all,d,REG)
   4797       100.0 * INCOME(d) * del_taxrimp(d) + TAXRIMP(d) * y(d)
   4798           = sum{c,COMM, sum{s,REG,
   4799               VMSB(c,s,d) * [tm(c,d) + tms(c,s,d)]
   4800               + MTAX(c,s,d) * [pcif(c,s,d) + qxs(c,s,d)]}};
   4801    
   4802   !<
   4803       9-4. Income taxes and other tax identities
   4804       ------------------------------------------
   4805   >!
   4806    
   4807   Coefficient (all,r,REG)
   4808       TAXRINC(r) # income tax payments in r #;
   4809   Formula (all,r,REG)
   4810       TAXRINC(r) = sum{e,ENDW, sum{a,ACTS, INCTAX(e,a,r)}};
   4811    
   4812   Equation E_del_taxrinc
   4813   # change in ratio of income tax payments to regional income #
   4814   (all,r,REG)
   4815       100.0 * INCOME(r) * del_taxrinc(r) + TAXRINC(r) * y(r)
   4816           = sum{e,ENDW, sum{a,ACTS, EVFB(e,a,r) * [tinc(e,a,r)]
   4817           + INCTAX(e,a,r) * [pes(e,a,r) + qfe(e,a,r)]}};
   4818    
   4819   Equation E_del_indtaxr
   4820   # change in ratio of indirect taxes to INCOME in r #
   4821   (all,r,REG)
   4822       del_indtaxr(r)
   4823           = del_taxrout(r) + del_taxrfu(r)
   4824           + del_taxriu(r) + del_taxrpc(r) + del_taxrgc(r) + del_taxric(r)
   4825           + del_taxrimp(r) + del_taxrexp(r);
   4826    
   4827   Variable (change)(all,r,REG)
   4828       del_ttaxr(r) # change in ratio of taxes to INCOME in r #;
   4829   Equation E_del_ttaxr
   4830   # change in ratio of taxes to INCOME in r #
   4831   (all,r,REG)
   4832       del_ttaxr(r)
   4833           = del_indtaxr(r) + del_taxrinc(r) + del_ctaxr(r);
   4834   !<
   4835      The del_ttaxr variable can be swapped with the commodity- and source-generic
   4836      consumption tax shift, tp(r), in order to generate a tax replacement
   4837      scenario, whereby taxes remain a constant share of national income.
   4838   >!
   4839    
   4840   !<
   4841       9-5. Carbon tax
   4842       ---------------
   4843   >!
   4844    
   4845   Variable (all,r,REG)(all,i,CTAX)
   4846       gco2(r,i) # carbon dioxide emissions #;
   4847    
   4848   Equation E_gco2pd
   4849   # carbon dioxide emissions from private consumption of domestic product #
   4850   (all,c,COMM)(all,r,REG)
   4851       gco2pd(c,r) = qpd(c,r);
   4852    
   4853   Equation E_gco2pm
   4854   # carbon dioxide emissions from private consumption of imported product #
   4855   (all,c,COMM)(all,r,REG)
   4856       gco2pm(c,r) = qpm(c,r);
   4857    
   4858   Equation E_gco2gd
   4859   # carbon dioxide emissions from government consumption of domestic product #
   4860   (all,c,COMM)(all,r,REG)
   4861       gco2gd(c,r) = qgd(c,r);
   4862    
   4863   Equation E_gco2gm
   4864   # carbon dioxide emissions from government consumption of imported product #
   4865   (all,c,COMM)(all,r,REG)
   4866       gco2gm(c,r) = qgm(c,r);
   4867    
   4868   Equation E_gco2id
   4869   # carbon dioxide emissions from investment consumption of domestic product #
   4870   (all,c,COMM)(all,r,REG)
   4871       gco2id(c,r) = qid(c,r);
   4872    
   4873   Equation E_gco2im
   4874   # carbon dioxide emissions from investment consumption of imported product #
   4875   (all,c,COMM)(all,r,REG)
   4876       gco2im(c,r) = qim(c,r);
   4877    
   4878   Equation E_gco2fd
   4879   # carbon dioxide emissions from firms' usage of domestic product #
   4880   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4881       gco2fd(c,a,r) = qfd(c,a,r);
   4882    
   4883   Equation E_gco2fm
   4884   # carbon dioxide emissions from firms' usage of imported product #
   4885   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   4886       gco2fm(c,a,r) = qfm(c,a,r);
   4887    
   4888   Equation E_gco2
   4889   # carbon dioxide emissions #
   4890   (all,r,REG)(all,c,CTAX)
   4891       CO2(r,c) * gco2(r,c) = sum{a,ACTS, CO2MF(c,a,r) * gco2fm(c,a,r)
   4892                                  + CO2DF(c,a,r) * gco2fd(c,a,r)}
   4893                            + CO2DG(c,r) * gco2gd(c,r) + CO2MG(c,r) * gco2gm(c,r)
   4894                            + CO2DP(c,r) * gco2pd(c,r) + CO2MP(c,r) * gco2pm(c,r)
   4895                            + CO2DI(c,r) * gco2id(c,r) + CO2MI(c,r) * gco2im(c,r);
   4896    
   4897   Equation E_gco2t
   4898   # carbon dioxide emissions #
   4899   (all,r,REG)
   4900       CO2T(r) * gco2t(r) = sum{c,CTAX, CO2(r,c) * gco2(r,c)};
   4901    
   4902   Variable
   4903       gco2tw # total world emissions #;
   4904   Equation E_gco2tw
   4905   # total world emissions #
   4906       sum{r,REG, CO2T(r)} * gco2tw = sum{r,REG, CO2T(r) * gco2t(r)};
   4907    
   4908   !<
   4909       9-6. Carbon Tax Rate
   4910       --------------------
   4911    
   4912       RCTAXB and NCTAXB represent changes in real and nominal carbon tax
   4913       rates.  The real rate is defined as the nominal rate deflated by the income
   4914       deflator.
   4915   >!
   4916    
   4917   Variable (change)(all,r,REG)
   4918       del_rctax(r) # real carbon tax rate (USD per tonne of CO2) #;
   4919   Coefficient (all,r,REG)
   4920       PIND(r) # income deflator #;
   4921   Update (all,r,REG)
   4922       PIND(r) = p(r);
   4923   Formula (initial) (all,r,REG)
   4924       PIND(r) = 1.0;
   4925   Equation E_del_rctax
   4926   # real carbon tax rate #
   4927   (all,r,REG)
   4928       del_rctax(r) = [1.0 / PIND(r)]
   4929           * [del_nctaxb(REGTOBLOC(r)) - 0.01 * NCTAXLEV(r) * p(r)];
   4930    
   4931   Variable (orig_level = 1.0)(all,b,BLOC)
   4932       pyb(b) # income deflator for bloc #;
   4933   Coefficient (all,b,BLOC)
   4934       INCOMEB(b) # Net income in bloc #;
   4935   Formula (all,b,BLOC)
   4936       INCOMEB(b) = sum{r,REG: REGTOBLOC(r) = b, INCOME(r)};
   4937   Equation E_pyb # income deflator #
   4938   (all,b,BLOC)
   4939       INCOMEB(b) * pyb(b) = sum{r,REG: REGTOBLOC(r) = b, INCOME(r) * p(r)};
   4940    
   4941   Variable (change)(all,r,BLOC)
   4942       del_rctaxb(r) # real carbon tax rate (1997 USD per tonne of CO2) #;
   4943   Coefficient (all,b,BLOC)
   4944       PINDB(b) # income deflator #;
   4945   Update (all,b,BLOC)
   4946       PINDB(b) = pyb(b);
   4947   Formula (initial) (all,b,BLOC)
   4948       PINDB(b) = 1.0;
   4949   Coefficient (all,b,BLOC)
   4950       NCTAXLEVB(b) # nominal carbon tax rate (current USD per tonne of CO2) #;
   4951   Formula (all,b,BLOC)
   4952       NCTAXLEVB(b) = sum{r,REG: REGTOBLOC(r) = b, NCTAXLEV(r) * CO2T(r)}
   4953                    / CO2TB(b);
   4954   Equation E_del_nctaxb
   4955   # real carbon tax rate #
   4956   (all,b,BLOC)
   4957       del_rctaxb(b) = [1.0 / PINDB(b)]
   4958                     * [del_nctaxb(b) - 0.01 * NCTAXLEVB(b) * pyb(b)];
   4959    
   4960   Variable (change) (all,r,REG)
   4961       del_ctgshr(r) # government share of carbon tax payments/permits revenue #;
   4962   Coefficient (all,r,REG)
   4963       CTGSHARE(r) # government share of carbon tax payments/permits revenue #;
   4964   Update (change) (all,r,REG)
   4965       CTGSHARE(r) = del_ctgshr(r);
   4966   Read
   4967       CTGSHARE from file GTAPDATA header "GSHR";
   4968    
   4969   Equation E_del_ctaxr
   4970   # change in ratio of carbon tax payments/permit rent to regional income #
   4971   (all,r,REG)
   4972       100.0 * INCOME(r) * del_ctaxr(r)
   4973           + CTGSHARE(r) * NCTAXLEV(r) * CO2Q(r) * y(r)
   4974           = 100.0 * NCTAXLEV(r) * CO2Q(r) * del_ctgshr(r)
   4975               + 100.0 * CTGSHARE(r) * CO2Q(r) * del_nctaxb(REGTOBLOC(r))
   4976               + CTGSHARE(r) * NCTAXLEV(r) * CO2Q(r) * gco2q(r);
   4977    
   4978   !<
   4979       10. Numeraire and closure
   4980       -------------------------
   4981   >!
   4982    
   4983   Variable (orig_level=1.0)(all,r,REG)
   4984       pfactor(r) # price index (at basic prices) of primary factors, by region #;
   4985   Coefficient (all,r,REG)
   4986       VENDWREG(r) # value of primary factors, at basic prices, by region #;
   4987   Formula (all,r,REG)
   4988       VENDWREG(r) = sum{e,ENDW, sum{a,ACTS, EVFB(e,a,r)}};
   4989    
   4990   Equation E_pfactor
   4991   # computes % change in price index of primary factors, by region #
   4992   (all,r,REG)
   4993       VENDWREG(r) * pfactor(r)
   4994           = sum{e,ENDW, sum{a,ACTS, EVFB(e,a,r) * peb(e,a,r)}};
   4995    
   4996   Variable (orig_level=1.0)
   4997       pfactwld # world price index of primary factors #;
   4998   Coefficient
   4999       VENDWWLD # value of primary factors, at basic prices, worldwide #;
   5000   Formula
   5001       VENDWWLD = sum{r,REG, VENDWREG(r)};
   5002    
   5003   Equation E_rorg
   5004   # computes % change in global price index of primary factors #
   5005       VENDWWLD * pfactwld = sum{r,REG, VENDWREG(r) * pfactor(r)};
   5006   !<  This equation derives the price index of primary factors. Note that this is
   5007       the only instance where an equation name breaks the GTAP model's naming
   5008       convention (i.e., equation name does directly not relate to variable being
   5009       derived). This is because PFACTWLD is exogenous as the model.s price
   5010       anchor (numeraire) and thus this equation .explains., RORG which has no
   5011       separate equation (which has been dropped due to Walras' law). Note as well
   5012       that the equation is separated into two. The first E_pfactor defines a
   5013       regional index for factor prices, and the second defines the global index.
   5014       By naming this equation E_rorg and because pfactwld is exogenous, we can
   5015       for convenience, use TABmate's automatic closure tool to list down all
   5016       exogenous and endogenous variable split (i.e., closure) that is consistent
   5017       with the standard GTAP closure. Using TABmate's automatic closure tool is
   5018       beneficial especially during model development or extension.
   5019   >!
   5020    
   5021   Variable
   5022       walras_sup # supply in omitted market--global supply of cgds composite #;
   5023   Variable
   5024       walras_dem # demand in the omitted market--global demand for saving #;
   5025   Variable
   5026       walraslack # slack variable in the omitted market #;
   5027    
   5028   Equation E_walras_sup
   5029   # extra equation: computes change in supply in the omitted market #
   5030       walras_sup = pcgdswld + globalcgds;
   5031   !<
   5032       This is an extra equation which simply computes change in supply in the
   5033       omitted market.  (modified from HT 12 to reflect the value as opposed to
   5034       quantity change, in light of the new treatment of psave(r))
   5035   >!
   5036    
   5037   Equation E_walras_dem
   5038   # extra equation: computes change in demand in the omitted market #
   5039       GLOBINV * walras_dem = sum{r,REG, SAVE(r) * [psave(r) + qsave(r)]};
   5040   !<
   5041       E_walras_dem is an extra equation which simply computes change in demand in
   5042       the omitted market.  (modified from HT 13 to reflect the value as opposed to
   5043       quantity change)
   5044   >!
   5045    
   5046   Equation E_walraslack
   5047   # Check Walras' Law.  Value of "walraslack" should be zero #
   5048       walras_sup = walras_dem +  walraslack;
   5049   !<
   5050       E_walraslack allows us to verify that Walras' Law holds. The value of
   5051       walraslack should be zero in any GE simulation. The variable walraslack is
   5052       endogenous under normal, GE closure.  If the GE links are broken, then
   5053       walraslack must be swapped with the numeraire, thereby forcing global
   5054       saving to explicitly equal global investment.
   5055   >!
   5056    
   5057   !<
   5058       ---------------------------------------------------
   5059       B. Summary Indices (for use in welfare measurement)
   5060       ---------------------------------------------------
   5061    
   5062       We first calculate a number of useful summary statistics, including
   5063       terms of trade variables/coefficients which are used in the
   5064       Welfare Measurement and Decomposition section (Section 11)
   5065    
   5066       The following equations do not generally affect the equilibrium structure
   5067       of the model, although they do include the equation for the usual numeraire
   5068       variable, "pfactwld".
   5069    
   5070       B-0. Variables and coefficients for summary indices
   5071       B-1. Factor price indices
   5072       B-2. Regional terms of trade (ToT)
   5073       B-3. GDP indices (value, price and quantity)
   5074       B-4. Aggregate trade indices (value, price and quantity)
   5075       B-5. Trade balance indices
   5076       B-6. Terms of trade (ToT) decomposition
   5077   >!
   5078    
   5079   !<
   5080       B-0. Appendix-specific variables and coefficients
   5081       -------------------------------------------------
   5082       only used in this summary indices appendix
   5083   >!
   5084    
   5085   Variable (all,c,COMM)(all,r,REG)
   5086       vxwfob(c,r) # value of merchandise regional exports, by commodity, FOB #;
   5087   Variable (all,c,COMM)(all,r,REG)
   5088       vmwcif(c,r) # value of merchandise regional imports, by commodity, CIF #;
   5089   Variable (all,r,REG)
   5090       vxwreg(r) # value of merchandise exports, by region #;
   5091   Variable (all,r,REG)
   5092       vmwreg(r) # value of merchandise imports, by region, at world prices #;
   5093    
   5094   Coefficient (all,c,COMM)(all,r,REG)
   5095       VXDFOB(c,r) # FOB value of com. c exports to all dest. (tradeables only) #;
   5096   Formula (all,c,COMM)(all,r,REG)
   5097       VXDFOB(c,r) = sum{d,REG, VFOB(c,r,d)};
   5098    
   5099   Coefficient (all,c,COMM)(all,r,REG)
   5100       VXW(c,r) # value of exports by commodity c and region r at FOB prices #;
   5101   Formula (all,c,COMM)(all,r,REG)
   5102       VXW(c,r) = VXDFOB(c,r) + IF[c in MARG, VST(c,r)];
   5103    
   5104   Coefficient (all,r,REG)
   5105       VXWREGION(r) # value of exports by region r at FOB prices #;
   5106   Formula (all,r,REG)
   5107       VXWREGION(r) = sum{c,COMM, VXW(c,r)};
   5108    
   5109   Coefficient (all,c,COMM)(all,d,REG)
   5110       VMCIF(c,d) # value of commodity imports c by DEST. d at CIF prices #;
   5111   Formula (all,c,COMM)(all,d,REG)
   5112       VMCIF(c,d) = sum{s,REG, VCIF(c,s,d)};
   5113    
   5114   Coefficient (all,r,REG)
   5115       VMWREGION(r) # value of commodity imports by region r at CIF prices #;
   5116   Formula (all,r,REG)
   5117       VMWREGION(r) = sum{c,COMM, VMCIF(c,r)};
   5118    
   5119   !<
   5120       B-1. Factor price indices
   5121       -------------------------
   5122   >!
   5123    
   5124   Variable (orig_level=1.0)(all,e,ENDW)(all,a,ACTS)(all,r,REG)
   5125       pfactreal(e,a,r) # ratio of return to primary factor e to CPI in r #;
   5126   Equation E_pfactreal
   5127   # defines the real rate of return to primary factor e in region r #
   5128   (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   5129       pfactreal(e,a,r) = pes(e,a,r) - ppriv(r);
   5130   !<
   5131       This equation defines the real rate of return to primary factor e in
   5132       region r (new).
   5133   >!
   5134    
   5135   Variable (orig_level=1.0)(all,e,ENDWMS)(all,r,REG)
   5136       pebfactreal(e,r)
   5137       # ratio of (tax-inclusive) return to mobile and sluggish factor e in r #;
   5138   Coefficient (all,e,ENDWMS)(all,r,REG)
   5139       VENDWMS(e,r) # value of mobile and sluggish e in r at basic prices #;
   5140   Coefficient (all,e,ENDWMS)(all,a,ACTS)(all,r,REG)
   5141       ENDWMSSHR(e,a,r) # share of mobile and sluggish e usage by act a in reg r #;
   5142   Zerodivide default RNREG;
   5143   Formula (all,e,ENDWMS)(all,r,REG)
   5144       VENDWMS(e,r) = sum{a,ACTS, EVFB(e,a,r)};
   5145   Formula (all,e,ENDWMS)(all,a,ACTS)(all,r,REG)
   5146       ENDWMSSHR(e,a,r) = EVFB(e,a,r) / VENDWMS(e,r);
   5147   Zerodivide off;
   5148    
   5149   Equation E_pebfactreal
   5150   # defines the real (tax-inclusive) return to mobile and sluggish factor e in r #
   5151   (all,e,ENDWMS)(all,r,REG)
   5152       pebfactreal(e,r) = sum{a, ACTS, ENDWMSSHR(e,a,r) *  peb(e,a,r)} - ppriv(r);
   5153    
   5154   Variable (orig_level=1.0)(all,e,ENDWMS)(all,r,REG)
   5155       pefactreal(e,r)
   5156       # ratio of (tax-exclusive) return to mobile and sluggish factor e in r #;
   5157   Equation E_pefactreal
   5158   # defines the real (tax-exclusive) return to mobile and sluggish factor e in r #
   5159   (all,e,ENDWMS)(all,r,REG)
   5160       pefactreal(e,r) = pe(e,r) - ppriv(r);
   5161    
   5162   !<
   5163       B-2. Regional terms of trade (ToT)
   5164       ----------------------------------
   5165    
   5166       The next three equations correspond to Table 10 of Hertel and Tsigas on
   5167       Regional Terms of Trade.
   5168   >!
   5169    
   5170   Variable (orig_level=1.0)(all,r,REG)
   5171       psw(r) # index of prices received for tradeables produced in region r #;
   5172   Equation E_psw
   5173   # estimate change in index of prices received for tradeables c produced in r #
   5174   (all,r,REG)
   5175       VXWREGION(r) * psw(r)
   5176           = sum{c,COMM, sum{d,REG, VFOB(c,r,d) * pfob(c,r,d)}}
   5177           + sum{m,MARG, VST(m,r) * pds(m,r)};
   5178   !<
   5179       This equation estimates the change in the index of prices received for
   5180       tradeable products produced in r.  (modified from HT 64 to eliminate the
   5181       investment component)
   5182   >!
   5183    
   5184   Variable (orig_level=1.0)(all,r,REG)
   5185       pdw(r) # index of prices paid for tradeables used in importing region r #;
   5186   Equation E_pdw
   5187   # estimate change in index of prices paid for tradeable products used in r #
   5188   (all,r,REG)
   5189       VMWREGION(r) * pdw(r)
   5190           = sum{c,COMM, sum{s,REG, VCIF(c,s,r) * pcif(c,s,r)}};
   5191   !<
   5192       This equation estimates the change in the index of prices paid for
   5193       tradeable products used in r.  (modified from HT 65 to eliminate saving)
   5194   >!
   5195    
   5196   Variable (orig_level=1.0)(all,r,REG)
   5197       tot(r) # terms of trade for region r: tot(r) = psw(r) - pdw(r) #;
   5198   Equation E_tot
   5199   # terms of trade equation computed as difference in psw and pdw #
   5200   (all,r,REG)
   5201       tot(r) = psw(r) - pdw(r);
   5202    
   5203   !<
   5204       B-3. GDP indices (value, price and quantity)
   5205       --------------------------------------------
   5206   >!
   5207    
   5208   ! GDP expenditure side summary !
   5209   Set
   5210       GDPEX (Household,Investment,Government,Exports,IntnlMargins,Imports);
   5211   Coefficient (all,r,REG)(all,g,GDPEX)
   5212       GDPEXP(r,g) # GDP expenditure side summary #;
   5213   Formula
   5214   (all,r,REG) GDPEXP(r,"Household")    = sum{c,COMM, VPP(c,r)};
   5215   (all,r,REG) GDPEXP(r,"Investment")   = sum{c,COMM, VIP(c,r)};
   5216   (all,r,REG) GDPEXP(r,"Government")   = sum{c,COMM, VGP(c,r)};
   5217   (all,s,REG) GDPEXP(s,"Exports")      = sum{c,COMM, sum{d,REG, VFOB(c,s,d)}};
   5218   (all,r,REG) GDPEXP(r,"IntnlMargins") = sum{m,MARG, VST(m,r)};
   5219   (all,d,REG) GDPEXP(d,"Imports")      = - sum{c,COMM, sum{s,REG, VCIF(c,s,d)}};
   5220   Write
   5221       GDPEXP to file GTAPSUM header "GDPE";
   5222    
   5223   Variable (orig_level=GDP)(all,r,REG)
   5224       vgdp(r) # change in value of GDP #;
   5225   Coefficient (all,r,REG)
   5226       GDP(r) # gross domestic product in region r #;
   5227   Formula (all,r,REG)
   5228       GDP(r) = sum{g,GDPEX, GDPEXP(r,g)};
   5229   !<
   5230       Gross Domestic Product in region r. Trade is valued at FOB and CIF prices.
   5231   >!
   5232    
   5233   Equation E_vgdp
   5234   # change in value of GDP #
   5235   (all,r,REG)
   5236       GDP(r) * vgdp(r)
   5237           = sum{c,COMM, VGP(c,r) * [qga(c,r) + pga(c,r)]}
   5238           + sum{c,COMM, VPP(c,r) * [qpa(c,r) + ppa(c,r)]}
   5239           + sum{c,COMM, VIP(c,r) * [qinv(r) + pinv(r)]}
   5240           + sum{c,COMM, sum{d,REG, VFOB(c,r,d) * [qxs(c,r,d) + pfob(c,r,d)]}}
   5241           + sum{m,MARG, VST(m,r) * [qst(m,r) + pds(m,r)]}
   5242           - sum{c,COMM, sum{s,REG, VCIF(c,s,r) * [qxs(c,s,r) + pcif(c,s,r)]}};
   5243    
   5244   Variable (orig_level=1.0)(all,r,REG)
   5245       pgdp(r) # GDP price index #;
   5246   Variable (orig_level=GDP)(all,r,REG)
   5247       qgdp(r) # GDP (expenditure-side) quantity index #;
   5248    
   5249   Equation E_pgdp
   5250   # GDP price index #
   5251   (all,r,REG)
   5252       GDP(r) * pgdp(r)
   5253           = sum{c,COMM, VGP(c,r) * pga(c,r)}
   5254           + sum{c,COMM, VPP(c,r) * ppa(c,r)}
   5255           + sum{c,COMM, VIP(c,r) * pia(c,r)}
   5256           + sum{c,COMM, sum{d,REG, VFOB(c,r,d) * pfob(c,r,d)}}
   5257           + sum{m,MARG, VST(m,r) * pds(m,r)}
   5258           - sum{c,COMM, sum{s,REG, VCIF(c,s,r) * pcif(c,s,r)}};
   5259    
   5260   Equation E_qgdp
   5261   # GDP quantity index #
   5262   (all,r,REG)
   5263       GDP(r) * qgdp(r)
   5264           = sum{c,COMM, VGP(c,r) * qga(c,r)}
   5265           + sum{c,COMM, VPP(c,r) * qpa(c,r)}
   5266           + sum{c,COMM, VIP(c,r) * qia(c,r)}
   5267           + sum{c,COMM, sum{d,REG, VFOB(c,r,d) * qxs(c,r,d)}}
   5268           + sum{m,MARG, VST(m,r) * qst(m,r)}
   5269           - sum{c,COMM, sum{s,REG, VCIF(c,s,r) * qxs(c,s,r)}};
   5270    
   5271   !<
   5272       modified from HT 72 for use with AnalyseGE
   5273   >!
   5274   Variable (all,a,ACTS)(all,r,REG)
   5275       compvalad(a,r) # composition of value added for good c and region r #;
   5276    
   5277   Equation E_compvalad
   5278   # track change in composition of value added #
   5279   (all,a,ACTS)(all,r,REG)
   5280       compvalad(a,r) = qo(a,r) - qgdp(r);
   5281    
   5282   !<
   5283       B-4. Aggregate trade indices (value, price and quantity)
   5284       --------------------------------------------------------
   5285   >!
   5286    
   5287   !<
   5288       Common variables and coefficients
   5289       Value indices for aggregate trade
   5290       Price indices for aggregate trade
   5291       Quantity indices for aggregate trade
   5292   >!
   5293    
   5294   !<
   5295       Common variables and coefficients
   5296       .................................
   5297    
   5298       only used in this aggregate trade indices section
   5299   >!
   5300   Zerodivide default RNREG;
   5301   Variable (orig_level=1.0)(all,c,COMM)(all,r,REG)
   5302       pxw(c,r) # aggregate exports price index of c from region r #;
   5303   Coefficient (all,c,COMM)
   5304       VXWCOMMOD(c) # value of world exports by commodity c at FOB prices #;
   5305   Formula (all,c,COMM)
   5306       VXWCOMMOD(c) = sum{r,REG, VXW(c,r)};
   5307   Coefficient
   5308       VXWLD # value of commodity exports, FOB, globally #;
   5309   Formula
   5310       VXWLD = sum{r,REG, VXWREGION(r)};
   5311    
   5312   Coefficient (all,c,COMM)
   5313       VMWCOMMOD(c) # global value of commodity imports, CIF, by commodity #;
   5314   Formula (all,c,COMM)
   5315       VMWCOMMOD(c) = sum{r,REG, VMCIF(c,r)};
   5316    
   5317   Coefficient (all,c,COMM)(all,r,REG)
   5318       VXDXSB(c,r) # basic value of com. c exports to all dest. (tradeables only) #;
   5319   Formula (all,c,COMM)(all,r,REG)
   5320       VXDXSB(c,r) = sum{d,REG, VXSB(c,r,d)};
   5321    
   5322   Coefficient (all,c,COMM)(all,r,REG)
   5323       PW_PM(c,r) # ratio of world to domestic prices #;
   5324   Formula (all,c,COMM)(all,r,REG)
   5325       PW_PM(c,r) = VXDFOB(c,r) / VXDXSB(c,r);
   5326    
   5327   Coefficient (all,c,COMM)(all,r,REG)
   5328       VOW(c,r) # value of commodity output in r at FOB incl transp. services #;
   5329   Formula (all,c,COMM)(all,r,REG)
   5330       VOW(c,r) = VDB(c,r) * PW_PM(c,r) + VXDFOB(c,r) + IF[c in MARG, + VST(c,r)];
   5331    
   5332   Coefficient (all,c,COMM)
   5333       VWOW(c) # value of world supply at world prices for c #;
   5334   Formula (all,c,COMM)
   5335       VWOW(c) = sum{r,REG, VOW(c,r)};
   5336    
   5337   Coefficient (all,c,COMM)
   5338       VWOU(c) # value of world output of c at user prices #;
   5339   Formula (all,c,COMM)
   5340       VWOU(c) = sum{r,REG, VPP(c,r) + VGP(c,r) + VIP(c,r)
   5341                     + sum{a,ACTS, VFP(c,a,r)}};
   5342   Zerodivide off;
   5343    
   5344   !<
   5345       Value indices for aggregate trade
   5346       .................................
   5347   >!
   5348    
   5349   Equation E_vxwfob
   5350   # the change in FOB value of exports of m from r #
   5351   (all,c,COMM)(all,r,REG)
   5352       ID01[VXW(c,r)] * vxwfob(c,r)
   5353           = sum{d,REG, VFOB(c,r,d) * [qxs(c,r,d) + pfob(c,r,d)]}
   5354           + IF[c in MARG, VST(c,r) * [qst(c,r) + pds(c,r)]];
   5355    
   5356   Equation E_vxwreg
   5357   # computes % change in value of merchandise exports, by region #
   5358   (all,r,REG)
   5359       VXWREGION(r) * vxwreg(r) = sum{c,COMM, VXW(c,r) * vxwfob(c,r)};
   5360    
   5361   Variable (all,c,COMM)
   5362       vxwcom(c) # value of global merchandise exports by commodity #;
   5363   Equation E_vxwcom
   5364   # computes % change in FOB value of global exports, by commodity #
   5365   (all,c,COMM)
   5366       VXWCOMMOD(c) * vxwcom(c) = sum{r,REG, VXW(c,r) * vxwfob(c,r)};
   5367    
   5368   Variable
   5369       vxwwld # value of world trade #;
   5370   Equation E_vxwwld
   5371   # computes % change in value of global exports #
   5372       VXWLD * vxwwld = sum{r,REG, VXWREGION(r) * vxwreg(r)};
   5373    
   5374   Equation E_vmwcif
   5375   # the change in CIF value of imports of commodity c into r #
   5376   (all,c,COMM)(all,d,REG)
   5377       VMCIF(c,d) * vmwcif(c,d)
   5378           = sum{s,REG, VCIF(c,s,d) * [pcif(c,s,d) + qxs(c,s,d)]};
   5379    
   5380   Equation E_vmwreg
   5381   # computes % change in value of imports, CIF basis, by region #
   5382   (all,r,REG)
   5383       VMWREGION(r) * vmwreg(r) = sum{c,COMM, VMCIF(c,r) * vmwcif(c,r)};
   5384    
   5385   Variable (all,c,COMM)
   5386       vmwcom(c) # value of global merchandise imports c, at world prices #;
   5387   Equation E_vmwcom
   5388   # computes % change in value of global imports, by commodity #
   5389   (all,c,COMM)
   5390       VMWCOMMOD(c) * vmwcom(c) = sum{r,REG, VMCIF(c,r) * vmwcif(c,r)};
   5391    
   5392   Variable (all,c,COMM)
   5393       valuew(c) # value of world supply of good c #;
   5394   Equation E_valuew
   5395   # change in value of world output of comm. c at FOB prices #
   5396   (all,c,COMM)
   5397       VWOW(c) * valuew(c) = sum{r,REG, VOW(c,r) * [pxw(c,r) + qc(c,r)]};
   5398    
   5399   Variable (all,c,COMM)
   5400       valuewu(c) # value of world supply of good c at user prices #;
   5401   Equation E_valuewu
   5402   # change in value of world output of commodity c at user prices #
   5403   (all,c,COMM)
   5404       VWOU(c) * valuewu(c)
   5405           = sum{r,REG, VPP(c,r) * [ppa(c,r) + qpa(c,r)]
   5406           + VGP(c,r) * [pga(c,r) + qga(c,r)]
   5407           + VIP(c,r) * [pinv(r) + qia(c,r)]
   5408           + sum{a,ACTS, VFP(c,a,r) * [pfa(c,a,r) + qfa(c,a,r)]}};
   5409    
   5410   !<
   5411       Price indices for aggregate trade
   5412       .................................
   5413   >!
   5414    
   5415   Equation E_pxw
   5416   # change in FOB price index of exports of m from r #
   5417   (all,C,COMM)(all,r,REG)
   5418       ID01[VXW(c,r)] * pxw(c,r)
   5419           = sum{d,REG, VFOB(c,r,d) * pfob(c,r,d)}
   5420           + IF[c in MARG, VST(c,r) * pds(c,r)];
   5421    
   5422   Variable (orig_level=1.0)(all,r,REG)
   5423       pxwreg(r) # price index of merchandise exports, by region #;
   5424   Equation E_pxwreg
   5425   # computes % change in price index of exports, by region #
   5426   (all,r,REG)
   5427       VXWREGION(r) * pxwreg(r) = sum{c,COMM, VXW(c,r) * pxw(c,r)};
   5428    
   5429   Variable (orig_level=1.0)(all,c,COMM)
   5430       pxwcom(c) # price index of global merchandise exports by commodity #;
   5431   Equation E_pxwcom
   5432   # computes % change in price index of exports, by commodity #
   5433   (all,c,COMM)
   5434       VXWCOMMOD(c) * pxwcom(c) = sum{r,REG, VXW(c,r) * pxw(c,r)};
   5435    
   5436   Variable (orig_level=1.0)
   5437       pxwwld # price index of world trade #;
   5438   Equation E_pxwwld
   5439   # computes % change in price index of global exports #
   5440       VXWLD * pxwwld = sum{r,REG, VXWREGION(r) * pxwreg(r)};
   5441    
   5442   Variable (all,c,COMM)(all,r,REG)
   5443       pmw(c,r) # world price of composite import c in region r #;
   5444   Equation E_pmw
   5445   # computes % change in CIF price index of imports of c into d #
   5446   (all,c,COMM)(all,d,REG)
   5447       VMCIF(c,d) * pmw(c,d) = sum{s,REG, VCIF(c,s,d) * pcif(c,s,d)};
   5448    
   5449   Variable (orig_level=1.0)(all,r,REG)
   5450       pmwreg(r) # price index of merchandise imports, by region #;
   5451   Equation E_pmwreg
   5452   # computes % change in price index of imports, by region #
   5453   (all,r,REG)
   5454       VMWREGION(r) * pmwreg(r) = sum{c,COMM, VMCIF(c,r) * pmw(c,r)};
   5455    
   5456   Variable (orig_level=1.0)(all,c,COMM)
   5457       pmwcom(c) # price index of global merchandise imports by commodity #;
   5458   Equation E_pmwcom
   5459   # computes % change in price index of imports, by commodity #
   5460   (all,c,COMM)
   5461       VMWCOMMOD(c) * pmwcom(c) = sum{r,REG, VMCIF(c,r) * pmw(c,r)};
   5462    
   5463   Variable (all,c,COMM)
   5464       pw(c) # world price index for total good c supplies #;
   5465   Equation E_pw
   5466   # change in index of world prices, FOB, for total production of c #
   5467   (all,c,COMM)
   5468       VWOW(c) * pw(c) = sum{r,REG, VOW(c,r) * pxw(c,r)};
   5469    
   5470   Variable (orig_level=1.0)(all,c,COMM)
   5471       pwu(c) # world price index for total good c supplies at user prices #;
   5472   Equation E_pwu
   5473   # change in index of user prices for deflating world production of c #
   5474   (all,c,COMM)
   5475       VWOU(c) * pwu(c)
   5476           = sum{r,REG, VPP(c,r) * ppa(c,r)
   5477           + VGP(c,r) * pga(c,r)
   5478           + VIP(c,r) * pinv(r)
   5479           + sum{a,ACTS, VFP(c,a,r) * pfa(c,a,r)}};
   5480    
   5481   !<
   5482       Quantity indices for aggregate trade
   5483       ....................................
   5484   >!
   5485    
   5486   Variable (orig_level=VXW)(all,c,COMM)(all,r,REG)
   5487       qxw(c,r) # aggregate exports of c from region r, FOB weights #;
   5488   Equation E_qxw
   5489   # change in volume of exports of (margin and non-margin) commodity c from r #
   5490   (all,c,COMM)(all,r,REG)
   5491       ID01[VXW(c,r)] * qxw(c,r)
   5492           = sum{d,REG, VFOB(c,r,d) * qxs(c,r,d)}
   5493           + IF[c in MARG, VST(c,r) * qst(c,r)];
   5494   !<
   5495       modified from HT 89 for use with AnalyseGE
   5496   >!
   5497    
   5498   Variable (orig_level=VXWREGION)(all,r,REG)
   5499       qxwreg(r) # volume of merchandise exports, by region #;
   5500   Equation E_qxwreg
   5501   # computes % change in quantity index of exports, by region #
   5502   (all,r,REG)
   5503       VXWREGION(r) * qxwreg(r) = sum{c,COMM, VXW(c,r) * qxw(c,r)};
   5504   !<
   5505       modified from HT 91 for use with AnalyseGE
   5506   >!
   5507    
   5508   Variable (orig_level=VXWCOMMOD)(all,c,COMM)
   5509       qxwcom(c) # volume of global merchandise exports by commodity #;
   5510   Equation E_qxwcom
   5511   # computes % change in quantity index of exports, by commodity #
   5512   (all,c,COMM)
   5513       VXWCOMMOD(c) * qxwcom(c) = sum{r,REG, VXW(c,r) * qxw(c,r)};
   5514   !<
   5515       modified from HT 93 for use with AnalyseGE
   5516   >!
   5517    
   5518   Variable (orig_level=VXWLD)
   5519       qxwwld # volume of world trade #;
   5520   Equation E_qxwwld
   5521   # computes % change in quantity index of global exports #
   5522       VXWLD * qxwwld = sum{r,REG, VXWREGION(r) * qxwreg(r)};
   5523   !<
   5524       modified from HT 95 for use with AnalyseGE
   5525   >!
   5526    
   5527   Variable (all,c,COMM)(all,d,REG)
   5528       qmw(c,d) # aggregate imports of c into region s, CIF weights #;
   5529   Equation E_qmw
   5530   # change in volume of imports of commodity c into d #
   5531   (all,c,COMM)(all,d,REG)
   5532       VMCIF(c,d) * qmw(c,d) = sum{s,REG, VCIF(c,s,d) * qxs(c,s,d)};
   5533   !<
   5534       modified from HT 90 for use with AnalyseGE
   5535   >!
   5536    
   5537   Variable (orig_level=VMWREGION)(all,r,REG)
   5538       qmwreg(r) # volume of merchandise imports, by region #;
   5539   Equation E_qmwreg
   5540   # computes % change in quantity index of imports, by region #
   5541   (all,r,REG)
   5542       VMWREGION(r) * qmwreg(r) = sum{c,COMM, VMCIF(c,r) * qmw(c,r)};
   5543   !<
   5544       modified from HT 92 for use with AnalyseGE
   5545   >!
   5546    
   5547   Variable (orig_level=VMWCOMMOD)(all,c,COMM)
   5548       qmwcom(c) # volume of global merchandise imports by commodity #;
   5549   Equation E_qmwcom
   5550   # computes % change in quantity index of imports, by commodity #
   5551   (all,c,COMM)
   5552       VMWCOMMOD(c) * qmwcom(c) = sum{r,REG, VMCIF(c,r) * qmw(c,r)};
   5553   !<
   5554       modified from HT 94 for use with AnalyseGE
   5555   >!
   5556    
   5557   Variable (all,c,COMM)
   5558       qow(c) # quantity index for world supply of good c #;
   5559   Equation E_qow
   5560   # change in index of world production of c #
   5561   (all,c,COMM)
   5562       VWOW(c) * qow(c) = sum{r,REG, VOW(c,r) * qc(c,r)};
   5563   !<
   5564       modified from HT 96 for use with AnalyseGE
   5565   >!
   5566    
   5567   Variable (orig_level=VWOU)(all,c,COMM)
   5568       qowu(c) # quantity index for world supply of good c at user prices #;
   5569   Equation E_qowu
   5570   # change in index of world production of c evaluated at user prices #
   5571   (all,c,COMM)
   5572       VWOU(c) * qowu(c)
   5573           = sum{r,REG, VPP(c,r) * qpa(c,r)
   5574           + VGP(c,r) * qga(c,r)
   5575           + VIP(c,r) * qia(c,r)
   5576           + sum{a,ACTS, VFP(c,a,r) * qfa(c,a,r)}};
   5577    
   5578   !<
   5579       B-5. Trade balance indices
   5580       --------------------------
   5581   >!
   5582    
   5583   Variable (change)(all,c,COMM)(all,r,REG)
   5584       del_tbalc(c,r) # change in trade balance by c and by r, $ US million #;
   5585   !<
   5586       A positive value indicates that the change in exports exceeds the change
   5587       in imports.
   5588   >!
   5589   Equation E_del_tbalc
   5590   # computes change in trade balance by commodity and by region #
   5591   (all,c,COMM)(all,r,REG)
   5592       del_tbalc(c,r)
   5593           = [VXW(c,r) / 100] * vxwfob(c,r) - [VMCIF(c,r) / 100] * vmwcif(c,r);
   5594    
   5595   Variable (change)(all,r,REG)
   5596       del_tbal(r) # change in trade balance X - M, $ US million #;
   5597   Equation E_del_tbal
   5598   # computes change in trade balance (X - M), by region #
   5599   (all,r,REG)
   5600       del_tbal(r)
   5601           = [VXWREGION(r) / 100] * vxwreg(r) - [VMWREGION(r) / 100] * vmwreg(r);
   5602    
   5603   !<
   5604       In order to maintain homogeneity in the presence of a fixed trade balance,
   5605       it is useful to have a nominal variable which this is measured against.
   5606       The next equation provides this, and we recommend users fix del_tbalry
   5607       instead of fixing del_tbal in future simulations.  The strategy is the same
   5608       one used above for taxes.
   5609   >!
   5610    
   5611   !<
   5612       The balance on current account is equal to the sum of the ordinary trade
   5613       balance and net emissions trading revenue.
   5614   >!
   5615   Variable (change) (all,r,REG)
   5616       del_tbalctra(r) # balance on current account #;
   5617   Equation E_del_tbalctra
   5618   # balance on current account #
   5619   (all,r,REG)
   5620       del_tbalctra(r) = del_tbal(r) + del_dvco2tra(r);
   5621    
   5622   Coefficient (all,r,REG)
   5623       TBALCTRA(r) # balance on current account #;
   5624   Formula (all,r,REG)
   5625       TBALCTRA(r) = VXWREGION(r) - VMWREGION(r)
   5626                   + [CO2Q(r) - CO2T(r)] * NCTAXLEV(r);
   5627    
   5628   Variable (change)(all,r,REG)
   5629       del_balcar(r)
   5630       # change in ratio of current account balance to regional income #;
   5631   Equation E_del_balcar
   5632   # change in ratio of trade balance to regional income #
   5633   (all,r,REG)
   5634       100 * INCOME(r) * del_balcar(r) = 100 * del_tbalctra(r) - TBALCTRA(r) * y(r);
   5635    
   5636   Variable
   5637       ywld # world income #;
   5638   Coefficient
   5639       INCOMEWLD # World income #;
   5640   Formula
   5641       INCOMEWLD = sum{r,REG, INCOME(r)};
   5642    
   5643   Equation E_ywld
   5644   # world income #
   5645       INCOMEWLD * ywld = sum{r,REG, INCOME(r) * y(r)};
   5646    
   5647   Variable (change)(all,r,REG)
   5648       del_tbalry(r) # change in trade bal. of r as a percentage of world income #;
   5649   Coefficient (all,r,REG)
   5650       TBAL(r) # trade balance for region r #;
   5651   Formula (all,r,REG)
   5652       TBAL(r) = VXWREGION(r) - VMWREGION(r);
   5653    
   5654   Equation E_del_tbalry
   5655   # change in trade balance of region r as a percentage of world income #
   5656   (all,r,REG)
   5657       INCOMEWLD * 100 * del_tbalry(r)
   5658           = VXWREGION(r) * vxwreg(r) - VMWREGION(r) * vmwreg(r)
   5659           - TBAL(r) * ywld;
   5660    
   5661   !<
   5662       B-6. Terms of trade (ToT) decomposition
   5663       ---------------------------------------
   5664       Computations for decomposition the terms-of-trade effect
   5665       Reference: Robert McDougall, SALTER No. 12 Working Paper
   5666   >!
   5667    
   5668   Coefficient (all,c,COMM)(all,r,REG)
   5669       SX_CR(c,r) # share of good c in total exports from r #;
   5670   Formula (all,m,MARG)(all,r,REG)
   5671       SX_CR(m,r)
   5672           = [sum{d,REG, VFOB(m,r,d)} + VST(m,r)]
   5673           / [sum{c,COMM, sum{d,REG, VFOB(c,r,d)}}
   5674               + sum{k,MARG, VST(k,r)}];
   5675   Formula (all,n,NMRG)(all,r,REG)
   5676       SX_CR(n,r)
   5677           = sum{d,REG, VFOB(n,r,d)}
   5678           / [sum{c,COMM, sum{d,REG, VFOB(c,r,d)}}
   5679               + sum{m,MARG, VST(m,r)}];
   5680    
   5681   Coefficient (all,m,MARG)(all,d,REG)
   5682       VTMCOMM(m,d) # margin usage of m in getting imports to dest. region d #;
   5683   Formula (all,m,MARG)(all,d,REG)
   5684       VTMCOMM(m,d) = sum{c,COMM, sum{s,REG, VTMFSD(m,c,s,d)}};
   5685    
   5686   Coefficient (all,c,COMM)(all,d,REG)
   5687       VMWDCRALL(c,d) # imports of c into d, with direct allocation of margins #;
   5688   Formula (all,c,COMM)(all,d,REG)
   5689       VMWDCRALL(c,d) = sum{s,REG, VFOB(c,s,d)} + IF[c in MARG, VTMCOMM(c,d)];
   5690    
   5691   Coefficient (all,r,REG)
   5692       VMWDATOT(r) # total imports into r, calculated on direct allocation basis #;
   5693   Formula (all,r,REG)
   5694       VMWDATOT(r) = sum{c,COMM, VMWDCRALL(c,r)};
   5695    
   5696   Coefficient (all,c,COMM)(all,r,REG)
   5697       SM_CR(c,r)  # share of good c in total imports into r #;
   5698   Formula (all,c,COMM)(all,r,REG)
   5699       SM_CR(c,r) = VMWDCRALL(c,r) / VMWDATOT(r);
   5700    
   5701   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)
   5702       SM_CRS(c,s,d) # share of imports of good c into d from s at FOB prices #;
   5703   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   5704       SM_CRS(c,s,d) = VFOB(c,s,d) / VMWDCRALL(c,d);
   5705    
   5706   Coefficient (all,m,MARG)(all,d,REG)
   5707       SMT_CR(m,d) # share of transport cost in imports of margin m in region d #;
   5708   Formula (all,m,MARG)(all,d,REG)
   5709       SMT_CR(m,d) = VTMCOMM(m,d) / VMWDCRALL(m,d);
   5710    
   5711   Variable (all,c,COMM)(all,d,REG)
   5712       pm_cr(c,d) # imports price index for good c and importing region d #;
   5713   Equation E_pm_cr
   5714   # price index for total imports of m in d -- margins commodities #
   5715   (all,c,COMM)(all,d,REG)
   5716       pm_cr(c,d)
   5717           = sum{s,REG, SM_CRS(c,s,d) * pfob(c,s,d)}
   5718           + IF[c in MARG, SMT_CR(c,d) * pt(c)];
   5719    
   5720   Variable (all,c,COMM)(all,r,REG)
   5721       c1_cr(c,r) # contribution of world price, px_c, to ToT #;
   5722   Equation E_c1_cr
   5723   # contribution of world export price index of good c to ToT for region r #
   5724   (all,c,COMM)(all,r,REG)
   5725       c1_cr(c,r) = [SX_CR(c,r) - SM_CR(c,r)] * [pxwcom(c) - pxwwld];
   5726    
   5727   Variable (all,c,COMM)(all,r,REG)
   5728       c2_cr(c,r) # contribution of regional export price, px_cr, to ToT #;
   5729   Equation E_c2_cr
   5730   # contribution of regional export price of good c for region r #
   5731   (all,c,COMM)(all,r,REG)
   5732       c2_cr(c,r) = SX_CR(c,r) * [pxw(c,r) - pxwcom(c)];
   5733    
   5734   Variable (all,c,COMM)(all,r,REG)
   5735       c3_cr(c,r) # contribution of regional import price, pm_cr, to ToT #;
   5736   Equation E_c3_cr
   5737   # contribution of imports price index of good c for region r #
   5738   (all,c,COMM)(all,r,REG)
   5739       c3_cr(c,r) = SM_CR(c,r) * [pm_cr(c,r) - pxwcom(c)];
   5740    
   5741   Variable (all,r,REG)
   5742       c1_r(r) # contribution of world prices for all goods to ToT #;
   5743   Equation E_c1_r
   5744   # contribution of world price indexes of all goods to ToT for r #
   5745   (all,r,REG)
   5746       c1_r(r) = sum{c,COMM, c1_cr(c,r)};
   5747    
   5748   Variable (all,r,REG)
   5749       c2_r(r) # contribution of regional export prices to ToT #;
   5750   Equation E_c2_r
   5751   # contribution of regional exports prices to ToT for r #
   5752   (all,r,REG)
   5753       c2_r(r) = sum{c,COMM, c2_cr(c,r)};
   5754    
   5755   Variable (all,r,REG)
   5756       c3_r(r) # contribution of regional import prices to ToT #;
   5757   Equation E_c3_r
   5758   # contribution of regional import prices to ToT for r #
   5759   (all,r,REG)
   5760       c3_r(r) = sum{c,COMM, c3_cr(c,r)};
   5761    
   5762   Variable (all,r,REG)
   5763       tot2(r) # trade terms for region r, computed from components #;
   5764   Equation E_tot2
   5765   # trade terms for region r, computed from components #
   5766   (all,r,REG)
   5767       tot2(r) = c1_r(r) + c2_r(r) - c3_r(r);
   5768    
   5769   !<
   5770       --------------------------------------------
   5771       11. Measurement and decomposition of welfare
   5772       --------------------------------------------
   5773    
   5774       11-0. Variables and coefficients
   5775       11-1. Government consumption shadow demand system
   5776       11-2. Private consumption shadow demand dystem
   5777       11-3. Regional Household shadow demand system
   5778       11-4. Equivalent Variation
   5779       11-5. Decomposition of welfare [Section 3.11 in JGEA paper]
   5780    
   5781       This section calculates equivalent variation "EV" and world equivalent
   5782       variation, "WEV", by determining the income "yev" that would be required
   5783       to achieve the current actual utility level "u" in a shadow demand system
   5784       in which prices are fixed.
   5785    
   5786       Section 11-2 calculates the utility elasticity of private consumption
   5787       expenditure, "ueprivev", within a shadow demand system for private
   5788       consumption, for use in section 11-3. Section 11-3 calculates private
   5789       consumption expenditure "ypev" for use in 11-2, and regional income "yev"
   5790       for use in 11-4, within a shadow demand system for the regional household.
   5791       Section 11-4 calculates "EV" and "WEV".
   5792    
   5793       Section 11-5 provides a decomposition of welfare changes in the model as
   5794       explained in the GTAP model (JGEA) paper.
   5795   >!
   5796    
   5797   !<
   5798       11-0. Variables and coefficients
   5799       --------------------------------
   5800       only used in this Equivalent Variation section of the summary indices
   5801       appendix
   5802   >!
   5803    
   5804   Variable (all,r,REG)
   5805       uelasev(r) # elasticity of cost of utility wrt utility, for EV calc. #;
   5806   Variable (all,r,REG)
   5807       ueprivev(r) # utility elast. of private consn expenditure, for EV calc. #;
   5808   Variable (all,r,REG)
   5809       ugev(r) # per capita utility from gov't expend., for EV calc. #;
   5810   Variable (all,r,REG)
   5811       upev(r) # per capita utility from private expend., for EV calc. #;
   5812   Variable (all,r,REG)
   5813       qsaveev(r) # total quantity of saving demanded, for EV calc. #;
   5814   Variable (all,r,REG)
   5815       yev(r) # regional household income in region r, for EV calc. #;
   5816   Variable (all,r,REG)
   5817       ypev(r) # private consumption expenditure in region r, for EV calc. #;
   5818   Variable (all,r,REG)
   5819       ygev(r) # government consumption expenditure in region r, for EV calc. #;
   5820    
   5821   Coefficient (all,r,REG)
   5822       INCOMEEV(r) # regional income, for EV calc. #;
   5823   Formula (initial) (all,r,REG)
   5824       INCOMEEV(r) = INCOME(r);
   5825   Update (all,r,REG)
   5826       INCOMEEV(r) = yev(r);
   5827    
   5828   Coefficient (all,r,REG)
   5829       UTILPRIVEV(r) # utility from private consumption, for EV calcs #;
   5830   Formula (initial) (all,r,REG)
   5831       UTILPRIVEV(r) = UTILPRIV(r);
   5832   Update (all,r,REG)
   5833       UTILPRIVEV(r) = upev(r);
   5834    
   5835   Coefficient (all,r,REG)
   5836       UTILGOVEV(r) # utility from private consumption, for EV calcs #;
   5837   Formula (initial) (all,r,REG)
   5838       UTILGOVEV(r) = UTILGOV(r);
   5839   Update (all,r,REG)
   5840       UTILGOVEV(r) = ugev(r);
   5841    
   5842   Coefficient (all,r,REG)
   5843       UTILSAVEEV(r) # utility from private consumption, for EV calcs #;
   5844   Formula (initial) (all,r,REG)
   5845       UTILSAVEEV(r) = UTILSAVE(r);
   5846   Update (change) (all,r,REG)
   5847       UTILSAVEEV(r) = [[qsaveev(r) - pop(r)] / 100] * UTILSAVEEV(r);
   5848    
   5849   !<
   5850       11-1. Government consumption shadow demand system
   5851       -------------------------------------------------
   5852   >!
   5853    
   5854   Equation E_ugev
   5855   # utility from government consumption in r #
   5856   (all,r,REG)
   5857       ygev(r) - pop(r) = ugev(r);
   5858    
   5859   !<
   5860       11-2. Private consumption shadow demand system
   5861       ----------------------------------------------
   5862   >!
   5863    
   5864   Variable (all,c,TOPP)(all,r,REG)
   5865       qpev(c,r)
   5866       # private hhld demand for commodity c in region r, for EV calc. #;
   5867    
   5868   Coefficient (all,c,TOPP)(all,r,REG)
   5869       VPPEV(c,r)
   5870       # private hhld expend. on c in r valued at purch. prices, for EV calc. #;
   5871   Formula (initial) (all,c,TOPP)(all,r,REG)
   5872       VPPEV(c,r) = VPP(c,r);
   5873   Update (all,c,TOPP)(all,r,REG)
   5874       VPPEV(c,r) = qpev(c,r);
   5875    
   5876   Coefficient (all,r,REG)
   5877       VPPREGEV(r) # private consumption expenditure in region r, for EV calc. #;
   5878   Formula (all,r,REG)
   5879       VPPREGEV(r) = sum{c,TOPP, VPPEV(c,r)};
   5880   !<
   5881       VPPREGEV should agree with PRIVEXPEV.
   5882   >!
   5883    
   5884   Coefficient (all,c,TOPP)(all,r,REG)
   5885       CONSHREV(c,r)
   5886       # share of private hhld consn devoted to good c in r, for EV calc. #;
   5887   Formula (all,c,TOPP)(all,r,REG)
   5888       CONSHREV(c,r) = VPPEV(c,r) / VPPREGEV(r);
   5889   Coefficient (all,c,TOPP)(all,r,REG)
   5890       EYEV(c,r)
   5891       # expend. elast. of private hhld demand for c in r, for EV calc. #;
   5892   Formula (all,c,TOPP)(all,r,REG)
   5893       EYEV(c,r)
   5894           = [1.0 / sum{n,TOPP, CONSHREV(n,r) * INCPAR(n,r)}]
   5895           * [INCPAR(c,r) * [1.0 - ALPHA(c,r)]
   5896               + sum{n,TOPP, CONSHREV(n,r) * INCPAR(n,r) * ALPHA(n,r)}]
   5897           + ALPHA(c,r)
   5898           - sum{n,TOPP, CONSHREV(n,r) * ALPHA(n,r)};
   5899    
   5900   Equation E_qpev
   5901   # private hhld demands for composite commodities, for EV calc. #
   5902   (all,c,TOPP)(all,r,REG)
   5903       qpev(c,r) - pop(r) = EYEV(c,r) * [ypev(r) - pop(r)];
   5904   !<
   5905       Prices are held constant for the EV calculation and so do not appear here.
   5906   >!
   5907    
   5908   Coefficient (all,r,REG)
   5909       UELASPRIVEV(r)
   5910       # elast. of cost wrt utility from private consn, for EV calc. #;
   5911   Formula (all,r,REG)
   5912       UELASPRIVEV(r) = sum{c,TOPP, CONSHREV(c,r) * INCPAR(c,r)};
   5913    
   5914   Equation E_upev
   5915   # computation of utility from private consumption in r #
   5916   (all,r,REG)
   5917       ypev(r) - pop(r) = UELASPRIVEV(r) * upev(r);
   5918    
   5919   Coefficient (all,c,TOPP)(all,r,REG)
   5920       XWCONSHREV(c,r)
   5921       # expansion-parameter-weighted consumption share, for EV calc. #;
   5922   Formula (all,c,TOPP)(all,r,REG)
   5923       XWCONSHREV(c,r) = CONSHREV(c,r) * INCPAR(c,r) / UELASPRIVEV(r);
   5924    
   5925   Equation E_ueprivev
   5926       # elasticity of cost wrt utility from private consn, for EV calc. #
   5927       (all,r,REG)
   5928       ueprivev(r)
   5929           = sum{c,TOPP, XWCONSHREV(c,r) * [qpev(c,r) - ypev(r)]};
   5930   !<
   5931       Prices are held constant for the EV calculation and so do not appear here.
   5932   >!
   5933    
   5934   !<
   5935    
   5936       11-3. Regional Household shadow demand system
   5937       ---------------------------------------------
   5938   >!
   5939    
   5940   Variable (all,r,REG)
   5941       ysaveev(r) # NET saving expenditure, for EV calc. #;
   5942    
   5943   Coefficient (all,r,REG)
   5944       PRIVEXPEV(r)
   5945       # private consumption expenditure in region r, for EV calc. #;
   5946   Formula (initial) (all,r,REG)
   5947       PRIVEXPEV(r) = PRIVEXP(r);
   5948   Update (all,r,REG)
   5949       PRIVEXPEV(r) = ypev(r);
   5950   !<
   5951       PRIVEXPEV should agree with VPPREGEV.
   5952   >!
   5953    
   5954   Coefficient (all,r,REG)
   5955       GOVEXPEV(r)
   5956       # government consumption expenditure in region r, for EV calc. #;
   5957   Formula (initial) (all,r,REG)
   5958       GOVEXPEV(r) = GOVEXP(r);
   5959   Update (all,r,REG)
   5960       GOVEXPEV(r) = ygev(r);
   5961    
   5962   Coefficient (all,r,REG)
   5963       SAVEEV(r)
   5964       # saving in region r, for EV calc. #;
   5965   Formula (initial) (all,r,REG)
   5966       SAVEEV(r) = SAVE(r);
   5967   Update (all,r,REG)
   5968       SAVEEV(r) = ysaveev(r);
   5969    
   5970   Coefficient (all,r,REG)
   5971       XSHRPRIVEV(r)
   5972       # private expenditure share in regional income, for EV calc. #;
   5973   Formula (all,r,REG)
   5974       XSHRPRIVEV(r) = PRIVEXPEV(r) / INCOMEEV(r);
   5975    
   5976   Coefficient (all,r,REG)
   5977       XSHRGOVEV(r)
   5978       # government expenditure share in regional income, for EV calc. #;
   5979   Formula (all,r,REG)
   5980       XSHRGOVEV(r) = GOVEXPEV(r) / INCOMEEV(r);
   5981    
   5982   Coefficient (all,r,REG)
   5983       XSHRSAVEEV(r) # saving share in regional income, for EV calc. #;
   5984   Formula (all,r,REG)
   5985       XSHRSAVEEV(r) = SAVEEV(r) / INCOMEEV(r);
   5986    
   5987   Variable (all,r,REG)
   5988       dpavev(r) # average distribution parameter shift, for EV calc. #;
   5989   Equation E_dpavev
   5990   # average distribution parameter shift, for EV calc. #
   5991       (all,r,REG)
   5992       dpavev(r)
   5993           = XSHRPRIVEV(r) * dppriv(r)
   5994           + XSHRGOVEV(r) * dpgov(r)
   5995           + XSHRSAVEEV(r) * dpsave(r);
   5996    
   5997   Equation E_uelasev
   5998       # elasticity of cost of utility wrt utility, for EV calc. #
   5999       (all,r,REG)
   6000       uelasev(r) = XSHRPRIV(r) * ueprivev(r) - dpavev(r);
   6001    
   6002   Equation E_ypev
   6003   # private consumption expenditure, for EV calc. #
   6004       (all,r,REG)
   6005       ypev(r) - yev(r) = -[ueprivev(r) - uelasev(r)] + dppriv(r);
   6006    
   6007   Equation E_ygev
   6008   # government consumption expenditure #
   6009   (all,r,REG)
   6010       ygev(r) - yev(r) = uelasev(r) + dpgov(r);
   6011    
   6012   Equation E_ysaveev
   6013   # saving #
   6014   (all,r,REG)
   6015       ysaveev(r) - yev(r) = uelasev(r) + dpsave(r);
   6016    
   6017   Equation E_qsaveev
   6018   # saving #
   6019   (all,r,REG)
   6020       qsaveev(r) = ysaveev(r);
   6021   !<
   6022       Note that because psave doesn't change, qsaveev moves with ysaveev.
   6023   >!
   6024    
   6025   Coefficient (all,r,REG)
   6026       UTILELASEV(r)
   6027       # elasticity of cost of utility wrt utility, for EV calc. #;
   6028   Formula (initial) (all,r,REG)
   6029       UTILELASEV(r) = UTILELAS(r);
   6030   Update (all,r,REG)
   6031       UTILELASEV(r) = uelasev(r);
   6032    
   6033   Equation E_yev
   6034   # equivalent income #
   6035   (all,r,REG)
   6036       u(r)
   6037           = au(r)
   6038           + DPARPRIV(r) * loge(UTILPRIVEV(r)) * dppriv(r)
   6039           + DPARGOV(r) * loge(UTILGOVEV(r)) * dpgov(r)
   6040           + DPARSAVE(r) * loge(UTILSAVEEV(r)) * dpsave(r)
   6041           + [1.0 / UTILELASEV(r)] * [yev(r) - pop(r)];
   6042    
   6043   !<
   6044       11-4. Equivalent Variation
   6045       --------------------------
   6046   >!
   6047    
   6048   Variable (change)(all,r,REG)
   6049       EV(r) # equivalent variation, $ US million #;
   6050   Equation E_EV
   6051   # regional EV #
   6052   (all,r,REG)
   6053       EV(r) = [INCOMEEV(r) / 100] * yev(r);
   6054    
   6055   Variable (change)
   6056       WEV # equivalent variation for the world #;
   6057   Equation E_WEV
   6058   # EV for the world #
   6059       WEV = sum{r,REG, EV(r)};
   6060    
   6061   !<
   6062       11-5. Welfare decomposition
   6063       ---------------------------
   6064       See GTAP Technical Paper No. 5 for derivation and interpretation.
   6065       See also "The Standard GTAP Model (Version 7)" paper.
   6066   >!
   6067    
   6068   !<
   6069       Declare new sets for Welfare decomposition and for use in DECOMP.TAB.
   6070       Supplementary sets for "toggles" in VIEWHAR.
   6071   >!
   6072   Set
   6073       DIR(domestic,imported);
   6074   Set
   6075       ALLTAX(prodtax,pfacttax,inctax,inputtax,contax,invtax,govtax,xtax,mtax);
   6076   Set
   6077       TECHTYPE(output,primfac,v_added,ininput,invest,transp,import);
   6078   Set
   6079       COLUMN(co2trd,alloc_A1,ENDWB1,tech_C1,pop_D1,tot_E1,IS_F1,pref_G1);
   6080    
   6081   Coefficient (all,r,REG)
   6082       EVSCALFACT(r) # equivalent variation scaling factor #;
   6083   Formula (all,r,REG)
   6084       EVSCALFACT(r) = [UTILELASEV(r) / UTILELAS(r)] * [INCOMEEV(r) / INCOME(r)];
   6085    
   6086   Coefficient (all,m,MARG)(all,d,REG)
   6087       VTMD(m,d) # aggregate value of svce m in shipments to destination d #;
   6088   Formula (all,m,MARG)(all,d,REG)
   6089       VTMD(m,d) = sum{c,COMM, sum{s,REG, VTMFSD(m,c,s,d)}};
   6090    
   6091   Variable (linear,change)(all,r,REG)
   6092       EV_ALT(r) # regional EV computed in alternative way #;
   6093   Equation E_EV_ALT
   6094   # decomposition of Equivalent Variation #
   6095   (all,r,REG)
   6096       EV_ALT(r)
   6097           !< Preference shifts >!
   6098           = -[0.01 * UTILELASEV(r) * INCOMEEV(r)]
   6099           * [DPARPRIV(r) * loge(UTILPRIVEV(r) / UTILPRIV(r)) * dppriv(r)
   6100               + DPARGOV(r) * loge(UTILGOVEV(r) / UTILGOV(r)) * dpgov(r)
   6101               + DPARSAVE(r) * loge(UTILSAVEEV(r) / UTILSAVE(r)) * dpsave(r)]
   6102           !< Scaling factor >!
   6103           + [0.01 * EVSCALFACT(r)]
   6104           !< Changes in allocative efficiency >!
   6105           * [[100.0 * del_dvco2tra(r)]
   6106               + sum{c,COMM, sum{a,ACTS, PTAX(c,a,r) * [qca(c,a,r) - pop(r)]}}
   6107               + sum{e,ENDW, sum{a,ACTS,
   6108                   INCTAX(e,a,r) * [qes(e,a,r) - pop(r)]}}
   6109               + sum{e,ENDW, sum{a,ACTS,
   6110                   ETAX(e,a,r) * [qfe(e,a,r) - pop(r)]}}
   6111               + sum{c,COMM, sum{a,ACTS,
   6112                   [MFTAX(c,a,r) + MFCTAX(c,a,r)] * [qfm(c,a,r) - pop(r)]}}
   6113               + sum{c,COMM, sum{a,ACTS,
   6114                   [DFTAX(c,a,r) + DFCTAX(c,a,r)] * [qfd(c,a,r) - pop(r)]}}
   6115               + sum{c,COMM, [MPTAX(c,r) + MPCTAX(c,r)] * [qpm(c,r) - pop(r)]}
   6116               + sum{c,COMM, [DPTAX(c,r) + DPCTAX(c,r)] * [qpd(c,r) - pop(r)]}
   6117               + sum{c,COMM, [MGTAX(c,r) + MGCTAX(c,r)] * [qgm(c,r) - pop(r)]}
   6118               + sum{c,COMM, [DGTAX(c,r) + DGCTAX(c,r)] * [qgd(c,r) - pop(r)]}
   6119               + sum{c,COMM, [MITAX(c,r) + MICTAX(c,r)] * [qim(c,r) - pop(r)]}
   6120               + sum{c,COMM, [DITAX(c,r) + DICTAX(c,r)] * [qid(c,r) - pop(r)]}
   6121               + sum{c,COMM, sum{d,REG, XTAXD(c,r,d) * [qxs(c,r,d) - pop(r)]}}
   6122               + sum{c,COMM, sum{s,REG, MTAX(c,s,r) * [qxs(c,s,r) - pop(r)]}}
   6123           !< Changes in endowments >!
   6124           + sum{e,ENDW, sum{a,ACTS, EVOS(e,a,r) * [qes(e,a,r) - pop(r)]}}
   6125               !< Depreciation >!
   6126           - VDEP(r) * [kb(r) - pop(r)]
   6127           !< Changes in technology >!
   6128           + sum{a,ACTS, VOS(a,r) * ao(a,r)}
   6129               + sum{c,ALLF, sum{a,ACTS, VFP(c,a,r) * afa(c,a,r)}}
   6130               + sum{m,MARG, sum{c,COMM, sum{s,REG,
   6131                   VTMFSD(m,c,s,r) * atmfsd(m,c,s,r)}}}
   6132               + sum{c,COMM, sum{s,REG, VMSB(c,s,r) * ams(c,s,r)}}
   6133           !< Changes in terms of trade >!
   6134           + sum{c,COMM, sum{s,REG, VFOB(c,r,s) * pfob(c,r,s)}}
   6135               + sum{m,MARG, VST(m,r) * pds(m,r)}
   6136               + NETINV(r) * pinv(r)
   6137               - sum{c,COMM, sum{s,REG, VFOB(c,s,r) * pfob(c,s,r)}}
   6138               - sum{m,MARG, VTMD(m,r) * pt(m)}
   6139               - SAVE(r) * psave(r)]
   6140           !< Changes in population >!
   6141           + 0.01 * INCOMEEV(r) * pop(r);
   6142    
   6143   Variable (linear,change)
   6144       WEV_ALT # expression for WEV computed in alternative way #;
   6145   Equation E_WEV_ALT
   6146   # Equivalent Variation for the world #
   6147       WEV_ALT = sum{r,REG, EV_ALT(r)};
   6148    
   6149   !<
   6150       11-5.0 Carbon trading
   6151       ---------------------
   6152   >!
   6153   Variable (linear,change) (all,r,REG)
   6154       CNTco2trd(r) # contribution to regional EV of carbon trading #;
   6155   Equation E_CNTco2trd
   6156   (all,r,REG)
   6157       CNTco2trd(r) = EVSCALFACT(r)
   6158           * [del_dvco2tra(r) - 0.01 * [CO2Q(r) - CO2T(r)] * NCTAXLEV(r) * pxwwld];
   6159    
   6160   !<
   6161       11-5.1 Preference shifts (EV)
   6162       -----------------------------
   6163   >!
   6164    
   6165   Variable (linear,change) (all,r,REG)
   6166       CNTdpar(r) # contribution to EV of change in distribution parameters #;
   6167   Equation E_CNTdpar
   6168   # contribution to EV of change in distribution parameters #
   6169   (all,r,REG)
   6170       CNTdpar(r)
   6171           = -0.01 * UTILELASEV(r) * INCOMEEV(r)
   6172           * [DPARPRIV(r) * loge(UTILPRIVEV(r) / UTILPRIV(r)) * dppriv(r)
   6173               + DPARGOV(r) * loge(UTILGOVEV(r) / UTILGOV(r)) * dpgov(r)
   6174               + DPARSAVE(r) * loge(UTILSAVEEV(r) / UTILSAVE(r)) * dpsave(r)];
   6175    
   6176   !<
   6177       11-5.2 Allocative efficiency (EV)
   6178       ---------------------------------
   6179   >!
   6180    
   6181   !< Contribution to EV of changes in output >!
   6182    
   6183   Variable (linear,change) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6184       CNTqca(c,a,r)
   6185       # contribution to EV of changes in output c of act. a in region r #;
   6186   Equation E_CNTqca
   6187   # contribution to EV of changes in industry output of act. a in region r #
   6188   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6189       CNTqca(c,a,r) = [0.01 * EVSCALFACT(r)]
   6190                       * PTAX(c,a,r) * [qca(c,a,r) - pop(r)];
   6191    
   6192   Variable (linear,change) (all,a,ACTS)(all,r,REG)
   6193       CNTqo(a,r)
   6194       # contribution to EV of changes in industry output of act. a in region r #;
   6195   Equation E_CNTqo
   6196   # contribution to EV of changes in industry output of act. a in region r #
   6197   (all,a,ACTS)(all,r,REG)
   6198       CNTqo(a,r) = [0.01 * EVSCALFACT(r)]
   6199                    * sum{c,COMM, PTAX(c,a,r) * [qca(c,a,r) - pop(r)]};
   6200   Variable (linear,change) (all,r,REG)
   6201       CNTqor(r) # contribution to EV in region r of output changes #;
   6202   Equation E_CNTqor
   6203   # contribution to EV in region r of output changes #
   6204   (all,r,REG)
   6205       CNTqor(r) = sum{a,ACTS, CNTqo(a,r)};
   6206    
   6207    
   6208   !< Contribution to EV of changes in supply of endowment >!
   6209   Variable (linear,change) (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6210       CNTqea(e,a,r)
   6211       # contribution to EV of changes in supply of ENDW e to act. a in reg. r #;
   6212   Equation E_CNTqea
   6213   # contribution to EV of changes in supply of ENDW e in reg. r #
   6214   (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6215       CNTqea(e,a,r) = [0.01 * EVSCALFACT(r)]
   6216                     * INCTAX(e,a,r) * [qes(e,a,r) - pop(r)];
   6217    
   6218    
   6219   Variable (linear,change) (all,e,ENDW)(all,r,REG)
   6220       CNTqe(e,r)
   6221       # contribution to EV of changes in supply of ENDW e in reg. r #;
   6222   Equation E_CNTqe
   6223   # contribution to EV of changes in supply of ENDW e in reg. r #
   6224   (all,e,ENDW)(all,r,REG)
   6225       CNTqe(e,r) = sum{a,ACTS, CNTqea(e,a,r)};
   6226    
   6227   Variable (linear,change) (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6228       CNTqfe(e,a,r)
   6229       # contribution to EV of changes in use of ENDW e in a in r #;
   6230   Equation E_CNTqfe
   6231   # contribution to EV of changes in use of ENDW e in a in r #
   6232   (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6233       CNTqfe(e,a,r)
   6234           = [0.01 * EVSCALFACT(r)] * ETAX(e,a,r) * [qfe(e,a,r) - pop(r)];
   6235    
   6236   Variable (linear,change) (all,e,ENDW)(all,r,REG)
   6237       CNTqfeer(e,r)
   6238       # contribution to EV of changes in use of ENDW e in all firms in r #;
   6239   Equation E_CNTqfeer
   6240   # contribution to EV of changes in use of ENDW e in all firms in r #
   6241   (all,e,ENDW)(all,r,REG)
   6242       CNTqfeer(e,r)
   6243           = sum{a,ACTS, CNTqfe(e,a,r)};
   6244    
   6245   Variable (linear,change) (all,r,REG)
   6246       CNTqfer(r)
   6247       # contribution to EV of changes in use of all ENDW in r #;
   6248   Equation E_CNTqfer
   6249   # contribution to EV of changes in use of all ENDW in r #
   6250   (all,r,REG)
   6251       CNTqfer(r)
   6252           = sum{e,ENDW, sum{a,ACTS, CNTqfe(e,a,r)}};
   6253    
   6254   !< Contribution to EV of changes in commodity use by firms >!
   6255   Variable (linear,change) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6256       CNTqfm(c,a,r)
   6257       # cont. to EV of changes in use of imported intermediates by a in r #;
   6258   Equation E_CNTqfm
   6259   # cont. to EV of changes in use of imported intermediates in r #
   6260   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6261       CNTqfm(c,a,r)
   6262           = [0.01 * EVSCALFACT(r)]
   6263             * [MFTAX(c,a,r) + MFCTAX(c,a,r)] * [qfm(c,a,r) - pop(r)];
   6264    
   6265   Variable (linear,change) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6266       CNTqfd(c,a,r)
   6267       # cont. to EV of changes in use of domestic intermediates by a in r #;
   6268   Equation E_CNTqfd
   6269   # cont. to EV of changes in use of domestic intermediates by a in r #
   6270   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6271       CNTqfd(c,a,r)
   6272           = [0.01 * EVSCALFACT(r)]
   6273             * [DFTAX(c,a,r) + DFCTAX(c,a,r)] * [qfd(c,a,r) - pop(r)];
   6274    
   6275   Variable (linear,change) (all,r,REG)(all,d,DIR)
   6276       CNTqfr(r,d)
   6277       # cont. to EV of changes in use of dom. and imp. intermediates in r #;
   6278   Equation E_CNTqfr
   6279   # cont. to EV of changes in use of dom. and imp. intermediates in r #
   6280   (all,r,REG)(all,d,DIR)
   6281       CNTqfr(r,d)
   6282           = IF[d="domestic", sum{c,COMM, sum{a,ACTS, CNTqfd(c,a,r)}}]
   6283           + IF[d="imported", sum{c,COMM, sum{a,ACTS, CNTqfm(c,a,r)}}];
   6284    
   6285   !< Contribution to EV of changes in commodity use by private households >!
   6286   Variable (linear,change) (all,c,COMM)(all,r,REG)
   6287       CNTqpm(c,r)
   6288       # contribution to EV of changes in consumption of imported good c in r #;
   6289   Equation E_CNTqpm
   6290   # contribution to EV of changes in consumption of imported good c in r #
   6291   (all,c,COMM)(all,r,REG)
   6292       CNTqpm(c,r)
   6293           = [0.01 * EVSCALFACT(r)]
   6294             * [MPTAX(c,r) + MPCTAX(c,r)]* [qpm(c,r) - pop(r)];
   6295    
   6296   Variable (linear,change) (all,c,COMM)(all,r,REG)
   6297       CNTqpd(c,r)
   6298       # contribution to EV of changes in consumption of domestic good c in r #;
   6299   Equation E_CNTqpd
   6300   # contribution to EV of changes in consumption of domestic good c in r #
   6301   (all,c,COMM)(all,r,REG)
   6302       CNTqpd(c,r)
   6303           = [0.01 * EVSCALFACT(r)]
   6304             * [DPTAX(c,r) + DPCTAX(c,r)] * [qpd(c,r) - pop(r)];
   6305    
   6306   Variable (linear,change) (all,r,REG)(all,d,DIR)
   6307       CNTqpr(r,d)
   6308       # cont. to EV of changes in consumption of dom. and imp. goods in r #;
   6309   Equation E_CNTqpr
   6310   # cont. to EV of changes in consumption of dom. and imp. goods in r #
   6311   (all,r,REG)(all,d,DIR)
   6312       CNTqpr(r,d)
   6313           = IF[d="domestic", sum{c,COMM, CNTqpd(c,r)}]
   6314           + IF[d="imported", sum{c,COMM, CNTqpm(c,r)}];
   6315    
   6316   !< Contribution to EV of changes in commodity use by government >!
   6317   Variable (linear,change) (all,c,COMM)(all,r,REG)
   6318       CNTqgm(c,r)
   6319       # contribution to EV of changes in gov't consumption of import c in r #;
   6320   Equation E_CNTqgm
   6321   # contribution to EV of changes in gov't consumption of import c in r #
   6322   (all,c,COMM)(all,r,REG)
   6323       CNTqgm(c,r)
   6324       	=  [0.01 * EVSCALFACT(r)]
   6325              * [MGTAX(c,r) + MGCTAX(c,r)]* [qgm(c,r) - pop(r)];
   6326    
   6327   Variable (linear,change) (all,c,COMM)(all,r,REG)
   6328       CNTqgd(c,r)
   6329       # contribution to EV of changes in gov't consumption of domestic good c in r #;
   6330   Equation E_CNTqgd
   6331   # contribution to EV of changes in consumption of domestic good c in r #
   6332   (all,c,COMM)(all,r,REG)
   6333       CNTqgd(c,r)
   6334           = [0.01 * EVSCALFACT(r)]
   6335             * [DGTAX(c,r) + DGCTAX(c,r)] * [qgd(c,r) - pop(r)];
   6336    
   6337   Variable (linear,change) (all,r,REG)(all,d,DIR)
   6338       CNTqgr(r,d)
   6339       # cont. to EV of changes in gov't consumption of dom. and imp. goods in r #;
   6340   Equation E_CNTqgr
   6341   # cont. to EV of changes in consumption of dom. and imp. goods in r #
   6342   (all,r,REG)(all,d,DIR)
   6343       CNTqgr(r,d)
   6344           = IF[d="domestic", sum{c,COMM, CNTqgd(c,r)}]
   6345           + IF[d="imported", sum{c,COMM, CNTqgm(c,r)}];
   6346    
   6347   !< Contribution to EV of changes in commodity use for investment >!
   6348   Variable (linear,change) (all,c,COMM)(all,r,REG)
   6349       CNTqim(c,r)
   6350       # contribution to EV of changes in imported investment good c in r #;
   6351   Equation E_CNTqim
   6352   # contribution to EV of changes in imported investment good c in r #
   6353   (all,c,COMM)(all,r,REG)
   6354       CNTqim(c,r)
   6355       	=  [0.01 * EVSCALFACT(r)]
   6356              * [MITAX(c,r) + MICTAX(c,r)]* [qim(c,r) - pop(r)];
   6357    
   6358   Variable (linear,change) (all,c,COMM)(all,r,REG)
   6359       CNTqid(c,r)
   6360       # contribution. to EV of changes in domestic investment good c in r #;
   6361   Equation E_CNTqid
   6362   # contribution. to EV of changes in domestic investment good c in r #
   6363   (all,c,COMM)(all,r,REG)
   6364       CNTqid(c,r)
   6365       	=  [0.01 * EVSCALFACT(r)]
   6366              * [DITAX(c,r) + DICTAX(c,r)]* [qid(c,r) - pop(r)];
   6367    
   6368   Variable (linear,change) (all,r,REG)(all,d,DIR)
   6369       CNTqia(r,d)
   6370       # contribution to EV of changes in dom. and imp. investment goods in r #;
   6371   Equation E_CNTqia
   6372   # contribution to EV of changes in dom. and imp. investment goods in r #
   6373   (all,r,REG)(all,d,DIR)
   6374       CNTqia(r,d)
   6375           = IF[d="domestic", sum{c,COMM, CNTqid(c,r)}]
   6376           + IF[d="imported", sum{c,COMM, CNTqim(c,r)}];
   6377    
   6378   !< Contribution to EV of changes in commodity exports >!
   6379   Variable (linear,change) (all,c,COMM)(all,s,REG)(all,d,REG)
   6380       CNTqxs(c,s,d)
   6381       # contribution to EV of changes in exports of c from SRCE s to DEST d #;
   6382   Equation E_CNTqxs
   6383   # contribution to EV of changes in exports of c from SRCE s to DEST d #
   6384   (all,c,COMM)(all,s,REG)(all,d,REG)
   6385       CNTqxs(c,s,d) = [0.01 * EVSCALFACT(s)]
   6386                       * XTAXD(c,s,d) *  [qxs(c,s,d) - pop(s)];
   6387    
   6388   Variable (linear,change) (all,r,REG)
   6389       CNTqxsr(r)
   6390       # cont. to EV of changes in exports of all goods from SRCE r to all DEST #;
   6391   Equation E_CNTqxsr
   6392   # cont. to EV of changes in exports of all goods from SRCE s to all destination #
   6393   (all,s,REG)
   6394       CNTqxsr(s) = sum{c,COMM, sum{d,REG, CNTqxs(c,s,d)}};
   6395    
   6396   Variable (linear,change) (all,c,COMM)(all,s,REG)(all,d,REG)
   6397       CNTqms(c,s,d)
   6398       # contribution to EV of changes in imports of c from SRCE s to DEST d #;
   6399   Equation E_CNTqms
   6400   # contribution to EV of changes in imports of c from SRCE s to DEST d #
   6401   (all,c,COMM)(all,s,REG)(all,d,REG)
   6402       CNTqms(c,s,d) = [0.01 * EVSCALFACT(d)]
   6403                       * MTAX(c,s,d) * [qxs(c,s,d) - pop(d)];
   6404    
   6405   Variable (linear,change) (all,r,REG)
   6406       CNTqmsr(r)
   6407       # cont. to EV of changes in imports of all goods from all SRCE to DEST r #;
   6408   Equation E_CNTqmsr
   6409   # cont. to EV of changes in imports of all goods from all SRCE to DEST d #
   6410   (all,d,REG)
   6411       CNTqmsr(d) = sum{c,COMM, sum{s,REG, CNTqms(c,s,d)}};
   6412    
   6413   !<
   6414       11-5.3 Endowments (EV)
   6415       ----------------------
   6416   >!
   6417   Variable (linear,change) (all,r,REG)
   6418       CNTendwr(r) # contribution to regional EV of changes in all ENDW #;
   6419   Equation E_CNTendwr
   6420   # contribution to regional EV of changes in all ENDW (INcludes depreciation) #
   6421   (all,r,REG)
   6422       CNTendwr(r)
   6423           = [0.01 * EVSCALFACT(r)]
   6424           * [sum{e,ENDW, sum{a,ACTS, EVOS(e,a,r) * [qes(e,a,r) - pop(r)]}}
   6425               - VDEP(r) * [kb(r) - pop(r)]];
   6426    
   6427   Variable (linear,change) (all,e,ENDW)(all,r,REG)
   6428       CNTendw(e,r) # contribution to regional EV of changes in ENDW e in r #;
   6429   Equation E_CNTendw
   6430   # contribution to regional EV of changes in all ENDW (EXcludes depreciation) #
   6431   (all,e,ENDW)(all,r,REG)
   6432       CNTendw(e,r) = [0.01 * EVSCALFACT(r)] *
   6433                      sum{a,ACTS, [EVOS(e,a,r) * [qes(e,a,r) - pop(r)]]};
   6434    
   6435   !<
   6436       11-5.4 Technology (EV)
   6437       ----------------------
   6438   >!
   6439    
   6440   Variable (linear,change) (all,a,ACTS)(all,r,REG)
   6441       CNTtech_ao(a,r)
   6442       # cont. to regional EV of output augmenting tech change in a #;
   6443   Equation E_CNTtech_ao
   6444   # cont. to regional EV of output augmenting tech change in a #
   6445   (all,a,ACTS)(all,r,REG)
   6446       CNTtech_ao(a,r) = [0.01 * EVSCALFACT(r)] * VOS(a,r) * ao(a,r);
   6447    
   6448   Variable (linear,change) (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6449       CNTtech_afe(e,a,r)
   6450       # cont. to EV of primary factor e augmenting tech change in a #;
   6451   Equation E_CNTtech_afe
   6452   # cont. to EV of primary factor e augmenting tech change in a #
   6453   (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6454       CNTtech_afe(e,a,r) = [0.01 * EVSCALFACT(r)] * VFP(e,a,r) * afe(e,a,r);
   6455    
   6456   Variable (linear,change) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6457       CNTtech_af(c,a,r)
   6458       # cont. to EV of composite c input augmenting tech change in act. a #;
   6459   Equation E_CNTtech_af
   6460   # cont. to EV of composite c input augmenting tech change in act. a #
   6461   (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6462       CNTtech_af(c,a,r)
   6463           = [0.01 * EVSCALFACT(r)] * [VMFP(c,a,r) + VDFP(c,a,r)] * afa(c,a,r);
   6464    
   6465   Variable (linear,change)(all,m,MARG)(all,c,COMM)(all,s,REG)(all,d,REG)
   6466       CNTtech_atmfsd(m,c,s,d)
   6467       # cont. to EV of tech change in transportation efficiency #;
   6468   Equation E_CNTtech_atmfsd
   6469   # cont. to EV of tech change in transportation efficiency #
   6470   (all,m,MARG)(all,c,COMM)(all,s,REG)(all,d,REG)
   6471       CNTtech_atmfsd(m,c,s,d)
   6472           = [0.01 * EVSCALFACT(d)] * VTMFSD(m,c,s,d) * atmfsd(m,c,s,d);
   6473    
   6474   Variable (linear,change) (all,c,COMM)(all,s,REG)(all,d,REG)
   6475       CNTtech_ams(c,s,d)
   6476       # cont. to EV of bilateral import augmenting tech change for COMM c #;
   6477   Equation E_CNTtech_ams
   6478   # cont. to EV of bilateral import augmenting tech change for COMM c #
   6479   (all,c,COMM)(all,s,REG)(all,d,REG)
   6480       CNTtech_ams(c,s,d) = [0.01 * EVSCALFACT(s)] * VMSB(c,s,d) * ams(c,s,d);
   6481    
   6482   !<
   6483       11-5.5 Terms of Trade (EV)
   6484       --------------------------
   6485   >!
   6486   Variable (linear,change) (all,r,REG)
   6487       CNTtotr(r)
   6488       # contribution to regional EV of changes in its terms of trade #;
   6489   Equation E_CNTtotr
   6490   # contribution to regional EV of changes in its terms of trade #
   6491   (all,r,REG)
   6492       CNTtotr(r)
   6493           = [0.01 * EVSCALFACT(r)]
   6494           * [sum{c,COMM, sum{d,REG, VFOB(c,r,d) * [pfob(c,r,d) - pxwwld]}}
   6495               + sum{m,MARG, VST(m,r) * [pds(m,r) - pxwwld]}
   6496               - sum{c,COMM, sum{s,REG, VFOB(c,s,r) * [pfob(c,s,r) - pxwwld]}}
   6497               - sum{m,MARG, VTMD(m,r) * [pt(m) - pxwwld]}];
   6498    
   6499   Variable (linear,change) (all,r,REG)
   6500       CNTpinv(r) # contribution to regional EV of changes in investment price #;
   6501   Equation E_CNTpinv
   6502   # contribution to regional EV of changes in investment price index #
   6503   (all,r,REG)
   6504       CNTpinv(r)
   6505           = [0.01 * EVSCALFACT(r)]
   6506           * [NETINV(r) * [pinv(r) - pxwwld] - SAVE(r) * [psave(r) - pxwwld]];
   6507    
   6508   !<
   6509       11-5.6 Population (EV)
   6510       ----------------------
   6511   >!
   6512   Variable (linear,change) (all,r,REG)
   6513       CNTpop(r) # contribution to EV in region r of change in population #;
   6514   Equation E_CNTpop
   6515   # contribution to EV in region r of change in population #
   6516   (all,r,REG)
   6517       CNTpop(r) = 0.01 * INCOMEEV(r) * pop(r);
   6518   !<
   6519       11-5.7 Summary of contributions (EV)
   6520       ------------------------------------
   6521   >!
   6522   !< Allocative efficiency contributions >!
   6523   Variable (linear,change) (all,r,REG)(all,t,ALLTAX)
   6524       CNTalleffr(r,t) # total contribution to regional EV of allocative effects #;
   6525   Equation E_CNTalleffr
   6526   # total contribution to regional EV of allocative effects #
   6527   (all,r,REG)(all,t,ALLTAX)
   6528       CNTalleffr(r,t)
   6529           = IF[t="prodtax",  sum{c,COMM, sum{a,ACTS, CNTqca(c,a,r)}} ]
   6530           + IF[t="inctax",   sum{e,ENDW, sum{a,ACTS, CNTqea(e,a,r)}} ]
   6531           + IF[t="pfacttax", sum{e,ENDW, sum{a,ACTS, CNTqfe(e,a,r)}} ]
   6532           + IF[t="inputtax", sum{c,COMM, sum{a,ACTS, CNTqfd(c,a,r)
   6533                                                    + CNTqfm(c,a,r)}} ]
   6534           + IF[t="contax",   sum{c,COMM, CNTqpd(c,r) + CNTqpm(c,r)}  ]
   6535           + IF[t="govtax",   sum{c,COMM, CNTqgd(c,r) + CNTqgm(c,r)}  ]
   6536           + IF[t="invtax",   sum{c,COMM, CNTqid(c,r) + CNTqim(c,r)}  ]
   6537           + IF[t="xtax",     sum{c,COMM, sum{d,REG,  CNTqxs(c,r,d)}} ]
   6538           + IF[t="mtax",     sum{c,COMM, sum{s,REG,  CNTqms(c,s,r)}} ];
   6539    
   6540   Variable (linear,change) (all,c,COMM)(all,r,REG)
   6541       CNTalleffcr(c,r)
   6542       # total contribution to regional EV of allocative effects #;
   6543   Equation E_CNTalleffcr
   6544   # total contribution to regional EV of allocative effects #
   6545   (all,c,COMM)(all,r,REG)
   6546       CNTalleffcr(c,r)
   6547           = sum{a,ACTS, CNTqfd(c,a,r) + CNTqfm(c,a,r)}
   6548           + CNTqpd(c,r) + CNTqpm(c,r)
   6549           + CNTqgd(c,r) + CNTqgm(c,r)
   6550           + CNTqid(c,r) + CNTqim(c,r)
   6551           + sum{d,REG, CNTqxs(c,r,d)}
   6552           + sum{s,REG, CNTqms(c,s,r)};
   6553    
   6554    
   6555   Variable (linear,change) (all,r,REG)(all,t,TECHTYPE)
   6556       CNTtechr(t,r) # contribution to regional EV of all technical change #;
   6557   Equation E_CNTtechr
   6558   # contribution to regional EV of all technical change #
   6559   (all,t,TECHTYPE)(all,r,REG)
   6560       CNTtechr(t,r)
   6561           = IF[t="output",   sum{a,ACTS, CNTtech_ao(a,r)}]
   6562           + IF[t="ininput",  sum{c,COMM, sum{a,ACTS, CNTtech_af(c,a,r)}}]
   6563           + IF[t="primfac", sum{e,ENDW, sum{a,ACTS, CNTtech_afe(e,a,r)}}]
   6564           + IF[t="transp",  sum{m,MARG, sum{c,COMM, sum{s,REG,
   6565                                   CNTtech_atmfsd(m,c,s,r)}}}]
   6566           + IF[t="import",  sum{c,COMM, sum{s,REG, CNTtech_ams(c,s,r)}}];
   6567    
   6568   !< Contributions to EV of changes in capital stock and depreciation >!
   6569   Variable (linear,change) (all,r,REG)
   6570       CNTkb(r)
   6571       # cont. to EV of changes to beg. period capital stock and depreciation #;
   6572   Equation E_CNTkb
   6573   # cont. to EV of changes to beg. period capital stock and depreciation #
   6574   (all,r,REG)
   6575       CNTkb(r) = - [0.01 * EVSCALFACT(r)] * VDEP(r) * [kb(r) - pop(r)];
   6576    
   6577   !<
   6578       ===========================
   6579       END OF GTAP model equations
   6580       ===========================
   6581   >!
   6582    
   6583   !<
   6584       ================================================
   6585       Welfare summary and post-simulation calculations
   6586       ================================================
   6587   >!
   6588    
   6589   !<
   6590       --------------------------
   6591       C. Welfare summary modules
   6592       --------------------------
   6593       C-A:  EV decomposition: Summary
   6594       C-A1: Allocative efficiency effect: Commodity summary
   6595       C-A2: Allocative efficiency effect: Tax type summary
   6596       C-AX: Decomposition of allocative effect, by tax type and commodity
   6597       C-B1: Endowment effect: Gross of depreciation
   6598       C-B2: Endowment effect: Depreciation
   6599       C-C1: Technical change effect
   6600       C-D1: Population effect
   6601       C-E1: Terms of trade (ToT) effect
   6602       C-F1: I-S Effect: Explanatory factors
   6603   >!
   6604    
   6605   !<
   6606       Preliminaries: Assign initial values
   6607       ------------------------------------
   6608   >!
   6609    
   6610   Zerodivide default RNREG;
   6611    
   6612   Coefficient (parameter) (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6613       BEVFP(e,a,r) # producer expenditure on c by act. a #;
   6614   Formula (initial) (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6615       BEVFP(e,a,r) = EVFP(e,a,r);
   6616    
   6617   Coefficient (parameter) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6618       BVMFP(c,a,r) # purchases of imported c r for use in a in region r #;
   6619   Formula (initial) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6620       BVMFP(c,a,r) = VMFP(c,a,r);
   6621    
   6622   Coefficient (parameter) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6623       BVDFP(c,a,r) # purchases of domestic c r for use in a in region r #;
   6624   Formula (initial) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6625       BVDFP(c,a,r) = VDFP(c,a,r);
   6626    
   6627   Coefficient (parameter) (all,a,ACTS)(all,r,REG)
   6628       BVOS(a,r) # value of commodity c output in region r #;
   6629   Formula (initial)(all,a,ACTS)(all,r,REG)
   6630       BVOS(a,r)
   6631           = sum{e,ENDW, BEVFP(e,a,r)}
   6632           + sum{c,COMM, BVMFP(c,a,r) + BVDFP(c,a,r)};
   6633    
   6634   Coefficient (parameter) (all,c,COMM)(all,s,REG)(all,d,REG)
   6635       BVXSB(c,s,d)
   6636       # exports of c from r to s at basic prices (tradeables only) #;
   6637   Formula (initial) (all,c,COMM)(all,s,REG)(all,d,REG)
   6638       BVXSB(c,s,d) = VXSB(c,s,d);
   6639    
   6640   Coefficient (parameter)(all,c,COMM)(all,r,REG)
   6641       BVDPB(c,r) # private household expenditure on domestic c in r #;
   6642   Formula (initial) (all,c,COMM)(all,r,REG)
   6643       BVDPB(c,r) = VDPB(c,r);
   6644    
   6645   Coefficient (parameter) (all,c,COMM)(all,r,REG)
   6646       BVDGB(c,r) # government household expenditure on domestic c in r #;
   6647   Formula (initial) (all,c,COMM)(all,r,REG)
   6648       BVDGB(c,r) = VDGB(c,r);
   6649    
   6650   Coefficient (parameter) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6651       BVDFB(c,a,r) # purchases of domestic c for use in a in region r #;
   6652   Formula (initial) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6653       BVDFB(c,a,r) = VDFB(c,a,r);
   6654    
   6655   Coefficient (parameter) (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6656       BEVFB(e,a,r) # producer expenditure on c by a in r at basic prices #;
   6657   Formula (initial)  (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6658       BEVFB(e,a,r) = EVFB(e,a,r);
   6659    
   6660   Coefficient (parameter) (all,c,COMM)(all,r,REG)
   6661       BVDB(c,r) # domestic sales of c in r at basic prices (tradeables only) #;
   6662   Formula (initial) (all,c,COMM)(all,r,REG)
   6663       BVDB(c,r) =  VDB(c,r);
   6664    
   6665   Coefficient (parameter) (all,m,MARG)(all,r,REG)
   6666       BVST(m,r)
   6667       # exports of m from r for int'l transp. at basic prices (tradeables only) #;
   6668   Formula (initial) (all,m,MARG)(all,r,REG)
   6669       BVST(m,r) =  VST(m,r);
   6670    
   6671   Coefficient (parameter) (all,c,COMM)(all,r,REG)
   6672       BVCB(c,r) # value of commodity c output in region r at basic prices #;
   6673   Formula (initial) (all,c,COMM)(all,r,REG)
   6674       BVCB(c,r) = VCB(c,r);
   6675   Formula (initial) (all,c,COMM)(all,r,REG)
   6676       BVCB(c,r) = BVDB(c,r) + sum{d,REG, BVXSB(c,r,d)}
   6677                 + IF[c in MARG, BVST(c,r)];
   6678    
   6679   Coefficient (parameter) (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6680       BVEB(e,a,r) # value of endowment e in region r at basic prices #;
   6681   Formula (initial) (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6682       BVEB(e,a,r) = EVFB(e,a,r);
   6683    
   6684   Coefficient (parameter) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6685       BMAKEB(c,a,r) # value of total output of firm a at initial basic prices #;
   6686   Formula (initial) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6687       BMAKEB(c,a,r) = MAKEB(c,a,r);
   6688    
   6689   Coefficient (parameter) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6690       BOUTAX(c,a,r) # power of activity output tax, base #;
   6691   Formula (initial) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6692       BOUTAX(c,a,r) = [MAKEB(c,a,r) - MAKES(c,a,r)] / MAKES(c,a,r) * 100;
   6693    
   6694   Coefficient (parameter) (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6695       BEVOS(e,a,r) # initial endowment supply #;
   6696   Formula (initial) (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6697       BEVOS(e,a,r) = EVOS(e,a,r);
   6698    
   6699   Coefficient (parameter)(all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6700       BINCTAX(e,a,r) # initial income tax #;
   6701   Formula (initial) (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6702       BINCTAX(e,a,r) = [[BVEB(e,a,r) - BEVOS(e,a,r)] / BEVOS(e,a,r)] * 100;
   6703    
   6704   Coefficient (parameter) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6705       BVMFB(c,a,r) # purchases of imports c for use in act. a in region r #;
   6706   Formula (initial) (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6707       BVMFB(c,a,r) = VMFB(c,a,r);
   6708    
   6709   Coefficient (parameter) (all,c,COMM)(all,r,REG)
   6710       BVMPB(c,r) # private household expenditure on c in r #;
   6711   Formula (initial) (all,c,COMM)(all,r,REG)
   6712       BVMPB(c,r) = VMPB(c,r);
   6713    
   6714   Coefficient (parameter) (all,c,COMM)(all,r,REG)
   6715       BVMPP(c,r) # private household expenditure on imported c #;
   6716   Formula (initial) (all,c,COMM)(all,r,REG)
   6717       BVMPP(c,r) = VMPP(c,r);
   6718    
   6719   Coefficient (parameter) (all,c,COMM)(all,r,REG)
   6720       BVDPP(c,r) # private household expenditure on domestic c in r #;
   6721   Formula (initial) (all,c,COMM)(all,r,REG)
   6722       BVDPP(c,r) = VDPP(c,r);
   6723    
   6724   Coefficient (parameter) (all,c,COMM)(all,r,REG)
   6725       BVMGB(c,r) # gov't household expenditure on c in r #;
   6726   Formula (initial) (all,c,COMM)(all,r,REG)
   6727       BVMGB(c,r) = VMGB(c,r);
   6728    
   6729   Coefficient (parameter) (all,c,COMM)(all,r,REG)
   6730       BVMGP(c,r) # government household expenditure on imported c #;
   6731   Formula (initial) (all,c,COMM)(all,r,REG)
   6732       BVMGP(c,r) = VMGP(c,r);
   6733    
   6734   Coefficient (parameter) (all,c,COMM)(all,r,REG)
   6735       BVDGP(c,r) # government household expenditure on domestic c in r #;
   6736   Formula (initial) (all,c,COMM)(all,r,REG)
   6737       BVDGP(c,r) = VDGP(c,r);
   6738    
   6739   Coefficient (parameter) (all,c,COMM)(all,r,REG)
   6740       BVMIB(c,r) # investment expenditure on c in r #;
   6741   Formula (initial) (all,c,COMM)(all,r,REG)
   6742       BVMIB(c,r) = VMIB(c,r);
   6743    
   6744   Coefficient (parameter) (all,c,COMM)(all,r,REG)
   6745       BVMIP(c,r) # investment expenditure on imported c #;
   6746   Formula (initial) (all,c,COMM)(all,r,REG)
   6747       BVMIP(c,r) = VMIP(c,r);
   6748    
   6749   Coefficient (parameter) (all,c,COMM)(all,r,REG)
   6750       BVDIP(c,r) # investment expenditure on domestic c in r #;
   6751   Formula (initial) (all,c,COMM)(all,r,REG)
   6752       BVDIP(c,r) = VDIP(c,r);
   6753    
   6754   Coefficient (parameter) (all,c,COMM)(all,r,REG)
   6755       BVDIB(c,r) # investment expenditure on domestic c in r #;
   6756   Formula (initial) (all,c,COMM)(all,r,REG)
   6757       BVDIB(c,r) = VDIB(c,r);
   6758    
   6759   Coefficient (parameter) (all,c,COMM)(all,s,REG)(all,d,REG)
   6760       BVMSB(c,s,d) # imports of c from r to s at domestic basic prices #;
   6761   Formula (initial) (all,c,COMM)(all,s,REG)(all,d,REG)
   6762       BVMSB(c,s,d) = VMSB(c,s,d);
   6763    
   6764   Coefficient (parameter) (all,c,COMM)(all,s,REG)(all,d,REG)
   6765       BVCIF(c,s,d) # imports of c from r to s valued cif (tradeables only) #;
   6766   Formula (initial) (all,c,COMM)(all,s,REG)(all,d,REG)
   6767       BVCIF(c,s,d) = VCIF(c,s,d);
   6768    
   6769   Coefficient (parameter) (all,c,COMM)(all,s,REG)(all,d,REG)
   6770       BMTAX(c,s,d) # power of import tax, base #;
   6771   Formula (initial) (all,c,COMM)(all,s,REG)(all,d,REG)
   6772       BMTAX(c,s,d) = [BVMSB(c,s,d) - BVCIF(c,s,d)] / BVCIF(c,s,d) * 100;
   6773    
   6774   Coefficient (parameter) (all,c,COMM)(all,s,REG)(all,d,REG)
   6775       BVFOB(c,s,d) # exports of c from r to s valued fob (tradeables only) #;
   6776   Formula (initial) (all,c,COMM)(all,s,REG)(all,d,REG)
   6777       BVFOB(c,s,d) = VFOB(c,s,d);
   6778    
   6779   Coefficient (parameter) (all,c,COMM)(all,s,REG)(all,d,REG)
   6780       BXTAX(c,s,d) # power of exports tax, base #;
   6781   Formula (initial) (all,c,COMM)(all,s,REG)(all,d,REG)
   6782       BXTAX(c,s,d) = [BVFOB(c,s,d) - BVXSB(c,s,d)] / BVXSB(c,s,d) * 100;
   6783    
   6784   Coefficient (parameter) (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6785       BETAX(e,a,r) # power of exports tax, base #;
   6786   Formula (initial)(all,e,ENDW)(all,a,ACTS)(all,r,REG)
   6787       BETAX(e,a,r) = [BEVFP(e,a,r) - BEVFB(e,a,r)] / BEVFB(e,a,r) * 100;
   6788    
   6789   Coefficient (parameter) (all,r,REG)
   6790       BSAVE(r) # expenditure on NET saving in region r at purchaser's prices #;
   6791   Formula (initial) (all,r,REG)
   6792       BSAVE(r) = SAVE(r);
   6793    
   6794   Coefficient (parameter) (all,r,REG)
   6795       ISBAL(r) # I-S balance, NETINV(r) - SAVE(r) #;
   6796   Formula (initial) (all,r,REG)
   6797       ISBAL(r) = NETINV(r) - BSAVE(r);
   6798   Zerodivide off;
   6799   !<
   6800       Begin post-sim calculations
   6801       ...........................
   6802   >!
   6803    
   6804   postsim (begin);
   6805    
   6806   File (new) WELVIEW # output file containing welfare decomposition summary #;
   6807    
   6808   !<
   6809       SET definitions for Welfare summary file. Supplementary sets for "toggles"
   6810       in VIEWHAR.
   6811   >!
   6812   Set
   6813       UNITA # dummy (unit) set for activities # (a);
   6814   Set
   6815       UNITC # dummy (unit) set for commodities # (c);
   6816   Set
   6817       UACT = UNITA x ACTS;
   6818   Set
   6819       UCOM = UNITC x COMM;
   6820   Set
   6821       ALLOCEFF = ENDW + UACT + UCOM;
   6822   Set
   6823       ENDWACTS = ENDW + ACTS;
   6824   Set
   6825       TAXSUM(pfacttax,prodtax,comtax);
   6826   Set
   6827       TYPE(xtax,mtax);
   6828   Subset
   6829       TYPE is subset of ALLTAX;
   6830   Set
   6831       PRICES(pworld,pexport,pimport);
   6832   Set
   6833       ACTIVITY(firm, private, investment, govt);
   6834   Set
   6835       COL(welcnt, dvol, taxrateb, taxrateu);
   6836   Set
   6837       DIREC(import,export);
   6838   Set
   6839       FORM(percent,value);
   6840   Set
   6841       COLM(ISbal,p_cgds,p_save);
   6842    
   6843   Zerodivide default RNREG;
   6844   Zerodivide (nonzero_by_zero) default RNREG;
   6845   !<
   6846       C-A: EV decomposition summary
   6847       -----------------------------
   6848   >!
   6849    
   6850   Coefficient (all,r,REG)(all,c,COLUMN)
   6851       WELFARE(r,c) # aggregate report of welfare change #;
   6852   Formula (all,r,REG)
   6853       WELFARE(r,"co2trd") = CNTco2trd(r);
   6854   Formula (all,r,REG)
   6855       WELFARE(r,"alloc_A1")= sum{t, ALLTAX, CNTalleffr(r,t)};
   6856   Formula (all,r,REG)
   6857       WELFARE(r,"ENDWB1") = CNTendwr(r);
   6858   Formula (all,r,REG)
   6859       WELFARE(r,"tech_C1") = sum{t,TECHTYPE, CNTtechr(t,r)};
   6860   Formula (all,r,REG)
   6861       WELFARE(r,"pop_D1")  = CNTpop(r);
   6862   Formula (all,r,REG)
   6863       WELFARE(r,"tot_E1")  = CNTtotr(r);
   6864   Formula (all,r,REG)
   6865       WELFARE(r,"IS_F1")   = CNTpinv(r);
   6866   Formula (all,r,REG)
   6867       WELFARE(r,"PREF_G1") = CNTdpar(r);
   6868    
   6869   Write
   6870       WELFARE to file WELVIEW header "A"
   6871       longname "EV Decomposition: Summary";
   6872    
   6873   !<
   6874       C-A1: Allocative efficiency effect: Activity, comodity and endowment Summary
   6875       ----------------------------------------------------------------------------
   6876   >!
   6877    
   6878   Mapping UCOM2COMM from UCOM to COMM;
   6879   Formula (all,c,UCOM)
   6880       UCOM2COMM(c) = $POS(c);
   6881   Mapping UACT2ACTS from UACT to ACTS;
   6882   Formula (all,a,UACT)
   6883       UACT2ACTS(a) = $POS(a);
   6884   Coefficient (all,a,ALLOCEFF)(all,r,REG)
   6885       CNTalleff(a,r) # allocative efficiency #;
   6886   Formula (all,r,REG)(all,e,ENDW)
   6887       CNTalleff(e,r) = CNTqfeer(e,r) + CNTqe(e,r);
   6888   Formula (all,r,REG)(all,c,UCOM)
   6889       CNTalleff(c,r) = CNTalleffcr(UCOM2COMM(c),r);
   6890   Formula (all,r,REG)(all,a,UACT)
   6891       CNTalleff(a,r) = sum{c,COMM, CNTqca(c,UACT2ACTS(a),r)};
   6892    
   6893   Write
   6894       CNTalleff to file WELVIEW header "A1"
   6895       longname "Allocative Efficiency Effect: Summary";
   6896    
   6897   !<
   6898       C-A2: Allocative efficiency effect: Tax type summary
   6899       ----------------------------------------------------
   6900   >!
   6901   Coefficient (all,r,REG)(all,t,ALLTAX)
   6902       CNTalleffkr(r,t) # allocative efficiency effect #;
   6903   Formula (all,r,REG)(all,t,ALLTAX)
   6904       CNTalleffkr(r,t) = CNTalleffr(r,t);
   6905   Write
   6906       CNTalleffkr to file WELVIEW header "A2"
   6907       longname "Allocative Efficiency Effect: Tax Type Summary";
   6908    
   6909   !<
   6910       C-AX: Decomposition of allocative effect: Tax type and commodity
   6911       ----------------------------------------------------------------
   6912    
   6913       C-A21:  Output tax effect
   6914       C-A22:  Domestic tax effect
   6915       C-A23:  Trade tax effect
   6916       C-A24:  Endowment tax effect
   6917       C-A25:  Factor income tax effect
   6918   >!
   6919    
   6920   !<
   6921       C-A21:  Output tax effect
   6922       .........................
   6923   >!
   6924    
   6925   Coefficient (all,a,ACTS)(all,r,REG)
   6926       OTAX(a,r) # output tax effect #;
   6927   Formula (all,a,ACTS)(all,r,REG)
   6928       OTAX(a,r) = CNTqo(a,r);
   6929    
   6930   Write
   6931       OTAX to file WELVIEW header "A21"
   6932       longname "Output Tax Effect";
   6933    
   6934   !<
   6935       C-A211: Output tax effect: Explanatory factors
   6936       ..............................................
   6937   >!
   6938    
   6939   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6940       UOUTAX(c,a,r) # power of activity output tax, updated #;
   6941   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   6942       UOUTAX(c,a,r) = [MAKEB(c,a,r) - MAKES(c,a,r)] / MAKES(c,a,r) * 100;
   6943    
   6944   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)(all,co,COL)
   6945       OUTPUT(c,a,r,co) # output tax, explanatory factors #;
   6946   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)(all,co,COL)
   6947       OUTPUT(c,a,r,co)
   6948           = IF[co="welcnt",   CNTqca(c,a,r)]
   6949           + IF[co="dvol",     BMAKEB(c,a,r) * qo(a,r) / 100]
   6950           + IF[co="taxrateb", BOUTAX(c,a,r)]
   6951           + IF[co="taxrateu", UOUTAX(c,a,r)];
   6952   Write
   6953       OUTPUT to file WELVIEW header "A211"
   6954       longname "Output Tax Effect: Explanatory Factors";
   6955    
   6956   !<
   6957       C-A22:  Domestic tax effect
   6958       ---------------------------
   6959    
   6960       C-A22:  Domestic tax effect: Summary
   6961       C-A221: Intermed. input tax effect
   6962       C-A222: Investment interm. input tax effect
   6963       C-A22F: Intermed. input tax effect: Explanatory factors
   6964       C-A22P: Private cons. tax effect: Explanatory factors
   6965       C-A22G: Government cons. tax effect: Explanatory factors
   6966       C-A22I: Investment demand Tax Effect: Explanatory factors
   6967   >!
   6968    
   6969   !<
   6970       C-A22: Domestic tax effect: Summary
   6971       ...................................
   6972   >!
   6973    
   6974   Coefficient (all,c,COMM)(all,ac,ACTIVITY)(all,r,REG)(all,t,DIR)
   6975       ATAX(c,ac,r,t) # tax effect: summary #;
   6976   Formula (all,c,COMM)(all,ac,ACTIVITY)(all,r,REG)
   6977       ATAX(c,ac,r,"domestic")
   6978           = IF[ac="firm",       sum{a,ACTS, CNTqfd(c,a,r)}]
   6979           + IF[ac="private",    CNTqpd(c,r)]
   6980           + IF[ac="govt",       CNTqgd(c,r)]
   6981           + IF[ac="investment", CNTqid(c,r)];
   6982   Formula (all,c,COMM)(all,ac,ACTIVITY)(all,r,REG)
   6983       ATAX(c,ac,r,"imported")
   6984           = IF[ac="firm",       sum{a,ACTS, CNTqfm(c,a,r)}]
   6985           + IF[ac="private",    CNTqpm(c,r)]
   6986           + IF[ac="govt",       CNTqgm(c,r)]
   6987           + IF[ac="investment", CNTqim(c,r)];
   6988   Write
   6989       ATAX to file WELVIEW header "A22"
   6990       longname "Domestic Tax Effect: Summary";
   6991    
   6992   !<
   6993       C-A221: Intermediate input tax effect
   6994       .....................................
   6995   >!
   6996    
   6997   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)(all,d,DIR)
   6998       STAX(c,a,r,d) # intermediate input tax effect #;
   6999   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)(all,d,DIR)
   7000       STAX(c,a,r,d)
   7001           = IF[d="domestic", CNTqfd(c,a,r)]
   7002           + IF[d="imported", CNTqfm(c,a,r)];
   7003   Write
   7004       STAX to file WELVIEW header "A221"
   7005       longname "Intermed. Input Tax Effect";
   7006    
   7007   !<
   7008       C-A222: Investment intermediate input tax effect
   7009       ................................................
   7010   >!
   7011    
   7012   Coefficient (all,c,COMM)(all,r,REG)(all,d,DIR)
   7013       ITAX(c,r,d) # investment intermediate input tax effect #;
   7014   Formula (all,c,COMM)(all,r,REG)(all,d,DIR)
   7015       ITAX(c,r,d)
   7016           = IF[d="domestic", CNTqid(c,r)]
   7017           + IF[d="imported", CNTqim(c,r)];
   7018   Write
   7019       ITAX to file WELVIEW header "A222"
   7020       longname "Investment Intermed. Input Tax Effect";
   7021    
   7022   !<
   7023       C-A22F: Intermediate input tax effect: Explanatory factors
   7024       ..........................................................
   7025   >!
   7026    
   7027   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)(all,d,DIR)(all,co,COL)
   7028       FIRM(c,a,r,d,co) # explanatory factors: firm interm. input tax effect #;
   7029   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)(all,co,COL)
   7030       FIRM(c,a,r,"domestic",co)
   7031           = IF[co="dvol",     [BVDFB(c,a,r) * qfd(c,a,r)] / 100]
   7032           + IF[co="taxrateb", 100 * [BVDFP(c,a,r) - BVDFB(c,a,r)] / BVDFB(c,a,r)]
   7033           + IF[co="taxrateu", 100 * [VDFP(c,a,r) - VDFB(c,a,r)] / VDFB(c,a,r)];
   7034   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)(all,co,COL)
   7035       FIRM(c,a,r,"imported",co)
   7036           = IF[co="dvol",     [BVMFB(c,a,r) * qfm(c,a,r)] / 100]
   7037           + IF[co="taxrateb", 100 * [BVMFP(c,a,r) - BVMFB(c,a,r)] / BVMFB(c,a,r)]
   7038           + IF[co="taxrateu", 100 * [VMFP(c,a,r) - VMFB(c,a,r)] / VMFB(c,a,r)];
   7039   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)(all,d,DIR)
   7040       FIRM(c,a,r,d,"welcnt") = STAX(c,a,r,d);
   7041   Write
   7042       FIRM to file WELVIEW header "A22F"
   7043       longname "Intermed. Input Tax Effect: Explanatory Factors";
   7044    
   7045   !<
   7046       C-A22P: Private consumption tax Effect: Explanatory Factors
   7047       ...........................................................
   7048   >!
   7049    
   7050   Coefficient (all,c,COMM)(all,r,REG)(all,d,DIR)(all,co,COL)
   7051       PRIVATE(c,r,d,co) # explanatory factors: priv hh consumption tax effect #;
   7052   Formula (all,c,COMM)(all,r,REG)(all,co,COL)
   7053       PRIVATE(c,r,"domestic",co)
   7054           = IF[co="dvol",     [BVDPB(c,r) * qpd(c,r)] / 100]
   7055           + IF[co="taxrateb", 100 * [BVDPP(c,r) - BVDPB(c,r)] / BVDPB(c,r)]
   7056           + IF[co="taxrateu", 100 * [VDPP(c,r) - VDPB(c,r)] / VDPB(c,r)];
   7057   Formula (all,c,COMM)(all,r,REG)(all,co,COL)
   7058       PRIVATE(c,r,"imported",co)
   7059           = IF[co="dvol",     [BVMPB(c,r) * qpm(c,r)] / 100]
   7060           + IF[co="taxrateb", 100 * [BVMPP(c,r) - BVMPB(c,r)] / BVMPB(c,r)]
   7061           + IF[co="taxrateu", 100 * [VMPP(c,r) - VMPB(c,r)] / VMPB(c,r)];
   7062   Formula (all,c,COMM)(all,r,REG)(all,d,DIR)
   7063       PRIVATE(c,r,d,"welcnt") = ATAX(c,"private",r,d);
   7064   Write
   7065       PRIVATE to file WELVIEW header "A22P"
   7066       longname "Private Cons. Tax Effect: Explanatory Factors";
   7067    
   7068   !<
   7069       C-A22G: Government consumption tax effect: Explanatory factors
   7070       ..............................................................
   7071   >!
   7072    
   7073   Coefficient (all,c,COMM)(all,r,REG)(all,d,DIR)(all,co,COL)
   7074       GOVT(c,r,d,co) # explanatory factors: gov't hh consumption tax effect #;
   7075   Formula (all,c,COMM)(all,r,REG)(all,co,COL)
   7076       GOVT(c,r,"domestic",co)
   7077           = IF[co="dvol",     [BVDGB(c,r) * qgd(c,r)] / 100]
   7078           + IF[co="taxrateb", 100 * [BVDGP(c,r) - BVDGB(c,r)] / BVDGB(c,r)]
   7079           + IF[co="taxrateu", 100 * [VDGP(c,r) - VDGB(c,r)] / VDGB(c,r)];
   7080   Formula (all,c,COMM)(all,r,REG)(all,co,COL)
   7081       GOVT(c,r,"imported",co)
   7082           = IF[co="dvol",     [BVMGB(c,r) * qgm(c,r)] / 100]
   7083           + IF[co="taxrateb", 100 * [BVMGP(c,r) - BVMGB(c,r)] / BVMGB(c,r)]
   7084           + IF[co="taxrateu", 100 * [VMGP(c,r) - VMGB(c,r)] / VMGB(c,r)];
   7085   Formula (all,c,COMM)(all,r,REG)(all,d,DIR)
   7086       GOVT(c,r,d,"welcnt") = ATAX(c,"govt",r,d);
   7087   Write
   7088       GOVT to file WELVIEW header "A22G"
   7089       longname "Government Cons. Tax Effect: Explanatory Factors";
   7090    
   7091   !<
   7092       C-A22I: Investment tax effect: Explanatory factors
   7093       ..................................................
   7094   >!
   7095    
   7096   Coefficient (all,c,COMM)(all,r,REG)(all,d,DIR)(all,co,COL)
   7097       INVESTMENT(c,r,d,co) # explanatory factors: investment tax effect #;
   7098   Formula (all,c,COMM)(all,r,REG)(all,co,COL)
   7099       INVESTMENT(c,r,"domestic",co)
   7100           = IF[co="dvol",     [BVDIB(c,r) * qid(c,r)] / 100]
   7101           + IF[co="taxrateb", 100 * [BVDIP(c,r) - BVDIB(c,r)] / BVDIB(c,r)]
   7102           + IF[co="taxrateu", 100 * [VDIP(c,r) - VDIB(c,r)] / VDIB(c,r)];
   7103   Formula (all,c,COMM)(all,r,REG)(all,co,COL)
   7104       INVESTMENT(c,r,"imported",co)
   7105           = IF[co="dvol",     [BVMIB(c,r) * qim(c,r)] / 100]
   7106           + IF[co="taxrateb", 100 * [BVMIP(c,r) - BVMIB(c,r)] / BVMIB(c,r)]
   7107           + IF[co="taxrateu", 100 * [VMIP(c,r) - VMIB(c,r)] / VMIB(c,r)];
   7108   Formula (all,c,COMM)(all,r,REG)(all,d,DIR)
   7109       INVESTMENT(c,r,d,"welcnt") = ATAX(c,"investment",r,d);
   7110   Write
   7111       INVESTMENT to file WELVIEW header "A22I"
   7112       longname "Investment Tax Effect: Explanatory Factors";
   7113    
   7114   !<
   7115       C-A23: Trade tax effect
   7116       ------------------------
   7117    
   7118       C-A23:  Trade tax effect
   7119       C-A231: Trade tax effect: Explanatory factors
   7120   >!
   7121    
   7122   !<
   7123       C-A23: Trade tax effect
   7124       ........................
   7125   >!
   7126    
   7127   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)(all,k,TYPE)
   7128       TTAX(c,s,d,k) # trade tax effect #;
   7129   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   7130       TTAX(c,s,d,"xtax") = CNTqxs(c,s,d);
   7131   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   7132       TTAX(c,s,d,"mtax") = CNTqms(c,s,d);
   7133   Write
   7134       TTAX to file WELVIEW header "A23"
   7135       longname "Trade Tax Effect";
   7136    
   7137   !<
   7138       C-A231: Trade tax effect: Explanatory factors
   7139       .............................................
   7140   >!
   7141    
   7142   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)
   7143       UMTAX(c,s,d) # power of import tax, updated # ;
   7144   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   7145       UMTAX(c,s,d) = [VMSB(c,s,d) - VCIF(c,s,d)] / VCIF(c,s,d) * 100;
   7146    
   7147   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)
   7148       UXTAX(c,s,d) # power of export tax, updated #;
   7149   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   7150       UXTAX(c,s,d) = [VFOB(c,s,d) - VXSB(c,s,d)] / VXSB(c,s,d) * 100;
   7151    
   7152   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)(all,co,COL)(all,dc,DIREC)
   7153       TRADE(c,s,d,co,dc) # trade tax effect: explanatory factors # ;
   7154   Formula (all,c,COMM)(all,s,REG)(all,d,REG)(all,co,COL)
   7155       TRADE(c,s,d,co,"export")
   7156           = IF[co="welcnt",   TTAX(c,s,d,"xtax")]
   7157           + IF[co="dvol",     BVXSB(c,s,d) * qxs(c,s,d) / 100]
   7158           + IF[co="taxrateb", BXTAX(c,s,d)]
   7159           + IF[co="taxrateu", UXTAX(c,s,d)];
   7160   Formula (all,c,COMM)(all,s,REG)(all,d,REG)(all,co,COL)
   7161       TRADE(c,s,d,co,"import")
   7162           = IF[co="welcnt",   TTAX(c,s,d,"mtax")]
   7163           + IF[co="dvol",     BVXSB(c,s,d) * qxs(c,s,d) / 100]
   7164           + IF[co="taxrateb", BMTAX(c,s,d)]
   7165           + IF[co="taxrateu", UMTAX(c,s,d)];
   7166    
   7167   Write
   7168       TRADE to file WELVIEW header "A231"
   7169       longname "Trade Tax Effect: Explanatory Factors";
   7170    
   7171   !<
   7172       C-A24: Endowment tax effect
   7173       ---------------------------
   7174    
   7175       C-A24:  Endowment tax effect
   7176       C-A241: Endowment tax effect: Explanatory factors
   7177   >!
   7178    
   7179   !<
   7180       C-A24:   Endowment tax effect
   7181       .............................
   7182   >!
   7183    
   7184   Coefficient (all,e,ENDW)(all,r,REG)
   7185       FACTAX(e,r) # Endowment tax effect #;
   7186   Formula (all,e,ENDW)(all,r,REG)
   7187       FACTAX(e,r) = sum{a,ACTS, CNTqfe(e,a,r)};
   7188   Write
   7189       FACTAX to file WELVIEW header "A24"
   7190       longname "Endowment Tax Effect";
   7191    
   7192   !<
   7193       C-A241: Endowment tax effect: Explanatory factors
   7194       .................................................
   7195   >!
   7196   Coefficient (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   7197       UETAX(e,a,r) # power of factor tax, updated #;
   7198   Formula (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   7199       UETAX(e,a,r) = [EVFP(e,a,r) - EVFB(e,a,r)] / EVFB(e,a,r) * 100;
   7200    
   7201   ! Note: PFACTOR in "classic" welfare decomp was changed to FACTORTAX because
   7202           the variable pfactor(r) has already been defined !
   7203   Coefficient (all,e,ENDW)(all,a,ACTS)(all,r,REG)(all,co,COL)
   7204       FACTORTAX(e,a,r,co) # Endowment tax effect #;
   7205   Formula (all,e,ENDW)(all,a,ACTS)(all,r,REG)(all,co,COL)
   7206       FACTORTAX(e,a,r,co)
   7207           = IF[co="welcnt",   CNTqfe(e,a,r)]
   7208           + IF[co="dvol",     BEVFB(e,a,r) * qfe(e,a,r) / 100]
   7209           + IF[co="taxrateb", BETAX(e,a,r)]
   7210           + IF[co="taxrateu", UETAX(e,a,r)];
   7211    
   7212   Write FACTORTAX to file WELVIEW header "A241"
   7213         longname "Endowment Tax Effect: Explanatory Factors";
   7214    
   7215   !<
   7216       C-A25: Income tax effect
   7217       ------------------------
   7218    
   7219       C-A25:  Income tax effect
   7220       C-A251: Income tax effect: Explanatory factors
   7221   >!
   7222    
   7223   !<
   7224       C-A25: Income tax effect
   7225       ........................
   7226   >!
   7227    
   7228   Coefficient (all,e,ENDW)(all,r,REG)
   7229       YTAX(e,r) # factor income tax effect #;
   7230   Formula (all,e,ENDW)(all,r,REG)
   7231       YTAX(e,r) = sum{a,ACTS, CNTqea(e,a,r)};
   7232   Write
   7233       YTAX to file WELVIEW header "A25"
   7234       longname "Income Tax Effect";
   7235    
   7236   !<
   7237       C-A251: Income tax effect: Explanatory factors
   7238       ..............................................
   7239   >!
   7240   Coefficient (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   7241       UINCTAX(e,a,r) # power of income tax, updated #;
   7242   Formula (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   7243       UINCTAX(e,a,r) = [[EVFB(e,a,r) - EVOS(e,a,r)] / EVOS(e,a,r)] * 100;
   7244   Coefficient (all,e,ENDW)(all,a,ACTS)(all,r,REG)(all,co,COL)
   7245       INCOMETAX(e,a,r,co) # income tax effect: Explanatory Factors #;
   7246   Formula (all,e,ENDW)(all,a,ACTS)(all,r,REG)(all,co,COL)
   7247       INCOMETAX(e,a,r,co)
   7248           = IF[co="welcnt",   CNTqea(e,a,r)]
   7249           + IF[co="dvol",     BVEB(e,a,r) * qes(e,a,r) / 100]
   7250           + IF[co="taxrateb", BINCTAX(e,a,r)]
   7251           + IF[co="taxrateu", UINCTAX(e,a,r)];
   7252   Write
   7253       INCOMETAX to file WELVIEW header "A251"
   7254       longname "Income Tax Effect: Explanatory Factors";
   7255    
   7256   !<
   7257       C-B1: Endowment effect: Gross of depreciation
   7258       ---------------------------------------------
   7259   >!
   7260    
   7261   Coefficient (all,r,REG)(all,e,ENDW)
   7262       CNTendowment(r,e) # contribution to welfare by ENDW e in region r #;
   7263   Formula (all,r,REG)(all,e,ENDW)
   7264       CNTendowment(r,e) = CNTendw(e,r);
   7265   Write
   7266       CNTendowment to file WELVIEW header "B1"
   7267       longname "Endowment Effect, Gross of Depreciation";
   7268    
   7269   !<
   7270       C-B2: Endowment effect: depreciation
   7271       ------------------------------------
   7272   >!
   7273    
   7274   Write
   7275       CNTkb to file WELVIEW header "B2"
   7276       longname "Endowment Effect: Depreciation";
   7277    
   7278   !<
   7279       C-C1: Technical change effect
   7280       -----------------------------
   7281    
   7282       C-C1:  Technical change effect: Summary
   7283       C-C1X: Technical change effect: Further decomposition
   7284   >!
   7285    
   7286   Coefficient (all,r,REG)(all,t,TECHTYPE)
   7287       CNTtech(r,t) # contribution to welfare change by tech #;
   7288   Formula (all,r,REG)(all,t,TECHTYPE)
   7289       CNTtech(r,t) = CNTtechr(t,r);
   7290    
   7291   Write
   7292       CNTtech to file WELVIEW header "C1"
   7293       longname "Technical Change Effect: Summary";
   7294    
   7295   Write
   7296       CNTtech_ao to file WELVIEW header "C11"
   7297       longname "(ao) Output Augm. Tech. Change Effect";
   7298   Write
   7299       CNTtech_afe to file WELVIEW header "C12"
   7300       longname "(afe) Primary Factor Augm. Tech. Change Effect";
   7301   Write
   7302        CNTtech_af to file WELVIEW header "C15"
   7303       longname "(afa) Intermed. Input Augm. Tech. Change Effect";
   7304   Write
   7305       CNTtech_atmfsd to file WELVIEW header "C16"
   7306       longname "(atmfsd) Internat. Margin Augm. Tech. Change Effect";
   7307   Write
   7308       CNTtech_ams to file WELVIEW header "C17"
   7309       longname "(ams) Bilateral Import Augm. Tech. Change Effect";
   7310    
   7311   !<
   7312       C-D1: Population effect
   7313       -----------------------
   7314    
   7315       No decomposition required here.
   7316   >!
   7317    
   7318   !<
   7319       C-E1: Terms of Trade (ToT) effect
   7320       ---------------------------------
   7321   >!
   7322    
   7323   ! Note: TOT(c,r,t,f) in Welfare Decomp was renamed to WTOT(c,r,t,f) because a
   7324           prior tot(r) variable has been declared in the model!
   7325   Coefficient (all,c,COMM)(all,r,REG)(all,t,PRICES)(all,f,FORM)
   7326       WTOT(c,r,t,f)
   7327       # terms trade effects decomposed by effects of different prices #;
   7328   Formula (all,c,COMM)(all,r,REG)
   7329       WTOT(c,r,"pworld","percent") = c1_cr(c,r);
   7330   Formula (all,c,COMM)(all,r,REG)
   7331       WTOT(c,r,"pexport","percent") = c2_cr(c,r);
   7332   Formula (all,c,COMM)(all,r,REG)
   7333       WTOT(c,r,"pimport","percent") = -c3_cr(c,r);
   7334   Formula (all,c,COMM)(all,r,REG)
   7335       WTOT(c,r,"pworld","value")
   7336           = CNTtotr(r) * c1_cr(c,r)
   7337           / sum{k,COMM, sum{t,PRICES, WTOT(k,r,t,"percent")}};
   7338   Formula (all,c,COMM)(all,r,REG)
   7339       WTOT(c,r,"pexport","value")
   7340           = CNTtotr(r) * c2_cr(c,r)
   7341           / sum{t,PRICES, sum{k,COMM, WTOT(k,r,t,"percent")}};
   7342   Formula (all,c,COMM)(all,r,REG)
   7343       WTOT(c,r,"pimport","value")
   7344           = -c3_cr(c,r) * CNTtotr(r)
   7345           / sum{t,PRICES, sum{k,COMM, WTOT(k,r,t,"percent")}};
   7346    
   7347   Write
   7348       WTOT to file WELVIEW header "E1"
   7349       longname "Terms of Trade Effect";
   7350    
   7351   !<
   7352       C-F1: I-S Effect: Explanatory factors
   7353       -------------------------------------
   7354   >!
   7355    
   7356   Coefficient (all,r,REG)(all,c,COLM)
   7357       CGDSCOMP(r,c) # components of cgds effect #;
   7358   Formula (all,r,REG)
   7359       CGDSCOMP(r,"ISbal") = ISBAL(r);
   7360   Formula (all,r,REG)
   7361       CGDSCOMP(r,"p_cgds") = pinv(r);
   7362   Formula (all,r,REG)
   7363       CGDSCOMP(r,"p_save") = psave(r);
   7364   Write
   7365       CGDSCOMP to file WELVIEW header "F1"
   7366       longname "I-S Effect: Explanatory Factors";
   7367    
   7368   !<
   7369       -----------------------------
   7370       END OF Welfare summary module
   7371       -----------------------------
   7372   >!
   7373    
   7374   !<
   7375       -------------------------------------------------
   7376       D. GTAPVol (post-simulation) summary calculations
   7377       -------------------------------------------------
   7378   >!
   7379    
   7380   !<
   7381       Compute the relevant volume changes
   7382       -----------------------------------
   7383   >!
   7384    
   7385   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)
   7386       DQXS(c,s,d)
   7387       # ch. in vol. of exports of c from region s to d at initial basic prices #;
   7388   Formula  (all,c,COMM)(all,s,REG)(all,d,REG)
   7389       DQXS(c,s,d) = [qxs(c,s,d) / 100] * BVXSB(c,s,d);
   7390    
   7391   Coefficient (all,c,COMM)(all,r,REG)
   7392       DQDS(c,r)
   7393       # ch. in vol. of domestic sales of com. c in r at initial basic prices #;
   7394   Formula (all,c,COMM)(all,r,REG)
   7395       DQDS(c,r) = [qds(c,r) / 100] * BVDB(c,r) ;
   7396    
   7397   Coefficient (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   7398       DQFE(e,a,r)
   7399       # ch. in vol. of endowment e by activity a in r at initial basic prices #;
   7400   Formula (all,e,ENDW)(all,a,ACTS)(all,r,REG)
   7401       DQFE(e,a,r) = [qfe(e,a,r) / 100] * BEVFB(e,a,r) ;
   7402    
   7403   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   7404       DQFM(c,a,r)
   7405       # ch. in vol. of imp. intermed. c by act. a in r at initial basic prices #;
   7406   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   7407       DQFM(c,a,r) = [qfm(c,a,r) / 100] * BVMFB(c,a,r) ;
   7408    
   7409   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   7410       DQFD(c,a,r)
   7411       # ch. in vol. of dom. intermed. c by act. a in r at initial basic prices #;
   7412   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   7413            DQFD(c,a,r) = [qfd(c,a,r) / 100] * BVDFB(c,a,r) ;
   7414    
   7415   Coefficient (all,c,COMM)(all,r,REG)
   7416       DQPM(c,r)
   7417       # ch. in vol. of priv. hhld cons. for imp. c in r at initial basic prices #;
   7418   Formula (all,c,COMM)(all,r,REG)
   7419       DQPM(c,r) = [qpm(c,r) / 100] * BVMPB(c,r) ;
   7420    
   7421   Coefficient (all,c,COMM)(all,r,REG)
   7422       DQPD(c,r)
   7423       # ch. in vol. of priv. hhld cons. for dom. c in r at initial basic prices #;
   7424   Formula (all,c,COMM)(all,r,REG)
   7425       DQPD(c,r) = [qpd(c,r) / 100] * BVDPB(c,r) ;
   7426    
   7427   Coefficient (all,c,COMM)(all,r,REG)
   7428       DQGM(c,r)
   7429       # ch. in vol. of government cons. for imp. c in r at initial basic prices #;
   7430   Formula (all,c,COMM)(all,r,REG)
   7431       DQGM(c,r) = [qgm(c,r) / 100] * BVMGB(c,r) ;
   7432    
   7433   Coefficient (all,c,COMM)(all,r,REG)
   7434       DQGD(c,r)
   7435       # ch. in vol. of government cons. for dom. c in r at initial basic prices #;
   7436   Formula (all,c,COMM)(all,r,REG)
   7437       DQGD(c,r) = [qgd(c,r) / 100] * BVDGB(c,r) ;
   7438    
   7439   Coefficient (all,a,ACTS)(all,r,REG)
   7440       DQO(a,r)
   7441       # ch. in vol. of output by activity a in r at initial basic prices #;
   7442   Formula (all,a,ACTS)(all,r,REG)
   7443       DQO(a,r) = [qo(a,r) / 100] * BVOS(a,r) ;
   7444    
   7445   Coefficient (all,c,COMM)(all,r,REG)
   7446       DQC(c,r)
   7447       # ch. in vol. of supply of com. c in r at initial basic prices #;
   7448   Formula (all,c,COMM)(all,r,REG)
   7449       DQC(c,r) = [qc(c,r) / 100] * BVCB(c,r) ;
   7450    
   7451   Coefficient (all,s,REG)(all,d,REG)
   7452       DTOT(s,d)
   7453       # ch. in vol. of total exports from region s to d at initial basic prices #;
   7454   Formula (all,s,REG)(all,d,REG)
   7455       DTOT(s,d) = sum{c,COMM, DQXS(c,s,d)};
   7456    
   7457   Zerodivide off;
   7458    
   7459   FILE
   7460    (New) GTAPVOL # HAR file of volume changes # ;
   7461   !< Write the output of this module to ViewHAR for easy viewing and summation >!
   7462    
   7463   Write
   7464       DQXS to file GTAPVOL header "DQXS";
   7465       DQDS to file GTAPVOL header "DQDS";
   7466       DQFE to file GTAPVOL header "DQFE";
   7467       DQFM to file GTAPVOL header "DQFM";
   7468       DQFD to file GTAPVOL header "DQFD";
   7469       DQPM to file GTAPVOL header "DQPM";
   7470       DQPD to file GTAPVOL header "DQPD";
   7471       DTOT to file GTAPVOL header "DTOT";
   7472       DQO  to file GTAPVOL header "DQO ";
   7473       DQC  to file GTAPVOL header "DQC ";
   7474       DQGD to file GTAPVOL header "DQGD";
   7475       DQGM to file GTAPVOL header "DQGM";
   7476    
   7477   !<
   7478       --------------
   7479       END OF GTAPVol
   7480       --------------
   7481   >!
   7482   postsim (end);
   7483   !<
   7484       -----------------------------------
   7485       END OF post-simulation calculations
   7486       -----------------------------------
   7487   >!
   7488    
   7489   !<
   7490       E. Real Energy Price Index
   7491       --------------------------
   7492    
   7493       The real energy price index is a Divisia index of user prices of energy,
   7494       deflated by the GDP deflator.
   7495   >!
   7496    
   7497   Coefficient (all,c,EGY)(all,r,REG)
   7498       TOTDEM(c,r) # energy usage at purchaser's prices #;
   7499   Formula (all,c,EGY)(all,r,REG)
   7500       TOTDEM(c,r) = sum{a,ACTS, VDFP(c,a,r) + VMFP(c,a,r)}
   7501                   + VDPP(c,r) + VMPP(c,r) + VDIP(c,r) + VMIP(c,r)
   7502                   + VDGP(c,r) + VMGP(c,r);
   7503    
   7504   Variable (all,c,EGY)(all,r,REG)
   7505       vdem(c,r) # money value of energy usage at producer's prices #;
   7506   Equation E_vdem
   7507   # money value of energy usage at producer's prices #
   7508   (all,c,EGY)(all,r,REG)
   7509       TOTDEM(c,r) * vdem(c,r)
   7510                   = sum{a,ACTS, VDFP(c,a,r) * [pfd(c,a,r) + qfd(c,a,r)]
   7511                               + VMFP(c,a,r) * [pfm(c,a,r) + qfm(c,a,r)]}
   7512                   + VDPP(c,r) * [ppd(c,r) + qpd(c,r)]
   7513                   + VMPP(c,r) * [ppm(c,r) + qpm(c,r)]
   7514                   + VDIP(c,r) * [pid(c,r) + qid(c,r)]
   7515                   + VMIP(c,r) * [pim(c,r) + qim(c,r)]
   7516                   + VDGP(c,r) * [pgd(c,r) + qgd(c,r)]
   7517                   + VMGP(c,r) * [pgm(c,r) + qgm(c,r)];
   7518    
   7519   Variable (all,c,EGY)(all,r,REG)
   7520       qdem(c,r) # producer-prices-weighted energy usage quantity index #;
   7521   Equation E_qdem
   7522   # agents'-prices-weighted energy usage quantity index #
   7523   (all,c,EGY)(all,r,REG)
   7524       TOTDEM(c,r) * qdem(c,r)
   7525                   = sum{a,ACTS, VDFP(c,a,r) * qfd(c,a,r)
   7526                               + VMFP(c,a,r) * qfm(c,a,r)}
   7527                   + VDPP(c,r) * qpd(c,r) + VMPP(c,r) * qpm(c,r)
   7528                   + VDIP(c,r) * qid(c,r) + VMIP(c,r) * qim(c,r)
   7529                   + VDGP(c,r) * qgd(c,r) + VMGP(c,r) * qgm(c,r);
   7530    
   7531   Variable (all,c,EGY)(all,r,REG)
   7532       apen(c,r) # real energy price index #;
   7533   Equation E_apen
   7534   # real energy price index #
   7535   (all,c,EGY)(all,r,REG)
   7536       apen(c,r) = vdem(c,r) - qdem(c,r) - pgdp(r);
   7537    
   7538   !<
   7539       ----------------------------------------------
   7540       F. Data balance check and summary calculations
   7541       ----------------------------------------------
   7542   >!
   7543    
   7544   Set
   7545       COSTS # industry cost summary # = "IntDom" + "IntImp" + ENDW + "PTAX"  ;
   7546   Set
   7547       GDPIN # income-side GDP # = ENDW + "IndTaxes";
   7548   Set
   7549       SALES # Commodity Sales Summary #
   7550       (Intermediate,Household,Investment,Government,Exports,IntnlMargins);
   7551    
   7552   Coefficient (all,a,ACTS)(all,r,REG)(all,c,COSTS)
   7553       COSTSUM(a,r,c) # industry cost summary #;
   7554   Formula
   7555    (all,a,ACTS)(all,r,REG) COSTSUM(a,r,"IntDom")      = sum{c,COMM, VDFP(c,a,r)};
   7556    (all,a,ACTS)(all,r,REG) COSTSUM(a,r,"IntImp")      = sum{c,COMM, VMFP(c,a,r)};
   7557    (all,a,ACTS)(all,r,REG)(all,e,ENDW) COSTSUM(a,r,e) = EVFP(e,a,r);
   7558    (all,a,ACTS)(all,r,REG) COSTSUM(a,r,"PTAX")        = sum{c,COMM, PTAX(c,a,r)};
   7559    (all,a,ACTS)(all,r,REG)(all,e,ENDW) COSTSUM(a,r,e) = EVFP(e,a,r);
   7560    (all,a,ACTS)(all,r,REG) COSTSUM(a,r,"PTAX")        = sum{c,COMM, PTAX(c,a,r)};
   7561   Write
   7562       COSTSUM to file GTAPSUM header "COST";
   7563    
   7564   Coefficient (all,r,REG)(all,g,GDPIN)
   7565      GDPINC(r,g) # income-side GDP #;
   7566   Formula
   7567      (all,r,REG)(all,e,ENDW) GDPINC(r,e) = sum{a,ACTS, EVFP(e,a,r)};
   7568      (all,r,REG) GDPINC(r,"IndTaxes") =  INDTAX(r) - TAXRFU(r)
   7569                                       + [INCOME(r) - FY(r) - INDTAX(r)];
   7570   Write
   7571       GDPINC to file GTAPSUM header "GDPI";
   7572    
   7573   Coefficient (all,c,COMM)(all,r,REG)(all,sa,SALES)
   7574       SALESUM(c,r,sa) # commodity sales summary #;
   7575   Formula
   7576   (all,c,COMM)(all,r,REG) SALESUM(c,r,"Intermediate") = sum{a,ACTS, VDFB(c,a,r)};
   7577   (all,c,COMM)(all,r,REG) SALESUM(c,r,"Household")    = VDPB(c,r);
   7578   (all,c,COMM)(all,r,REG) SALESUM(c,r,"Investment")   = VDIB(c,r);
   7579   (all,c,COMM)(all,r,REG) SALESUM(c,r,"Government")   = VDGB(c,r);
   7580   (all,c,COMM)(all,r,REG) SALESUM(c,r,"Exports")      = VXDXSB(c,r);
   7581   (all,c,MARG)(all,r,REG) SALESUM(c,r,"IntnlMargins") = VST(c,r);
   7582   (all,c,NMRG)(all,r,REG) SALESUM(c,r,"IntnlMargins") = 0;
   7583   Write
   7584       SALESUM to file GTAPSUM header "SALE";
   7585    
   7586   Zerodivide default RNREG;
   7587    Coefficient (all,c,COMM)(all,r,REG)
   7588       VDBCHK(c,r) # VCB(c,r) - MAKEBCOM(c,r) should be tiny #;
   7589   Formula (all,c,COMM)(all,r,REG)
   7590       VDBCHK(c,r) = VCB(c,r) - MAKEBCOM(c,r);
   7591   Write
   7592       VDBCHK to file GTAPSUM header "VMCK";
   7593   Formula (all,c,COMM)(all,r,REG)
   7594       VDBCHK(c,r) = 100 * VDBCHK(c,r) / VCB(c,r);
   7595   Write
   7596       VDBCHK to file GTAPSUM header "VMCP" longname "VDBCHK as %";
   7597    
   7598   Coefficient (all,c,COMM)(all,s,REG)(all,d,REG)
   7599       TRDCHK(c,s,d) # VCIF(c,s,d) - [VFOB(c,s,d) + VTFSD(c,s,d)] should be tiny #;
   7600   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   7601       TRDCHK(c,s,d) = VCIF(c,s,d) - [VFOB(c,s,d) + VTFSD(c,s,d)];
   7602   Write
   7603       TRDCHK to file GTAPSUM header "TRCK";
   7604   Formula (all,c,COMM)(all,s,REG)(all,d,REG)
   7605       TRDCHK(c,s,d) = 100 * TRDCHK(c,s,d) / VCIF(c,s,d);
   7606   Write
   7607       TRDCHK to file GTAPSUM header "TRCP" longname "TRDCHK as %";
   7608    
   7609   Coefficient (all,m,MARG)
   7610       VTMCHK(m) # VTMUSE(m) - VTMPROV(m) should be tiny #;
   7611   Formula (all,m,MARG)
   7612       VTMCHK(m) = VTMUSE(m) - VTMPROV(m);
   7613   Write
   7614       VTMCHK to file GTAPSUM header "VTCK";
   7615   Formula (all,m,MARG)
   7616       VTMCHK(m) = 100 * VTMCHK(m) / VTMUSE(m);
   7617   Write
   7618       VTMCHK to file GTAPSUM header "VTCP" longname "VTMCHK as %";
   7619    
   7620   Coefficient (all,c,COMM)(all,r,REG)
   7621       CHKMKClIMP(c,r) # Checking the accounting on imports supply and demand #;
   7622   Formula (all,c,COMM)(all,r,REG)
   7623       CHKMKClIMP(c,r)
   7624           = sum{s,REG, VMSB(c,s,r)}
   7625           - sum{a,ACTS, VMFB(c,a,r)}
   7626           - VMPB(c,r) - VMGB(c,r) - VMIB(c,r);
   7627   Write
   7628       CHKMKClIMP to file GTAPSUM header "MPCK";
   7629   Formula (all,c,COMM)(all,r,REG)
   7630       CHKMKClIMP(c,r) = 100 * CHKMKClIMP(c,r) / [sum{s,REG, VMSB(c,s,r)}];
   7631    
   7632   Write
   7633       CHKMKClIMP to file GTAPSUM header "MPCP" longname "CHKMKClIMP as %";
   7634    
   7635   Coefficient (all,c,COMM)(all,a,ACTS)(all,r,REG)
   7636       VOSCHK(c,a,r) # MAKEB - [MAKES + PTAX] should be tiny #;
   7637   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   7638       VOSCHK(c,a,r) = MAKEB(c,a,r) - [MAKES(c,a,r) + PTAX(c,a,r)];
   7639   Write
   7640       VOSCHK to file GTAPSUM header "VOCK";
   7641   Formula (all,c,COMM)(all,a,ACTS)(all,r,REG)
   7642       VOSCHK(c,a,r) = 100 * VOSCHK(c,a,r) / MAKEB(c,a,r);
   7643   Write
   7644       VOSCHK to file GTAPSUM header "VOCS" longname "VOSCHK as %";
   7645    
   7646   zerodivide off;
   7647    
   7648   postsim (begin);
   7649   Write
   7650       VDBCHK     to file GTAPSUM header "VMCQ" longname "PostSim VDBCHK as %";
   7651       TRDCHK     to file GTAPSUM header "TRCQ" longname "PostSim TRDCHK as %";
   7652       VTMCHK     to file GTAPSUM header "VTCQ" longname "PostSim VTMCHK as %";
   7653       CHKMKClIMP to file GTAPSUM header "MPCQ" longname "PostSim CHKMKClIMP as %";
   7654       VOSCHK     to file GTAPSUM header "VOCQ" longname "PostSim VOPCHK as %";
   7655       GDPINC     to file GTAPSUM header "GDIP" longname "PostSim GDPINC";
   7656       GDP        to file GTAPSUM header "GDEP" longname "PostSim GDPEXP";
   7657       INCOME     to file GTAPSUM header "INCR" longname "PostSim Income";
   7658   postsim (end);
   7659    
   7660   !<
   7661    
   7662       =========================
   7663       END OF GTAPv7-EP.TAB FILE
   7664       =========================
   7665   >!
   7666    
   7667    
   7668   Write FVAENSHR to file GTAPSUM header "VAES";
   7669   Write EDP to file GTAPSUM header "EDP";
   7670    
   7671   Write
   7672   ! PSHELYVOL to file GTAPSUM header "ELYV";!
   7673    PSHEGENVOL to file GTAPSUM header "EGNV";
   7674    PSHEBLVOL to file GTAPSUM header "EBLV";
   7675    PSHEPLVOL to file GTAPSUM header "EPLV";
   7676    EPA       to file GTAPSUM header "EPA";
   7677    EPAS       to file GTAPSUM header "EPAS";
   7678    
   7679   Write CO2MPVMPP to file GTAPSUM header "COMP";
   7680   Write CO2DP to file GTAPSUM header "CO2M";
   7681   Write VMPP to file GTAPSUM header "VMPP";

