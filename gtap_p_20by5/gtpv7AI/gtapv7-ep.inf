    493   Set
    494       NENYG # non-energy subutility commodities # = COMM - EGY;
    495   Set
    496       TOPG # inputs into top of government demand structure # (eny, neny);
    497   Subset
    498       TOPG is subset of ALLG ;
    499    
    500   !< GTAP-Power: add sets and subset >!
    501   Set
    502       EGENG # inputs into government electricity generation nest: egen #
    503       read elements from file GTAPSETS header "EGNG";
    504   Set
    505       ELYG # inputs into government electricity top-nest #
    506       read elements from file GTAPSETS header "ELYG";
    507   Subset
    508       EBLG is subset of ALLG;
    509   Subset
    510       EPLG is subset of ALLG;
